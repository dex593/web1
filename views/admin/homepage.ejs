<!DOCTYPE html>
<html lang="vi">
  <%- include("../partials/head", { title }) %>
  <body>
    <div class="site admin">
      <%- include("partials/nav") %>
      <main>
        <section class="section container">
          <div class="admin-section-header">
            <div>
              <h1>Trang chủ</h1>
              <p class="note">Cập nhật thông báo và tựa nổi bật hiển thị ngoài trang chủ.</p>
            </div>
          </div>

          <% if (status === "saved") { %>
            <p class="admin-success">Đã cập nhật trang chủ.</p>
          <% } %>

          <%
            const homepageBannerSlots = [1, 2, 3];
            const homepageBannerList = Array.isArray(homepage.banners) ? homepage.banners : [];
            const getHomepageBanner = (slot) =>
              homepageBannerList.find((banner) => Number(banner && banner.slot) === slot) ||
              (slot === 1
                ? {
                  slot: 1,
                  enabled: homepage.bannerEnabled,
                  url: homepage.bannerUrl || "",
                  linkUrl: homepage.bannerLinkUrl || "",
                  updatedAt: homepage.bannerUpdatedAt || 0
                }
                : { slot, enabled: false, url: "", linkUrl: "", updatedAt: 0 });
          %>

          <form class="admin-form" method="post" action="/admin/homepage" enctype="multipart/form-data">
            <div class="panel">
              <div class="admin-section-header">
                <h2>Thông báo</h2>
              </div>
              <div class="admin-grid">
                <label class="admin-field">
                  <span>Tiêu đề 1</span>
                  <input type="text" name="notice_title_1" value="<%= homepage.noticeTitle1 %>" />
                </label>
                <label class="admin-field admin-field--wide">
                  <span>Nội dung 1</span>
                  <textarea name="notice_body_1" rows="3"><%= homepage.noticeBody1 %></textarea>
                </label>
                <label class="admin-field">
                  <span>Tiêu đề 2</span>
                  <input type="text" name="notice_title_2" value="<%= homepage.noticeTitle2 %>" />
                </label>
                <label class="admin-field admin-field--wide">
                  <span>Nội dung 2</span>
                  <textarea name="notice_body_2" rows="3"><%= homepage.noticeBody2 %></textarea>
                </label>
              </div>
              <p class="note">Để trống cả tiêu đề và nội dung để ẩn thông báo.</p>
            </div>

            <div class="panel">
              <div class="admin-section-header">
                <h2>Banner trang ch&#7911;</h2>
              </div>
              <div class="admin-grid">
                <% homepageBannerSlots.forEach((slot) => { %>
                  <% const banner = getHomepageBanner(slot); %>
                  <% const bannerEnabled = Boolean(banner.enabled); %>
                  <div class="admin-field admin-field--wide admin-homepage-banner-slot">
                    <span>Banner <%= slot %></span>
                    <label class="admin-homepage-banner-toggle">
                      <span>Hi&#7875;n th&#7883; banner <%= slot %></span>
                      <input
                        type="checkbox"
                        name="<%= slot === 1 ? 'banner_enabled' : `banner_enabled_${slot}` %>"
                        value="1"
                        data-homepage-banner-toggle
                        <%= bannerEnabled ? "checked" : "" %>
                      />
                    </label>
                    <div class="admin-homepage-banner-fields" data-homepage-banner-fields <%= bannerEnabled ? "" : "hidden" %>>
                      <label>
                        <span>Ch&#7885;n file banner</span>
                        <input type="file" name="banner_<%= slot %>" accept="image/jpeg,image/png,image/webp" />
                      </label>
                      <label>
                        <span>Link khi b&#7845;m banner</span>
                        <input
                          type="text"
                          name="<%= slot === 1 ? 'banner_link_url' : `banner_link_url_${slot}` %>"
                          value="<%= banner.linkUrl || "" %>"
                          placeholder="https://... ho&#7863;c /duong-dan"
                        />
                      </label>
                      <% if (banner.url) { %>
                        <img
                          class="admin-homepage-banner-preview"
                          src="<%= cacheBust(banner.url, banner.updatedAt || 0) %>"
                          alt="Banner trang ch&#7911; <%= slot %> hi&#7879;n t&#7841;i"
                          loading="lazy"
                        />
                      <% } %>
                    </div>
                  </div>
                <% }) %>
              </div>
            </div>

            <div class="panel">
              <div class="admin-section-header">
                <h2>Tựa nổi bật</h2>
              </div>
              <div class="admin-grid">
                <label class="admin-field">
                  <span>Tựa nổi bật 1</span>
                  <select name="featured_1">
                    <option value="">-- Chọn truyện --</option>
                    <% mangaLibrary.forEach((manga) => { %>
                      <option value="<%= manga.id %>" <%= featuredIds[0] === manga.id ? "selected" : "" %>>
                        <%= manga.title %>
                      </option>
                    <% }) %>
                  </select>
                </label>
                <label class="admin-field">
                  <span>Tựa nổi bật 2</span>
                  <select name="featured_2">
                    <option value="">-- Chọn truyện --</option>
                    <% mangaLibrary.forEach((manga) => { %>
                      <option value="<%= manga.id %>" <%= featuredIds[1] === manga.id ? "selected" : "" %>>
                        <%= manga.title %>
                      </option>
                    <% }) %>
                  </select>
                </label>
                <label class="admin-field">
                  <span>Tựa nổi bật 3</span>
                  <select name="featured_3">
                    <option value="">-- Chọn truyện --</option>
                    <% mangaLibrary.forEach((manga) => { %>
                      <option value="<%= manga.id %>" <%= featuredIds[2] === manga.id ? "selected" : "" %>>
                        <%= manga.title %>
                      </option>
                    <% }) %>
                  </select>
                </label>
                <label class="admin-field">
                  <span>Tựa nổi bật 4</span>
                  <select name="featured_4">
                    <option value="">-- Chọn truyện --</option>
                    <% mangaLibrary.forEach((manga) => { %>
                      <option value="<%= manga.id %>" <%= featuredIds[3] === manga.id ? "selected" : "" %>>
                        <%= manga.title %>
                      </option>
                    <% }) %>
                  </select>
                </label>
              </div>
              <p class="note">Chọn tối đa 4 tựa. Nếu bỏ trống, hệ thống sẽ lấy truyện mới cập nhật.</p>
            </div>

            <div class="admin-actions">
              <button class="button" type="submit">Lưu thay đổi</button>
            </div>
          </form>
        </section>
      </main>
    </div>
    <script nonce="<%= cspNonce || "" %>">
      document.querySelectorAll("[data-homepage-banner-toggle]").forEach((toggle) => {
        const slot = toggle.closest(".admin-homepage-banner-slot");
        const fields = slot ? slot.querySelector("[data-homepage-banner-fields]") : null;
        if (!fields) return;
        const syncBannerFields = () => {
          fields.hidden = !toggle.checked;
        };
        toggle.addEventListener("change", syncBannerFields);
        syncBannerFields();
      });
    </script>
  </body>
</html>
