<html lang="vi">
  <%- include("../partials/head", { title }) %>
  <body>
    <% const isTeamMode = Boolean(teamManageScope && teamManageScope.teamId); %>
    <% const initialGroupTeams = Array.isArray(groupTeamSelections) ? groupTeamSelections : []; %>
    <% const initialGroupName = (chapterGroupName || initialGroupTeams.map((item) => item.name).join(' / ') || '').toString(); %>
    <% const initialGroupIds = initialGroupTeams.map((item) => Number(item.id)).filter((id) => Number.isFinite(id) && id > 0).join(','); %>
    <% const lockedGroupTeamIds = isTeamMode
      ? [Number(teamManageScope.teamId)].filter((id) => Number.isFinite(id) && id > 0).map((id) => Math.floor(id))
      : []; %>
    <div class="site admin">
      <%- include("partials/nav") %>
      <main>
        <section class="section container">
          <div class="admin-section-header">
            <div>
              <h1><%= isOneshotManga ? "Thêm Oneshot" : "Thêm chương mới" %></h1>
              <p class="note"><strong><%= manga.title %></strong> — tạo chương và upload trang.</p>
            </div>
            <div class="admin-actions">
              <a class="button button--ghost" href="/admin/manga/<%= manga.id %>/chapters">Quay lại</a>
            </div>
          </div>

          <div class="panel admin-form">
            <div class="admin-section-header">
              <h2>Thông tin chương</h2>
            </div>

            <% if (!b2Ready) { %>
              <p class="admin-error">
                Thiếu cấu hình lưu trữ ảnh trong <code>.env</code>. Vui lòng cấu hình dịch vụ lưu trữ ảnh để upload trang.
              </p>
            <% } else if (!draftToken) { %>
              <p class="admin-error">Không tạo được phiên upload tạm. Vui lòng tải lại trang.</p>
            <% } %>

            <form
              class="admin-grid"
              method="post"
              action="/admin/manga/<%= manga.id %>/chapters/new"
              data-chapter-new-form
              data-b2-ready="<%= b2Ready && draftToken ? "1" : "0" %>"
              data-draft-token="<%= draftToken %>"
              data-draft-ttl-minutes="<%= draftTtlMinutes %>"
              data-chapter-numbers="<%= JSON.stringify(chapterNumbers || []) %>"
              data-chapter-upload-api-base-url="<%= chapterUploadApiBaseUrl || "" %>"
              data-chapter-upload-api-proof="<%= chapterUploadApiProof || "" %>"
              data-is-webtoon="<%= isWebtoonManga ? "1" : "0" %>"
            >
              <input type="hidden" name="draft_token" value="<%= draftToken %>" data-draft-token-input />
              <input type="hidden" name="draft_pages" value="[]" data-draft-pages-input />

              <% if (isOneshotManga) { %>
                <input type="hidden" name="number" value="0" data-chapter-number-input />
                <div class="admin-field admin-field--wide">
                  <span>Loại chương</span>
                  <input type="text" value="Oneshot" readonly />
                  <span class="admin-sub">Truyện đang bật chế độ Oneshot: chỉ tạo 1 chương duy nhất và dùng chung bình luận với trang truyện.</span>
                </div>
              <% } else { %>
                <label class="admin-field">
                  <span>Số chương</span>
                  <input
                    type="text"
                    name="number"
                    inputmode="decimal"
                    pattern="[0-9]+([.,][0-9]+)?"
                    value="<%= nextNumber %>"
                    required
                    autocomplete="off"
                    spellcheck="false"
                    data-chapter-number-input
                  />
                </label>
                <p class="admin-error" data-chapter-number-error hidden></p>

                <label class="admin-field admin-field--wide">
                  <span>Vị trí trong danh sách</span>
                  <select name="position" data-chapter-position-select>
                    <option value="after_latest" selected>Sau chương mới nhất (mặc định)</option>
                    <% (chapterNumbers || []).forEach((value) => { %>
                      <option value="after:<%= value %>">Sau chương <%= value %></option>
                    <% }) %>
                  </select>
                  <span class="admin-sub">
                    Chọn vị trí để hệ thống gợi ý số chương. Bạn vẫn có thể sửa lại số chương thủ công.
                  </span>
                </label>
              <% } %>

              <label class="admin-field admin-field--wide">
                <span>Tiêu đề (tuỳ chọn)</span>
                <input type="text" name="title" autocomplete="off" />
              </label>

              <label
                class="admin-field admin-field--wide admin-team-selector"
                data-team-group-picker
                data-team-search-endpoint="/admin/teams/search"
                data-team-search-iconless="1"
              >
                <span>Nhóm dịch</span>
                <input type="hidden" name="group_name" value="<%= initialGroupName %>" data-team-group-value />
                <input type="hidden" name="group_team_ids" value="<%= initialGroupIds %>" data-team-group-ids />
                <input
                  type="hidden"
                  value="<%= JSON.stringify(initialGroupTeams.map((item) => ({ id: item.id, name: item.name, slug: item.slug }))) %>"
                  data-team-initial-teams
                />
                <input type="hidden" value="<%= JSON.stringify(lockedGroupTeamIds) %>" data-team-locked-ids />

                <div class="admin-team-selector__selected" data-team-selected-list></div>
                <input
                  type="search"
                  placeholder="Tìm nhóm dịch theo tên hoặc slug"
                  autocomplete="off"
                  data-team-search-input
                />
                <div class="admin-team-selector__results" hidden data-team-search-results></div>
                <p class="admin-error" hidden data-team-search-error></p>
                <% if (isTeamMode) { %>
                  <span class="admin-sub">Bạn có thể thêm nhiều nhóm dịch hợp tác. Nhóm của bạn sẽ luôn được giữ trong danh sách.</span>
                <% } else { %>
                  <span class="admin-sub">Chọn một hoặc nhiều nhóm dịch từ danh sách tìm kiếm.</span>
                <% } %>
              </label>

              <div class="panel admin-field admin-field--wide admin-lock-panel">
                <h3 class="admin-lock-panel__title">Khóa chương</h3>

                <% if (canToggleInteractionBoostOnCreate) { %>
                  <label class="admin-field admin-lock-panel__option" data-interaction-boost-wrap>
                    <div class="admin-checkbox-inline">
                      <input type="checkbox" name="interaction_boost_enabled" value="1" data-interaction-boost-toggle />
                      <span>Tăng tương tác</span>
                    </div>
                    <p class="admin-lock-panel__note">
                      Khi bật, chỉ cho phép user đọc chương này nếu chính user đó đã có bình luận ở chương ngay trước. Không thể bật cùng lúc với khóa mật khẩu.
                    </p>
                  </label>
                <% } %>

                <label class="admin-field admin-lock-panel__option">
                  <div class="admin-checkbox-inline">
                    <input type="checkbox" name="chapter_password_enabled" value="1" data-chapter-password-toggle />
                    <span>Cài mật khẩu chương</span>
                  </div>
                  <p class="admin-lock-panel__label">Mật khẩu chương</p>
                  <input
                    type="password"
                    name="chapter_password"
                    minlength="<%= chapterPasswordMinLength %>"
                    maxlength="<%= chapterPasswordMaxLength %>"
                    autocomplete="new-password"
                    spellcheck="false"
                    data-chapter-password-input
                    disabled
                  />
                  <p class="admin-lock-panel__note">
                    Khi bật, ô nhập mật khẩu sẽ được bật để bạn đặt mật khẩu cho chương. Không thể bật cùng lúc với tăng tương tác.
                  </p>
                </label>
              </div>

              <div class="admin-field admin-field--wide">
                <span>Upload trang (tạm)</span>
                <p class="note">
                  Ảnh sẽ tự upload tạm lên khu vực <code>tmp</code> của hệ thống lưu trữ ảnh. Nếu không lưu chương, hệ thống sẽ tự xóa sau
                  <strong><%= draftTtlLabel %></strong>.
                </p>

                <label class="upload-drop <%= b2Ready && draftToken ? "" : "is-disabled" %>" data-upload-drop>
                  <input
                    class="upload-input"
                    type="file"
                    accept="image/jpeg,image/png,image/webp"
                    multiple
                    data-chapter-draft-pages-input
                    <%= b2Ready && draftToken ? "" : "disabled" %>
                  />
                  <span class="upload-drop__title">Kéo thả ảnh vào đây</span>
                  <span class="upload-drop__sub">hoặc bấm để chọn (JPG/PNG/WebP)</span>
                </label>

                <div class="upload-overall upload-overall--inline" hidden data-upload-overall>
                  <div class="upload-progress">
                    <div class="upload-progress__bar" style="width: 0%" data-upload-overall-bar></div>
                  </div>
                  <p class="note" data-upload-overall-text></p>
                </div>

                <div class="admin-error" hidden data-draft-upload-error></div>
                <div class="upload-queue upload-queue--draft" hidden data-upload-queue></div>
              </div>

              <div class="admin-actions">
                <button class="button" type="submit" data-chapter-save disabled><%= isOneshotManga ? "Lưu Oneshot" : "Lưu chương" %></button>
                <button
                  class="button button--ghost"
                  type="button"
                  data-chapter-clear-pages
                  title="Xoá tất cả ảnh đang hiển thị trong danh sách"
                  disabled
                >
                  Xoá tất cả
                </button>
              </div>
            </form>
          </div>
        </section>
      </main>
    </div>
    <script src="/vendor/browser-image-compression/browser-image-compression.js"></script>
    <script nonce="<%= cspNonce || "" %>">
      (() => {
        const form = document.querySelector("[data-chapter-new-form]");
        if (!(form instanceof HTMLFormElement)) return;

        const passwordToggle = form.querySelector("[data-chapter-password-toggle]");
        const passwordInput = form.querySelector("[data-chapter-password-input]");
        const interactionWrap = form.querySelector("[data-interaction-boost-wrap]");
        const interactionToggle = form.querySelector("[data-interaction-boost-toggle]");
        const chapterNumberInput = form.querySelector("[data-chapter-number-input]");
        if (passwordToggle instanceof HTMLInputElement && passwordInput instanceof HTMLInputElement) {
          const initialPasswordValue = passwordInput.value || "";

          const syncPasswordInputState = () => {
            const enabled = Boolean(passwordToggle.checked);
            passwordInput.disabled = !enabled;
            passwordInput.required = enabled;
            if (enabled && !passwordInput.value && initialPasswordValue) {
              passwordInput.value = initialPasswordValue;
            }
            if (!enabled) {
              passwordInput.value = "";
            }
          };

          let chapterNumbers = [];
          if (
            interactionWrap instanceof HTMLElement &&
            interactionToggle instanceof HTMLInputElement &&
            chapterNumberInput instanceof HTMLInputElement
          ) {
            const chapterNumbersRaw = (form.dataset.chapterNumbers || "").toString().trim();
            if (chapterNumbersRaw) {
              try {
                const parsed = JSON.parse(chapterNumbersRaw);
                if (Array.isArray(parsed)) {
                  chapterNumbers = parsed
                    .map((value) => Number(value))
                    .filter((value) => Number.isFinite(value));
                }
              } catch (_error) {
                chapterNumbers = [];
              }
            }
          }

          const syncInteractionToggleState = () => {
            if (
              !(interactionWrap instanceof HTMLElement) ||
              !(interactionToggle instanceof HTMLInputElement) ||
              !(chapterNumberInput instanceof HTMLInputElement)
            ) {
              return;
            }

            const enteredChapterNumber = Number((chapterNumberInput.value || "").toString().replace(",", "."));
            const hasPreviousChapter =
              Number.isFinite(enteredChapterNumber) &&
              chapterNumbers.some((value) => value < enteredChapterNumber);
            interactionWrap.hidden = !hasPreviousChapter;
            interactionToggle.disabled = !hasPreviousChapter;
            if (!hasPreviousChapter) {
              interactionToggle.checked = false;
            }
          };

          const syncChapterLockModes = (source) => {
            if (
              passwordToggle.checked &&
              interactionToggle instanceof HTMLInputElement &&
              interactionToggle.checked
            ) {
              if (source === "interaction") {
                passwordToggle.checked = false;
              } else {
                interactionToggle.checked = false;
              }
            }
            if (source === "password" && passwordToggle.checked && interactionToggle instanceof HTMLInputElement) {
              interactionToggle.checked = false;
            }
            if (source === "interaction" && interactionToggle instanceof HTMLInputElement && interactionToggle.checked) {
              passwordToggle.checked = false;
            }
            syncInteractionToggleState();
            syncPasswordInputState();
          };

          form.addEventListener("submit", () => {
            if (interactionToggle instanceof HTMLInputElement && interactionToggle.checked) {
              passwordToggle.checked = false;
            } else if (passwordToggle.checked && interactionToggle instanceof HTMLInputElement) {
              interactionToggle.checked = false;
            }
            syncChapterLockModes("submit");
          });

          passwordToggle.addEventListener("change", () => syncChapterLockModes("password"));
          if (interactionToggle instanceof HTMLInputElement) {
            interactionToggle.addEventListener("change", () => syncChapterLockModes("interaction"));
          }
          if (chapterNumberInput instanceof HTMLInputElement) {
            chapterNumberInput.addEventListener("input", () => syncChapterLockModes("chapter"));
            chapterNumberInput.addEventListener("change", () => syncChapterLockModes("chapter"));
          }
          syncChapterLockModes();
        }
      })();
    </script>
  </body>
</html>
