<%
  const { truncateCardTitle, buildSafeCoverSources } = coverHelpers;
  const pageState = pagination && typeof pagination === "object"
    ? pagination
    : { page: 1, totalPages: 1, hasPrev: false, hasNext: false, prevPage: 1, nextPage: 1, perPage: 24 };
  const buildCatalogPageHref = (targetPage) => {
    const safeTarget = Number.isFinite(targetPage) && targetPage > 0 ? Math.floor(targetPage) : 1;
    const params = new URLSearchParams();
    if (filters.q) {
      params.set("q", filters.q);
    }
    if (filters.status) {
      params.set("status", filters.status);
    }
    (filters.include || []).forEach((genreId) => {
      params.append("include", String(genreId));
    });
    (filters.exclude || []).forEach((genreId) => {
      params.append("exclude", String(genreId));
    });
    if (pageState.perPage && Number(pageState.perPage) !== 24) {
      params.set("perPage", String(pageState.perPage));
    }
    if (safeTarget > 1) {
      params.set("page", String(safeTarget));
    }
    const query = params.toString();
    return query ? `/manga?${query}` : "/manga";
  };

  const mangaCatalogSpeculationTargets = [];
  const mangaCatalogSpeculationSeen = new Set();
  (mangaLibrary || []).forEach((item, index) => {
    if (index >= 18) return;
    const safeSlug = item && item.slug ? String(item.slug).trim() : "";
    if (!safeSlug) return;
    const href = `/manga/${encodeURIComponent(safeSlug)}`;
    if (mangaCatalogSpeculationSeen.has(href)) return;
    mangaCatalogSpeculationSeen.add(href);
    mangaCatalogSpeculationTargets.push(href);
  });
  const mangaCatalogSpeculationRules = mangaCatalogSpeculationTargets.length
    ? {
      prefetch: [
        {
          source: "list",
          urls: mangaCatalogSpeculationTargets,
          eagerness: "moderate"
        }
      ]
    }
    : null;
  const runtimeSiteConfig = siteConfig && typeof siteConfig === "object" ? siteConfig : {};
  const brandingConfig =
    runtimeSiteConfig.branding && typeof runtimeSiteConfig.branding === "object"
      ? runtimeSiteConfig.branding
      : {};
  const siteName = (brandingConfig.siteName || "BFANG Team").toString().trim() || "BFANG Team";
  const safeJsonForScript = (value) => JSON.stringify(value)
    .replace(/</g, "\\u003c")
    .replace(/>/g, "\\u003e")
    .replace(/&/g, "\\u0026")
    .replace(/\u2028/g, "\\u2028")
    .replace(/\u2029/g, "\\u2029");
%>
<!DOCTYPE html>
<html lang="vi">
  <%- include("partials/head", {
    title
  }) %>
  <body>
    <% if (mangaCatalogSpeculationRules) { %>
      <script type="speculationrules" nonce="<%= cspNonce || "" %>"><%- safeJsonForScript(mangaCatalogSpeculationRules) %></script>
    <% } %>
    <div class="site">
      <%- include("partials/header") %>
      <main>
        <section class="section container">
          <div class="section-header">
            <h1>Toàn bộ truyện</h1>
            <span class="section-line"></span>
          </div>
          <p class="lede">Toàn bộ series do <%= siteName %> lưu trữ và quản lý.</p>
          <div class="filter-panel panel">
            <div class="filter-head">
              <p class="filter-title">Tìm kiếm nâng cao</p>
              <p class="filter-sub">Nhấn 1 lần để chọn, 2 lần để loại trừ, 3 lần để bỏ.</p>
            </div>
            <form class="filter-form filter-form--advanced" action="/manga" method="get">
              <label class="filter-field filter-field--wide">
                <span>Tìm kiếm</span>
                <input
                  type="search"
                  name="q"
                  placeholder="Tên truyện, tác giả"
                  value="<%= filters.q %>"
                />
              </label>
              <label class="filter-field">
                <span>Trạng thái</span>
                <select name="status">
                  <option value="">Tất cả trạng thái</option>
                  <% (filters.statusOptions || []).forEach((option) => { %>
                    <option value="<%= option.value %>" <%= filters.status === option.value ? "selected" : "" %>>
                      <%= option.label %> (<%= option.count %>)
                    </option>
                  <% }) %>
                </select>
              </label>
              <div class="filter-group">
                <p class="filter-group-title">Thể loại</p>
                <% if (genres.length) { %>
                  <div class="filter-options" data-filter-options>
                    <% genres.forEach((genre) => { %>
                      <% const state = filters.include.includes(genre.id)
                        ? "include"
                        : filters.exclude.includes(genre.id)
                        ? "exclude"
                        : "none"; %>
                      <button
                        type="button"
                        class="filter-option filter-option--toggle <%= state === "include" ? "is-include" : state === "exclude" ? "is-exclude" : "" %>"
                        data-genre="<%= genre.id %>"
                        data-state="<%= state %>"
                      >
                        <span class="filter-state"></span>
                        <span class="filter-name"><%= genre.name %></span>
                      </button>
                    <% }) %>
                  </div>
                <% } else { %>
                  <p class="note">Chưa có thể loại để chọn.</p>
                <% } %>
              </div>
              <div class="filter-hidden" data-filter-hidden>
                <% filters.include.forEach((genreId) => { %>
                  <input type="hidden" name="include" value="<%= genreId %>" />
                <% }) %>
                <% filters.exclude.forEach((genreId) => { %>
                  <input type="hidden" name="exclude" value="<%= genreId %>" />
                <% }) %>
              </div>
              <div class="filter-actions">
                <button class="button" type="submit">Tìm kiếm</button>
                <% if (filters.q || filters.status || filters.include.length || filters.exclude.length) { %>
                  <a class="button button--ghost" href="/manga">Xóa lọc</a>
                <% } %>
              </div>
            </form>
            <p class="filter-summary">Tất cả <%= resultCount %> truyện.</p>
          </div>
          <% if (mangaLibrary.length === 0) { %>
            <p class="note">Không có truyện phù hợp với bộ lọc hiện tại.</p>
          <% } else { %>
            <div class="manga-grid manga-grid--catalog manga-grid--list-style">
              <% mangaLibrary.forEach((manga, index) => { %>
                <% const latestChapterLabel = manga.latestChapterIsOneshot ? "Oneshot" : `Ch. ${manga.latestChapterNumber || 0}`; %>
                <% const catalogStatusClass = manga.status === "Hoàn thành" ? "is-complete" : manga.status === "Tạm dừng" ? "is-hiatus" : "is-ongoing"; %>
                <article class="manga-card manga-card--list">
                  <a href="/manga/<%= manga.slug %>">
                    <div class="cover <%= manga.isAdult ? "cover--adult" : "" %>" <%= manga.isAdult ? "data-adult-cover" : "" %>>
                      <% if (manga.cover) { %>
                        <% const catalogCoverBaseUrl = cacheBust(manga.cover, manga.coverUpdatedAt); %>
                        <% const catalogCoverSources = buildSafeCoverSources(catalogCoverBaseUrl, {
                          slotWidths: [132, 172, 262],
                          quality: 95,
                          maxWidth: 900,
                          defaultWidth: 172
                        }); %>
                        <img
                          src="<%= catalogCoverSources.src %>"
                          srcset="<%= catalogCoverSources.srcset %>"
                          sizes="(max-width: 760px) 47vw, 174px"
                          alt="Bìa <%= manga.title %>"
                          loading="lazy"
                          decoding="async"
                          fetchpriority="low"
                          width="420"
                          height="600"
                        />
                      <% } else { %>
                        <span class="cover__label">No Cover</span>
                      <% } %>
                      <span class="manga-badge <%= catalogStatusClass %>">
                        <%= manga.status || "Đang ra" %>
                      </span>
                      <span class="manga-chapter-label"><%= latestChapterLabel %></span>
                    </div>
                    <div class="manga-body">
                      <% const cardTitle = truncateCardTitle(manga.title); %>
                      <h3 title="<%= manga.title %>"><%= cardTitle %></h3>
                      <div class="manga-list-meta" aria-label="Thông tin truyện">
                        <span><i class="fa-regular fa-eye" aria-hidden="true"></i> <%= Number((manga.totalViews ?? manga.total_views) || 0).toLocaleString("vi-VN") %> lượt xem</span>
                        <span><i class="fa-regular fa-bookmark" aria-hidden="true"></i> <%= Number((manga.bookmarkCount ?? manga.bookmark_count) || 0).toLocaleString("vi-VN") %> lượt lưu</span>
                        <span><i class="fa-regular fa-comments" aria-hidden="true"></i> <%= Number((manga.commentCount ?? manga.comment_count) || 0).toLocaleString("vi-VN") %> bình luận</span>
                      </div>
                    </div>
                  </a>
                </article>
              <% }) %>
            </div>

            <% if (pageState.totalPages > 1) { %>
              <% const catalogVisiblePageNumbers = []; %>
              <% if (pageState.totalPages <= 6) { %>
                <% for (let i = 1; i <= pageState.totalPages; i += 1) { catalogVisiblePageNumbers.push(i); } %>
              <% } else if (pageState.page <= 3) { %>
                <% catalogVisiblePageNumbers.push(1, 2, 3, 4, "...", pageState.totalPages); %>
              <% } else if (pageState.page >= pageState.totalPages - 2) { %>
                <% catalogVisiblePageNumbers.push(1, "...", pageState.totalPages - 3, pageState.totalPages - 2, pageState.totalPages - 1, pageState.totalPages); %>
              <% } else { %>
                <% catalogVisiblePageNumbers.push(1, "...", pageState.page - 1, pageState.page, pageState.page + 1, "...", pageState.totalPages); %>
              <% } %>

              <nav class="admin-pagination" aria-label="Phân trang truyện">
                <a
                  class="button button--ghost <%= pageState.hasPrev ? "" : "is-disabled" %>"
                  href="<%= pageState.hasPrev ? buildCatalogPageHref(pageState.prevPage) : "#" %>"
                  aria-label="Trang trước"
                  <%= pageState.hasPrev ? "" : 'tabindex="-1" aria-disabled="true"' %>
                >
                  Trước
                </a>

                <div class="admin-pagination__numbers">
                  <% catalogVisiblePageNumbers.forEach((num) => { %>
                    <% if (num === "...") { %>
                      <span class="admin-pagination__dots">...</span>
                    <% } else if (num === pageState.page) { %>
                      <span class="chip"><%= num %></span>
                    <% } else { %>
                      <a class="button button--ghost" href="<%= buildCatalogPageHref(num) %>"><%= num %></a>
                    <% } %>
                  <% }) %>
                </div>

                <a
                  class="button button--ghost <%= pageState.hasNext ? "" : "is-disabled" %>"
                  href="<%= pageState.hasNext ? buildCatalogPageHref(pageState.nextPage) : "#" %>"
                  aria-label="Trang sau"
                  <%= pageState.hasNext ? "" : 'tabindex="-1" aria-disabled="true"' %>
                >
                  Sau
                </a>
              </nav>
            <% } %>
          <% } %>
        </section>
      </main>
      <%- include("partials/footer") %>
    </div>
  </body>
</html>
