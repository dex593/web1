<%
  const { appendCoverVariant } = coverHelpers;
  const mangaDetailHeadScripts = {
    comments: false,
    readingHistory: true,
    bookmarks: true
  };

  const detailCoverBaseUrl = manga && manga.cover ? cacheBust(manga.cover, manga.coverUpdatedAt) : "";
  const detailCover194 = appendCoverVariant(detailCoverBaseUrl, 194, 291, 95);
  const detailCover324 = appendCoverVariant(detailCoverBaseUrl, 324, 486, 95);
  const detailCover384 = appendCoverVariant(detailCoverBaseUrl, 384, 576, 95);
  const detailCover564 = appendCoverVariant(detailCoverBaseUrl, 564, 846, 95);
%>
<!DOCTYPE html>
<html lang="vi">
  <%- include("partials/head", {
    title,
    headScripts: mangaDetailHeadScripts
  }) %>
  <body>
    <div class="site">
      <%- include("partials/header") %>
      <main>
        <section class="section container">
          <div class="detail-grid">
            <div class="detail-cover reveal" style="--delay: 0.05s;">
              <div class="cover cover--detail">
                <% if (manga.cover) { %>
                  <img
                    src="<%= detailCover194 %>"
                    srcset="<%= `${detailCover194} 194w, ${detailCover324} 324w, ${detailCover384} 384w, ${detailCover564} 564w` %>"
                    sizes="(max-width: 760px) 70vw, 194px"
                    alt="Bìa <%= manga.title %>"
                    loading="eager"
                    decoding="async"
                    fetchpriority="high"
                    width="420"
                    height="600"
                  />
                <% } else { %>
                  <span class="cover__label">No Cover</span>
                <% } %>
              </div>
            </div>
            <div class="detail-info reveal" style="--delay: 0.1s;">
              <div class="section-header">
                <h1><%= manga.title %></h1>
                <span class="section-line"></span>
              </div>
              <% const groupLinks = Array.isArray(manga.groupTeamLinks)
                ? manga.groupTeamLinks
                  .map((item) => ({
                    label: item && item.label ? String(item.label).trim() : "",
                    url: item && item.url ? String(item.url).trim() : ""
                  }))
                  .filter((item) => item.label)
                : []; %>
              <% if (groupLinks.length) { %>
                <p class="manga-author">
                  Nhóm dịch:
                  <% groupLinks.forEach((groupItem, index) => { %>
                    <% if (groupItem.url) { %>
                      <a class="inline-link" href="<%= groupItem.url %>">
                        <%= groupItem.label %>
                      </a>
                    <% } else { %>
                      <span><%= groupItem.label %></span>
                    <% } %><%= index < groupLinks.length - 1 ? ", " : "" %>
                  <% }) %>
                </p>
              <% } %>
              <% const authors = (manga.author || "")
                .split(",")
                .map((value) => value.trim())
                .filter(Boolean); %>
              <% if (authors.length) { %>
                <p class="manga-author">
                  Tác giả:
                  <% authors.forEach((authorName, index) => { %>
                    <a class="inline-link" href="/manga?q=<%= encodeURIComponent(authorName) %>">
                      <%= authorName %>
                    </a><%= index < authors.length - 1 ? ", " : "" %>
                  <% }) %>
                </p>
              <% } %>
              <% const otherNames = (manga.otherNames || "")
                .split(/\r?\n/)
                .map((value) => value.trim())
                .filter(Boolean); %>
              <% if (otherNames.length) { %>
                <p class="note">Tên khác: <%= otherNames.join(" • ") %></p>
              <% } %>
              <div class="meta-row">
                <span class="tag"><%= manga.status %></span>
                <span class="meta">Cập nhật <%= formatDate(manga.updatedAt) %></span>
              </div>
              <% const latestChapterForProgress = manga && manga.latestChapterNumber
                ? { number: manga.latestChapterNumber }
                : null; %>
              <% const firstChapterForProgress = manga && manga.firstChapterNumber
                ? { number: manga.firstChapterNumber }
                : null; %>
              <div class="chips">
                <% manga.genres.forEach((genre) => { %>
                  <a class="chip" href="/manga?include=<%= encodeURIComponent(genre) %>">
                    <%= genre %>
                  </a>
                <% }) %>
              </div>
              <div class="manga-view-total" title="Tổng lượt xem tất cả chương">
                <span class="view-eye" aria-hidden="true">
                  <svg
                    class="view-eye-icon"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.8"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                  >
                    <path d="M2.2 12c1.9-3.6 5.6-6 9.8-6s7.9 2.4 9.8 6c-1.9 3.6-5.6 6-9.8 6s-7.9-2.4-9.8-6Z" />
                    <circle cx="12" cy="12" r="2.9" />
                  </svg>
                </span>
                <span><%= Number(manga && manga.totalViews ? manga.totalViews : 0).toLocaleString("vi-VN") %> lượt xem</span>
              </div>
              <div class="detail-actions">
                <button
                  class="chip chip--link share-chip"
                  type="button"
                  data-share-button
                >
                  <i class="fa-solid fa-share-nodes" aria-hidden="true"></i>
                  <span data-share-label>Chia sẻ</span>
                </button>
                <button
                  class="chip chip--link share-chip detail-bookmark-button <%= mangaBookmarked ? "is-bookmarked" : "" %>"
                  type="button"
                  data-manga-bookmark-button
                  data-manga-slug="<%= manga.slug %>"
                  data-bookmarked="<%= mangaBookmarked ? "1" : "0" %>"
                >
                  <i class="fa-regular fa-bookmark" aria-hidden="true"></i>
                  <span data-bookmark-label><%= mangaBookmarked ? "Đã bookmark" : "Bookmark" %></span>
                </button>
              </div>
              <div
                class="detail-continue-slot"
                hidden
                data-reading-detail-continue
                data-manga-slug="<%= manga.slug %>"
                data-latest-chapter-number="<%= latestChapterForProgress ? latestChapterForProgress.number : "" %>"
                data-first-chapter-url="<%= firstChapterForProgress ? `/manga/${encodeURIComponent(manga.slug)}/chapters/${encodeURIComponent(String(firstChapterForProgress.number))}` : "" %>"
              ></div>
              <% if (manga.description) { %>
                <div
                  class="manga-description"
                  data-description-wrap
                  data-description-max="280"
                  data-description-max-mobile="200"
                >
                  <p class="lede manga-description__text">
                    <span data-description-content><%= manga.description %></span>
                    <button
                      class="inline-button manga-description__toggle"
                      type="button"
                      data-description-toggle
                      data-button-icon-skip="1"
                      hidden
                    >
                      Xem thêm
                    </button>
                  </p>
                </div>
              <% } %>
            </div>
          </div>
        </section>

        <section id="chapters" class="section container">
          <% const chapterPage = chapterPagination && chapterPagination.page ? Number(chapterPagination.page) : 1; %>
          <% const chapterTotalPages = chapterPagination && chapterPagination.totalPages ? Number(chapterPagination.totalPages) : 1; %>
          <% const chapterPageHref = (targetPage) => {
            const safeTarget = Number.isFinite(targetPage) && targetPage > 0 ? Math.floor(targetPage) : 1;
            if (safeTarget <= 1) return `/manga/${manga.slug}#chapters`;
            return `/manga/${manga.slug}?chapterPage=${safeTarget}#chapters`;
          }; %>
          <div class="section-header">
            <h2>Danh sách chương</h2>
            <span class="section-line"></span>
          </div>
          <% if (manga.chapters.length === 0) { %>
            <p class="note">Chưa có chương nào được đăng.</p>
          <% } else { %>
            <div class="chapter-table">
              <% const endChapterNumber = Number(manga && manga.latestChapterNumber ? manga.latestChapterNumber : 0); %>
              <ul class="chapter-list">
                <% manga.chapters.forEach((chapter) => { %>
                  <% const isOneshotChapter = Boolean(chapter && chapter.is_oneshot); %>
                  <% const chapterLabel = isOneshotChapter ? "Oneshot" : `Ch. ${chapter.number}`; %>
                  <% const isEndChapter = manga.status === "Hoàn thành" &&
                    Number(chapter.number) === endChapterNumber; %>
                  <li class="chapter">
                    <a
                      class="chapter-link"
                      href="/manga/<%= manga.slug %>/chapters/<%= chapter.number %>"
                      aria-label="Xem <%= chapterLabel %>"
                    >
                      <div class="chapter-main">
                        <div class="chapter-title-row">
                          <span class="chapter-num"><%= chapterLabel %></span>
                          <% const chapterTitle = (chapter.title || "").toString().trim(); %>
                          <% if (chapterTitle) { %>
                            <span class="chapter-sep" aria-hidden="true">-</span>
                            <span class="chapter-title" title="<%= chapterTitle %>"><%= chapterTitle %></span>
                          <% } %>
                          <% if (isEndChapter) { %>
                            <span class="chapter-badge" title="Chương kết">END</span>
                          <% } %>
                        </div>
                        <% const chapterGroups = (chapter.group_name || "")
                          .split(",")
                          .map((value) => value.trim())
                          .filter(Boolean); %>
                        <% if (chapterGroups.length) { %>
                          <div class="chapter-subrow" title="Nhóm dịch">
                            <svg
                              class="chapter-icon"
                              viewBox="0 0 24 24"
                              fill="none"
                              stroke="currentColor"
                              stroke-width="1.6"
                              aria-hidden="true"
                            >
                              <circle cx="12" cy="8" r="4" />
                              <path d="M4 20c1.6-3.5 5-5 8-5s6.4 1.5 8 5" />
                            </svg>
                            <span class="chapter-sub-text"><%= chapterGroups.join(", ") %></span>
                          </div>
                        <% } %>
                      </div>
                      <div class="chapter-meta">
                        <span
                          class="chapter-time"
                          title="<%= chapter.pages %> trang - <%= formatDate(chapter.date) %>"
                        >
                          <svg
                            class="chapter-icon"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="1.6"
                            aria-hidden="true"
                          >
                            <circle cx="12" cy="12" r="9" />
                            <path d="M12 7v5l3 2" />
                          </svg>
                          <%= formatTimeAgo(chapter.date) %>
                        </span>
                        <span class="chapter-views" title="Lượt xem chương">
                          <span class="view-eye" aria-hidden="true">
                            <svg
                              class="view-eye-icon"
                              viewBox="0 0 24 24"
                              fill="none"
                              stroke="currentColor"
                              stroke-width="1.8"
                              stroke-linecap="round"
                              stroke-linejoin="round"
                              aria-hidden="true"
                            >
                              <path d="M2.2 12c1.9-3.6 5.6-6 9.8-6s7.9 2.4 9.8 6c-1.9 3.6-5.6 6-9.8 6s-7.9-2.4-9.8-6Z" />
                              <circle cx="12" cy="12" r="2.9" />
                            </svg>
                          </span>
                          <span><%= Number(chapter && chapter.view_count ? chapter.view_count : 0).toLocaleString("vi-VN") %> lượt xem</span>
                        </span>
                      </div>
                    </a>
                  </li>
                <% }) %>
              </ul>
            </div>
            <% if (chapterTotalPages > 1) { %>
              <% const chapterVisiblePageNumbers = []; %>
              <% if (chapterTotalPages <= 6) { %>
                <% for (let i = 1; i <= chapterTotalPages; i += 1) { chapterVisiblePageNumbers.push(i); } %>
              <% } else if (chapterPage <= 3) { %>
                <% chapterVisiblePageNumbers.push(1, 2, 3, 4, "...", chapterTotalPages); %>
              <% } else if (chapterPage >= chapterTotalPages - 2) { %>
                <% chapterVisiblePageNumbers.push(1, "...", chapterTotalPages - 3, chapterTotalPages - 2, chapterTotalPages - 1, chapterTotalPages); %>
              <% } else { %>
                <% chapterVisiblePageNumbers.push(1, "...", chapterPage - 1, chapterPage, chapterPage + 1, "...", chapterTotalPages); %>
              <% } %>

              <nav class="admin-pagination" aria-label="Phân trang chương truyện">
                <a
                  class="button button--ghost <%= chapterPagination && chapterPagination.hasPrev ? "" : "is-disabled" %>"
                  href="<%= chapterPagination && chapterPagination.hasPrev ? chapterPageHref(chapterPagination.prevPage) : "#" %>"
                  aria-label="Trang chương trước"
                  <%= chapterPagination && chapterPagination.hasPrev ? "" : 'tabindex="-1" aria-disabled="true"' %>
                >
                  Trước
                </a>

                <div class="admin-pagination__numbers">
                  <% chapterVisiblePageNumbers.forEach((num) => { %>
                    <% if (num === "...") { %>
                      <span class="admin-pagination__dots">...</span>
                    <% } else if (num === chapterPage) { %>
                      <span class="chip"><%= num %></span>
                    <% } else { %>
                      <a class="button button--ghost" href="<%= chapterPageHref(num) %>"><%= num %></a>
                    <% } %>
                  <% }) %>
                </div>

                <a
                  class="button button--ghost <%= chapterPagination && chapterPagination.hasNext ? "" : "is-disabled" %>"
                  href="<%= chapterPagination && chapterPagination.hasNext ? chapterPageHref(chapterPagination.nextPage) : "#" %>"
                  aria-label="Trang chương sau"
                  <%= chapterPagination && chapterPagination.hasNext ? "" : 'tabindex="-1" aria-disabled="true"' %>
                >
                  Sau
                </a>
              </nav>
            <% } %>
          <% } %>
        </section>

        <% if (commentsHydrated) { %>
          <%- include("partials/manga-comments-section", {
            manga,
            comments,
            commentCount,
            commentPagination,
            commentComposerEnabled
          }) %>
        <% } else { %>
          <section
            id="comments"
            class="section container"
            data-comment-lazy="1"
            data-comment-load-url="<%= commentsLoadUrl %>"
            data-comment-mention-url="/manga/<%= manga.slug %>/comment-mentions"
            data-comment-manga-slug="<%= manga.slug %>"
            data-comment-manga-title="<%= manga.title %>"
            data-comment-scope="manga"
            data-comment-script-src="<%= cacheBust('/comments.js', assetVersion) %>"
          >
            <div class="section-header">
              <h2>Bình luận (<%= commentCount %>)</h2>
              <span class="section-line"></span>
            </div>
            <div class="panel">
              <p class="note">Đang tải bình luận...</p>
              <noscript>
                <p class="note">
                  Trình duyệt của bạn đã tắt JavaScript.
                  <a class="inline-link" href="<%= `${commentsLoadUrl}#comments` %>">Bấm vào đây để xem bình luận.</a>
                </p>
              </noscript>
            </div>
          </section>
        <% } %>
      </main>
      <%- include("partials/comments-lazy-loader") %>
      <%- include("partials/footer") %>
    </div>
  </body>
</html>
