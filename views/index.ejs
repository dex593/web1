<%
  const { truncateCardTitle, buildSafeCoverSources } = coverHelpers;
  const firstFeatured = Array.isArray(featured) && featured.length > 0 ? featured[0] : null;
  const firstFeaturedCoverBaseUrl = firstFeatured && firstFeatured.cover
    ? cacheBust(firstFeatured.cover, firstFeatured.coverUpdatedAt)
    : "";
  const firstFeaturedCoverSources = firstFeaturedCoverBaseUrl
    ? buildSafeCoverSources(firstFeaturedCoverBaseUrl, {
      slotWidths: [358],
      dprLevels: [1],
      quality: 95,
      maxWidth: 960,
      defaultWidth: 360
    })
    : { src: "", srcset: "" };
  const firstFeaturedCover = firstFeaturedCoverSources.src;
  const homepageHeadPreloadImages = firstFeaturedCover ? [firstFeaturedCover] : [];
  const latestForumPosts = Array.isArray(forumLatestPosts) ? forumLatestPosts : [];
  const homepageTopRankingSource = topRankings && typeof topRankings === "object" ? topRankings : {};
  const homepageTopRankingPeriods = [
    {
      key: "week",
      label: "Tuần",
      items: Array.isArray(homepageTopRankingSource.week) ? homepageTopRankingSource.week : []
    },
    {
      key: "month",
      label: "Tháng",
      items: Array.isArray(homepageTopRankingSource.month) ? homepageTopRankingSource.month : []
    },
    {
      key: "total",
      label: "Tổng",
      items: Array.isArray(homepageTopRankingSource.total) ? homepageTopRankingSource.total : []
    }
  ];
  const homepageTopRankingDefaultPeriod =
    (homepageTopRankingPeriods.find((period) => period.key === "week" && period.items.length > 0) ||
      homepageTopRankingPeriods.find((period) => period.items.length > 0) ||
      { key: "week" }).key;
  const hasHomepageTopRankings = homepageTopRankingPeriods.some((period) => period.items.length > 0);
  const homepageRecentComments = Array.isArray(recentComments) ? recentComments : [];
  const isForumHomepageEnabled = Boolean(forumPageEnabled);
  const homepageSpeculationTargets = [];
  const homepageSpeculationSeen = new Set();
  const appendHomepageSpeculationTarget = (slug) => {
    const safeSlug = (slug || "").toString().trim();
    if (!safeSlug) return;
    const href = `/manga/${encodeURIComponent(safeSlug)}`;
    if (homepageSpeculationSeen.has(href)) return;
    homepageSpeculationSeen.add(href);
    homepageSpeculationTargets.push(href);
  };

  (featured || []).forEach((item) => appendHomepageSpeculationTarget(item && item.slug));
  (latest || []).forEach((item) => appendHomepageSpeculationTarget(item && item.slug));
  homepageTopRankingPeriods.forEach((period) => {
    period.items.forEach((item) => appendHomepageSpeculationTarget(item && item.slug));
  });

  const formatCompactViews = (value) => {
    const safeValue = Number(value) || 0;
    if (safeValue >= 1000) {
      if (safeValue < 10000) {
        const compactOneDecimal = Math.floor((safeValue / 1000) * 10) / 10;
        return `${compactOneDecimal.toFixed(1).replace(/\.0$/, "")}K`;
      }

      return `${Math.floor(safeValue / 1000)}K`;
    }
    return Math.max(0, Math.floor(safeValue)).toString();
  };

  const truncateCommentPreview = (value, maxLength = 160) => {
    const safeText = (value == null ? "" : String(value)).replace(/\s+/g, " ").trim();
    if (!safeText) return "Bình luận trống.";
    const safeMaxLength = Number.isFinite(Number(maxLength)) ? Math.max(30, Math.floor(Number(maxLength))) : 160;
    if (safeText.length <= safeMaxLength) return safeText;
    return `${safeText.slice(0, safeMaxLength - 3).trim()}...`;
  };

  const formatChapterNumberText = (value) => {
    const chapterNumber = Number(value);
    if (!Number.isFinite(chapterNumber)) return "";
    if (Math.abs(chapterNumber - Math.round(chapterNumber)) < 1e-9) {
      return String(Math.round(chapterNumber));
    }
    return chapterNumber.toFixed(3).replace(/0+$/, "").replace(/\.$/, "");
  };

  const homepageSpeculationRules = homepageSpeculationTargets.length
    ? {
      prefetch: [
        {
          source: "list",
          urls: homepageSpeculationTargets.slice(0, 14),
          eagerness: "moderate"
        }
      ]
    }
    : null;

  const runtimeSiteConfig = siteConfig && typeof siteConfig === "object" ? siteConfig : {};
  const brandingConfig =
    runtimeSiteConfig.branding && typeof runtimeSiteConfig.branding === "object"
      ? runtimeSiteConfig.branding
      : {};
  const homepageConfig =
    runtimeSiteConfig.homepage && typeof runtimeSiteConfig.homepage === "object"
      ? runtimeSiteConfig.homepage
      : {};
  const contactConfig =
    runtimeSiteConfig.contact && typeof runtimeSiteConfig.contact === "object"
      ? runtimeSiteConfig.contact
      : {};

  const siteName = (brandingConfig.siteName || "BFANG Team").toString().trim() || "BFANG Team";
  const brandMark = (brandingConfig.brandMark || "BFANG").toString().trim() || "BFANG";
  const heroKicker = (brandingConfig.heroKicker || `${siteName} Manga`).toString().trim() || `${siteName} Manga`;
  const updateTag = (brandingConfig.updateTag || brandMark).toString().trim() || brandMark;
  const welcomeMessage =
    (homepageConfig.welcomeMessage || `Chào mừng bạn đến với website của ${siteName}.`).toString().trim() ||
    `Chào mừng bạn đến với website của ${siteName}.`;
  const introductionText =
    (homepageConfig.introduction ||
      `${siteName} là nhóm dịch manga hoạt động từ năm 2019 với hàng chục đầu truyện và hàng trăm chương truyện.`)
      .toString()
      .trim();
  const aboutTitle = (homepageConfig.aboutTitle || `Về ${siteName}`).toString().trim() || `Về ${siteName}`;
  const foundedYear = (homepageConfig.foundedYear || "2019").toString().trim() || "2019";
  const contentStandardsTitle =
    (homepageConfig.contentStandardsTitle || "Tiêu chuẩn nội dung").toString().trim() || "Tiêu chuẩn nội dung";
  const contactTitle = (homepageConfig.contactTitle || "Kênh liên hệ").toString().trim() || "Kênh liên hệ";
  const fallbackContentStandards = [
    "Chúng tôi chỉ làm manga, và thể loại yêu thích nhất là Drama.",
    "Các dự án được dịch thuật từ tiếng Anh hoặc tiếng Nhật và sử dụng Adobe Photoshop để biên tập."
  ];
  const normalizedContentStandards = Array.isArray(homepageConfig.contentStandards)
    ? homepageConfig.contentStandards
      .map((item) => (item == null ? "" : String(item)).trim())
      .filter(Boolean)
    : [];
  const contentStandards = normalizedContentStandards.length ? normalizedContentStandards : fallbackContentStandards;

  const normalizeExternalUrl = (value) => {
    const raw = (value || "").toString().trim();
    if (!raw) return "";

    let candidate = raw;
    if (!/^https?:\/\//i.test(candidate)) {
      candidate = `https://${candidate.replace(/^\/+/, "")}`;
    }

    try {
      const parsed = new URL(candidate);
      if (parsed.protocol !== "https:" && parsed.protocol !== "http:") return "";
      return `${parsed.protocol}//${parsed.host}${parsed.pathname || "/"}${parsed.search || ""}`;
    } catch (_err) {
      return "";
    }
  };

  const facebookUrl =
    normalizeExternalUrl(contactConfig.facebookUrl || "") ||
    "https://facebook.com/Bfangteam/";
  const facebookLabel =
    (contactConfig.facebookLabel || "facebook.com/Bfangteam").toString().trim() || "facebook.com/Bfangteam";
  const discordUrl =
    normalizeExternalUrl(contactConfig.discordUrl || "") ||
    "https://discord.moetruyen.net/";
  const discordLabel =
    (contactConfig.discordLabel || "discord.moetruyen.net").toString().trim() || "discord.moetruyen.net";
  const truncateDescription = (value, maxLength) => {
    const normalized = (value == null ? "" : String(value)).replace(/\s+/g, " ").trim();
    if (!normalized) return "Đang cập nhật mô tả truyện.";
    const safeMax = Number.isFinite(Number(maxLength)) ? Math.max(40, Math.floor(Number(maxLength))) : 170;
    if (normalized.length <= safeMax) return normalized;
    return `${normalized.slice(0, safeMax - 3).trim()}...`;
  };
  const safeJsonForScript = (value) => JSON.stringify(value)
    .replace(/</g, "\\u003c")
    .replace(/>/g, "\\u003e")
    .replace(/&/g, "\\u0026")
    .replace(/\u2028/g, "\\u2028")
    .replace(/\u2029/g, "\\u2029");
%>
<!DOCTYPE html>
<html lang="vi">
  <%- include("partials/head", {
    title,
    headPreloadImages: homepageHeadPreloadImages
  }) %>
  <body>
    <% if (homepageSpeculationRules) { %>
      <script type="speculationrules" nonce="<%= cspNonce || "" %>"><%- safeJsonForScript(homepageSpeculationRules) %></script>
    <% } %>
    <div class="site">
      <%- include("partials/header") %>
      <main data-homepage-signature="<%= homepageSignature %>">
        <section class="intro container">
          <div class="intro-header reveal" style="--delay: 0.1s;">
            <div class="intro-copy">
              <p class="kicker"><%= heroKicker %></p>
              <h1><%= welcomeMessage %></h1>
              <p class="lede"><%= introductionText %></p>
            </div>
            <div class="intro-actions">
              <a class="button button--ghost" href="#featured">Tựa nổi bật</a>
            </div>
          </div>
          <div class="intro-grid">
            <div class="panel intro-card intro-card--overview reveal" style="--delay: 0.15s;">
              <p class="intro-label">Tổng quan</p>
              <div class="stat-grid">
                <div>
                  <span class="stat-value"><%= stats.totalSeries %></span>
                  <span class="stat-label">Truyện</span>
                </div>
                <div>
                  <span class="stat-value"><%= stats.totalChapters %></span>
                  <span class="stat-label">Chương</span>
                </div>
              </div>
            </div>
            <div class="panel intro-card reveal" style="--delay: 0.2s;">
              <p class="intro-label">Thông báo</p>
              <% if (homepage && homepage.notices && homepage.notices.length) { %>
                <div class="intro-notes">
                  <% homepage.notices.forEach((notice) => { %>
                    <div class="intro-note">
                      <% if (notice.title) { %>
                        <span class="intro-note-title"><%= notice.title %></span>
                      <% } %>
                      <% if (notice.body) { %>
                        <p class="intro-text"><%= notice.body %></p>
                      <% } %>
                    </div>
                  <% }) %>
                </div>
              <% } else { %>
                <p class="intro-text">Chưa có thông báo.</p>
              <% } %>
              <div class="intro-meta">
                <span class="tag"><%= updateTag %></span>
                <span class="meta">Theo dõi cập nhật mới nhất</span>
              </div>
            </div>
          </div>
        </section>

        <% if (isForumHomepageEnabled && latestForumPosts.length > 0) { %>
          <section class="section container">
            <div class="section-header">
              <h2>Diễn đàn</h2>
              <span class="section-line"></span>
            </div>
            <div class="panel forum-latest-panel reveal" style="--delay: 0.18s;">
              <div class="forum-latest-list" role="list" aria-label="<%= latestForumPosts.length %> bài viết forum mới nhất">
                <% latestForumPosts.forEach((post) => { %>
                  <article class="forum-latest-item" role="listitem">
                    <a class="forum-latest-link" href="<%= post.href %>">
                      <div class="forum-latest-avatar-wrap">
                        <% if (post.avatarUrl) { %>
                          <img
                            class="forum-latest-avatar"
                            src="<%= post.avatarUrl %>"
                            alt="Avatar của <%= post.authorName %>"
                            loading="lazy"
                            onerror="this.hidden=true;if(this.nextElementSibling){this.nextElementSibling.hidden=false;}"
                          />
                        <% } %>
                        <span class="forum-latest-avatar forum-latest-avatar--fallback" <%= post.avatarUrl ? "hidden" : "" %> aria-hidden="true"><%= post.avatarFallback %></span>
                      </div>
                      <div class="forum-latest-item__body">
                        <h3 title="<%= post.title %>"><%= post.title %></h3>
                        <p class="forum-latest-item__meta">
                          <span
                            class="forum-latest-item__meta-part forum-latest-item__meta-part--author"
                            <% if (post.authorColor) { %>style="color: <%= post.authorColor %>;"<% } %>
                          ><%= post.metadataAuthor %></span>
                          <span class="forum-latest-item__meta-part"><%= post.timeAgo %></span>
                          <span class="forum-latest-item__meta-part"><%= post.commentCount %> bình luận</span>
                        </p>
                      </div>
                      <span class="forum-latest-item__category"><%= post.sectionLabel %></span>
                    </a>
                  </article>
                <% }) %>
              </div>
              <div class="forum-latest-footer">
                <a class="forum-latest-footer__link" href="/forum" aria-label="Vào forum" title="Vào forum">
                  <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                    <path d="M3 12h16"></path>
                    <path d="m13 5 8 7-8 7"></path>
                  </svg>
                </a>
              </div>
            </div>
          </section>
        <% } %>

        <section id="featured" class="section container">
          <div class="section-header section-header--homepage-featured">
            <h2>
              Truyện nổi bật
            </h2>
            <a class="section-header__view-all" href="/manga">
              <span>Xem tất cả</span>
              <i class="fa-solid fa-arrow-right-long" aria-hidden="true"></i>
            </a>
          </div>
          <div class="manga-grid manga-grid--featured-showcase">
            <% featured.forEach((manga, index) => { %>
              <% const featuredDescription = truncateDescription(manga.description, 190); %>
              <% const featuredStatusClass = manga.status === "Hoàn thành" ? "is-complete" : manga.status === "Tạm dừng" ? "is-hiatus" : "is-ongoing"; %>
              <article class="manga-card manga-card--featured">
                <a href="/manga/<%= manga.slug %>">
                  <div class="cover <%= manga.isAdult ? "cover--adult" : "" %>" <%= manga.isAdult ? "data-adult-cover" : "" %>>
                    <% if (manga.cover) { %>
                      <% const featuredCoverBaseUrl = cacheBust(manga.cover, manga.coverUpdatedAt); %>
                      <% const featuredCoverSources = buildSafeCoverSources(featuredCoverBaseUrl, {
                        slotWidths: [172, 264, 358],
                        quality: 95,
                        maxWidth: 960,
                        defaultWidth: 360
                      }); %>
                      <img
                        src="<%= featuredCoverSources.src %>"
                        srcset="<%= featuredCoverSources.srcset %>"
                        sizes="(max-width: 760px) 47vw, (max-width: 1200px) 31vw, 358px"
                        alt="Bìa <%= manga.title %>"
                        loading="<%= index === 0 ? "eager" : "lazy" %>"
                        decoding="async"
                        fetchpriority="<%= index === 0 ? "high" : "low" %>"
                        width="420"
                        height="600"
                      />
                    <% } else { %>
                      <span class="cover__label">No Cover</span>
                    <% } %>
                    <span class="manga-badge <%= featuredStatusClass %>">
                      <%= manga.status || "Đang ra" %>
                    </span>
                  </div>
                  <div class="manga-body">
                    <% const featuredCardTitle = truncateCardTitle(manga.title); %>
                    <h3 title="<%= manga.title %>"><%= featuredCardTitle %></h3>
                    <p class="manga-author"><%= manga.groupName || manga.author || "Đang cập nhật" %></p>
                    <p class="manga-description-preview" data-nosnippet><%= featuredDescription %></p>
                    <div class="manga-featured-meta" aria-label="Thông tin truyện nổi bật">
                      <span><i class="fa-regular fa-eye" aria-hidden="true"></i> <%= Number((manga.totalViews ?? manga.total_views) || 0).toLocaleString("vi-VN") %> lượt xem</span>
                      <span><i class="fa-solid fa-book-open" aria-hidden="true"></i> <%= Number((manga.chapterCount ?? manga.chapter_count) || 0).toLocaleString("vi-VN") %> chương</span>
                      <span><i class="fa-regular fa-comments" aria-hidden="true"></i> <%= Number((manga.commentCount ?? manga.comment_count) || 0).toLocaleString("vi-VN") %> bình luận</span>
                    </div>
                    <div class="manga-featured-footer">
                      <span class="manga-status-pill <%= featuredStatusClass %>">
                        <%= manga.status || "Đang ra" %>
                      </span>
                    </div>
                  </div>
                </a>
              </article>
            <% }) %>
          </div>
        </section>

        <% const randomSlicePool = Array.isArray(randomPageSlices) ? randomPageSlices : []; %>
        <% const randomSlicePattern = [
          { className: "first-block", size: 3 },
          { className: "block5", size: 5 },
          { className: "block2", size: 2 },
          { className: "block3", size: 3 },
          { className: "block5", size: 5 },
          { className: "block2", size: 2 }
        ]; %>
        <% const randomSliceBlocks = []; %>
        <% let randomSliceCursor = 0; %>
        <% let randomSlicePatternIndex = 0; %>
        <% while (randomSliceCursor < randomSlicePool.length) { %>
          <% const patternItem = randomSlicePattern[randomSlicePatternIndex % randomSlicePattern.length]; %>
          <% if (randomSliceCursor + patternItem.size > randomSlicePool.length) { break; } %>
          <% randomSliceBlocks.push({
            className: patternItem.className,
            items: randomSlicePool.slice(randomSliceCursor, randomSliceCursor + patternItem.size)
          }); %>
          <% randomSliceCursor += patternItem.size; %>
          <% randomSlicePatternIndex += 1; %>
        <% } %>
        <% if (randomSliceBlocks.length > 0) { %>
          <section class="section container">
            <div class="section-header section-header--panel-strip">
                <h2>Chương ngẫu nhiên</h2>
              <span class="section-line"></span>
            </div>
            <div class="panel panel-strip-panel reveal" style="--delay: 0.24s;">
              <div class="koma-stream-ranking-list" role="list" aria-label="Chương ngẫu nhiên">
                <% randomSliceBlocks.forEach((block, blockIndex) => { %>
                  <ul class="koma-stream-ranking-list-block <%= block.className %>" role="listitem" aria-label="Cụm chương ngẫu nhiên">
                    <% block.items.forEach((slice) => { %>
                      <li>
                        <a
                          href="<%= slice.href %>"
                          data-bg="<%= slice.imageUrl %>"
                          title="<%= `${slice.mangaTitle} • Chương ${slice.chapterNumber} • Trang ${slice.pageNumber}` %>"
                        >
                          <span class="panel-slice__meta">CH <%= slice.chapterNumber %> · TR <%= slice.pageNumber %></span>
                        </a>
                      </li>
                    <% }) %>
                  </ul>
                <% }) %>
              </div>
            </div>
          </section>
        <% } %>

        <section class="section container">
          <div class="section-header section-header--homepage-list">
            <h2>
              Mới cập nhật
            </h2>
            <a class="section-header__view-all" href="/manga">
              <span>Xem tất cả</span>
              <i class="fa-solid fa-arrow-right-long" aria-hidden="true"></i>
            </a>
          </div>
          <div class="manga-grid manga-grid--home manga-grid--list-style">
            <% latest.forEach((manga, index) => { %>
              <% const latestChapterLabel = manga.latestChapterIsOneshot ? "Oneshot" : `Ch. ${manga.latestChapterNumber || 0}`; %>
              <% const latestStatusClass = manga.status === "Hoàn thành" ? "is-complete" : manga.status === "Tạm dừng" ? "is-hiatus" : "is-ongoing"; %>
              <article class="manga-card manga-card--list">
                <a href="/manga/<%= manga.slug %>">
                  <div class="cover <%= manga.isAdult ? "cover--adult" : "" %>" <%= manga.isAdult ? "data-adult-cover" : "" %>>
                    <% if (manga.cover) { %>
                      <% const latestCoverBaseUrl = cacheBust(manga.cover, manga.coverUpdatedAt); %>
                      <% const latestCoverSources = buildSafeCoverSources(latestCoverBaseUrl, {
                        slotWidths: [172, 262, 358],
                        quality: 95,
                        maxWidth: 900,
                        defaultWidth: 264
                      }); %>
                      <img
                        src="<%= latestCoverSources.src %>"
                        srcset="<%= latestCoverSources.srcset %>"
                        sizes="(max-width: 760px) 47vw, (max-width: 1200px) 23vw, 263px"
                        alt="Bìa <%= manga.title %>"
                        loading="lazy"
                        decoding="async"
                        fetchpriority="low"
                        width="420"
                        height="600"
                      />
                    <% } else { %>
                      <span class="cover__label">No Cover</span>
                    <% } %>
                    <span class="manga-badge <%= latestStatusClass %>">
                      <%= manga.status || "Đang ra" %>
                    </span>
                    <span class="manga-chapter-label"><%= latestChapterLabel %></span>
                  </div>
                  <div class="manga-body">
                    <% const latestCardTitle = truncateCardTitle(manga.title); %>
                    <h3 title="<%= manga.title %>"><%= latestCardTitle %></h3>
                    <div class="manga-list-meta" aria-label="Thông tin truyện mới cập nhật">
                      <span><i class="fa-regular fa-eye" aria-hidden="true"></i> <%= Number((manga.totalViews ?? manga.total_views) || 0).toLocaleString("vi-VN") %> lượt xem</span>
                      <span><i class="fa-regular fa-comments" aria-hidden="true"></i> <%= Number((manga.commentCount ?? manga.comment_count) || 0).toLocaleString("vi-VN") %> bình luận</span>
                    </div>
                  </div>
                </a>
              </article>
            <% }) %>
          </div>
        </section>

        <% if (hasHomepageTopRankings || homepageRecentComments.length > 0) { %>
          <section class="section container">
            <div class="homepage-side-panels">
              <article class="panel homepage-side-panel homepage-side-panel--ranking reveal" style="--delay: 0.24s;">
                <div class="homepage-side-panel__head">
                  <h2>
                    <i class="fa-solid fa-trophy" aria-hidden="true"></i>
                    Bảng xếp hạng
                  </h2>
                  <div class="homepage-ranking-tabs" role="group" aria-label="Bộ lọc thời gian bảng xếp hạng">
                    <% homepageTopRankingPeriods.forEach((period) => { %>
                      <% const tabIsActive = period.key === homepageTopRankingDefaultPeriod; %>
                      <% const tabIsDisabled = period.items.length === 0; %>
                      <button
                        type="button"
                        class="homepage-ranking-tabs__item <%= tabIsActive ? "is-active" : "" %> <%= tabIsDisabled ? "is-disabled" : "" %>"
                        data-ranking-tab="<%= period.key %>"
                        <%= tabIsActive ? "aria-pressed=\"true\"" : "aria-pressed=\"false\"" %>
                        <%= tabIsDisabled ? "disabled" : "" %>
                      ><%= period.label %></button>
                    <% }) %>
                  </div>
                </div>
                <div class="homepage-ranking-lists" aria-live="polite">
                  <% homepageTopRankingPeriods.forEach((period) => { %>
                    <% const periodIsActive = period.key === homepageTopRankingDefaultPeriod; %>
                    <% const periodLabelText = period.label.toLowerCase(); %>
                    <% if (period.items.length > 0) { %>
                      <ol
                        class="homepage-ranking-list <%= periodIsActive ? "is-active" : "" %>"
                        data-ranking-period="<%= period.key %>"
                        aria-label="Top truyện theo lượt xem <%= periodLabelText %>"
                        <%= periodIsActive ? "" : "hidden" %>
                      >
                        <% period.items.forEach((manga, index) => { %>
                          <% const rankingGroupLabel = (manga.groupName || "").toString().trim() || "Nhóm dịch chưa cập nhật"; %>
                          <li class="homepage-ranking-item">
                            <a class="homepage-ranking-item__link" href="/manga/<%= manga.slug %>">
                              <span class="homepage-ranking-item__index"><%= manga.rank || index + 1 %></span>
                              <span class="homepage-ranking-item__cover <%= manga.isAdult ? "cover--adult" : "" %>" <%= manga.isAdult ? "data-adult-cover" : "" %>>
                                <% if (manga.cover) { %>
                                  <% const rankingCoverBaseUrl = cacheBust(manga.cover, manga.coverUpdatedAt); %>
                                  <% const rankingCoverSources = buildSafeCoverSources(rankingCoverBaseUrl, {
                                    slotWidths: [88, 132],
                                    quality: 92,
                                    maxWidth: 400,
                                    defaultWidth: 96
                                  }); %>
                                  <img
                                    src="<%= rankingCoverSources.src %>"
                                    srcset="<%= rankingCoverSources.srcset %>"
                                    sizes="64px"
                                    alt="Bìa <%= manga.title %>"
                                    loading="lazy"
                                    decoding="async"
                                    width="96"
                                    height="136"
                                  />
                                <% } else { %>
                                  <span class="cover__label">No Cover</span>
                                <% } %>
                              </span>
                              <span class="homepage-ranking-item__body">
                                <span class="homepage-ranking-item__title" title="<%= manga.title %>"><%= manga.title %></span>
                                <span class="homepage-ranking-item__meta" title="<%= rankingGroupLabel %>"><%= rankingGroupLabel %></span>
                              </span>
                              <span class="homepage-ranking-item__views" title="<%= Number((manga.totalViews ?? manga.total_views) || 0).toLocaleString("vi-VN") %> lượt xem">
                                <i class="fa-regular fa-eye" aria-hidden="true"></i>
                                <%= formatCompactViews(Number((manga.totalViews ?? manga.total_views) || 0)) %>
                              </span>
                            </a>
                          </li>
                        <% }) %>
                      </ol>
                    <% } else { %>
                      <p
                        class="homepage-side-panel__empty homepage-side-panel__empty--ranking <%= periodIsActive ? "is-active" : "" %>"
                        data-ranking-period="<%= period.key %>"
                        <%= periodIsActive ? "" : "hidden" %>
                      >Chưa có dữ liệu xếp hạng <%= periodLabelText %>.</p>
                    <% } %>
                  <% }) %>
                </div>
              </article>

              <article class="panel homepage-side-panel homepage-side-panel--comments reveal" style="--delay: 0.28s;">
                <div class="homepage-side-panel__head">
                  <h2>
                    <i class="fa-regular fa-comment" aria-hidden="true"></i>
                    Bình luận gần đây
                  </h2>
                </div>
                <% if (homepageRecentComments.length > 0) { %>
                  <div class="homepage-recent-comments" role="list" aria-label="Bình luận mới nhất trên trang chủ">
                    <% homepageRecentComments.forEach((comment) => { %>
                      <% const commentProfileHref = (comment.authorProfileHref || "").toString().trim(); %>
                      <% const rowCommentHref = (comment.commentPermalinkHref || comment.chapterHref || comment.mangaHref || "").toString().trim(); %>
                      <article
                        class="homepage-recent-comment <%= rowCommentHref ? "homepage-recent-comment--interactive" : "" %>"
                        role="listitem"
                        <% if (rowCommentHref) { %>
                          data-comment-row-link="<%= rowCommentHref %>"
                          tabindex="0"
                          aria-label="Mở bình luận của <%= comment.authorName %>"
                        <% } %>
                      >
                        <div class="homepage-recent-comment__author-row">
                          <% if (commentProfileHref) { %>
                            <a class="homepage-recent-comment__avatar-wrap homepage-recent-comment__profile-link" href="<%= commentProfileHref %>" aria-label="Xem trang cá nhân của <%= comment.authorName %>">
                              <% if (comment.avatarUrl) { %>
                                <img
                                  class="homepage-recent-comment__avatar"
                                  src="<%= comment.avatarUrl %>"
                                  alt="Avatar của <%= comment.authorName %>"
                                  loading="lazy"
                                  decoding="async"
                                  onerror="this.hidden=true;if(this.nextElementSibling){this.nextElementSibling.hidden=false;}"
                                />
                              <% } %>
                              <span class="homepage-recent-comment__avatar homepage-recent-comment__avatar--fallback" <%= comment.avatarUrl ? "hidden" : "" %>><%= comment.avatarFallback || "TV" %></span>
                            </a>
                          <% } else { %>
                            <span class="homepage-recent-comment__avatar-wrap" aria-hidden="true">
                              <% if (comment.avatarUrl) { %>
                                <img
                                  class="homepage-recent-comment__avatar"
                                  src="<%= comment.avatarUrl %>"
                                  alt="Avatar của <%= comment.authorName %>"
                                  loading="lazy"
                                  decoding="async"
                                  onerror="this.hidden=true;if(this.nextElementSibling){this.nextElementSibling.hidden=false;}"
                                />
                              <% } %>
                              <span class="homepage-recent-comment__avatar homepage-recent-comment__avatar--fallback" <%= comment.avatarUrl ? "hidden" : "" %>><%= comment.avatarFallback || "TV" %></span>
                            </span>
                          <% } %>
                          <p class="homepage-recent-comment__author-meta">
                            <% if (commentProfileHref) { %>
                              <a
                                class="homepage-recent-comment__author-name homepage-recent-comment__profile-link"
                                href="<%= commentProfileHref %>"
                                <% if (comment.authorColor) { %>style="color:<%= comment.authorColor %>"<% } %>
                              ><%= comment.authorName %></a>
                            <% } else { %>
                              <strong <% if (comment.authorColor) { %>style="color:<%= comment.authorColor %>"<% } %>><%= comment.authorName %></strong>
                            <% } %>
                            <span><%= comment.timeAgo || "Vừa xong" %></span>
                          </p>
                        </div>
                        <p class="homepage-recent-comment__content"><%= truncateCommentPreview(comment.content, 145) %></p>
                        <p class="homepage-recent-comment__manga">
                          <i class="fa-solid fa-book-open" aria-hidden="true"></i>
                          <span class="homepage-recent-comment__manga-text" title="<%= comment.commentTargetLabel || comment.mangaTitle || "Xem truyện" %>">
                            <%= comment.commentTargetLabel || comment.mangaTitle || "Xem truyện" %>
                          </span>
                        </p>
                      </article>
                    <% }) %>
                  </div>
                <% } else { %>
                  <p class="homepage-side-panel__empty">Chưa có bình luận mới.</p>
                <% } %>
              </article>
            </div>
          </section>
        <% } %>

        <section id="about" class="section container">
          <div class="panel about-panel reveal" style="--delay: 0.15s;">
            <div class="about-head">
              <p class="about-kicker"><%= aboutTitle %></p>
            </div>

            <div class="about-metrics" role="list" aria-label="Chỉ số hoạt động của <%= siteName %>">
              <div class="about-metric" role="listitem">
                <span class="about-metric__value"><%= foundedYear %></span>
                <span class="about-metric__label">Năm thành lập</span>
              </div>
              <div class="about-metric" role="listitem">
                <span class="about-metric__value"><%= stats.totalSeries %>+</span>
                <span class="about-metric__label">Dự án manga</span>
              </div>
              <div class="about-metric" role="listitem">
                <span class="about-metric__value"><%= stats.totalChapters %>+</span>
                <span class="about-metric__label">Chương đã dịch</span>
              </div>
            </div>

            <div class="about-grid">
              <article class="about-card">
                <h3><%= contentStandardsTitle %></h3>
                <% contentStandards.forEach((line) => { %>
                  <p><%= line %></p>
                <% }) %>
              </article>

              <article class="about-card">
                <h3><%= contactTitle %></h3>
                <div class="about-contact-list">
                  <a class="about-contact-link" href="<%= facebookUrl %>" target="_blank" rel="noopener noreferrer">
                    <span class="about-contact-link__icon" aria-hidden="true">
                      <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor">
                        <path d="M14 8h3V4h-3c-3.3 0-5 1.7-5 5v3H6v4h3v4h4v-4h3l1-4h-4V9c0-.7.3-1 1-1z" />
                      </svg>
                    </span>
                    <span class="about-contact-link__body">
                      <span class="about-contact-link__label">Facebook</span>
                      <span class="about-contact-link__value"><%= facebookLabel %></span>
                    </span>
                    <svg class="about-contact-link__arrow" viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M7 17L17 7" />
                      <path d="M9 7h8v8" />
                    </svg>
                  </a>

                  <a class="about-contact-link" href="<%= discordUrl %>" target="_blank" rel="noopener noreferrer">
                    <span class="about-contact-link__icon" aria-hidden="true">
                      <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor">
                        <path d="M18.5 6.6A13.6 13.6 0 0 0 15 5.5l-.4.7c1.5.4 2.2.9 3 1.5-2.2-1-4.5-1-6.6-1s-4.4 0-6.6 1c.8-.6 1.5-1.1 3-1.5L7 5.5a13.6 13.6 0 0 0-3.5 1.1C1.3 10 0.7 13.4 1 16.7A14 14 0 0 0 5.2 19l.9-1.4c-.7-.2-1.4-.5-2-.9l.5-.4c2 1 4.2 1.2 6.4 1.2 2.2 0 4.4-.2 6.4-1.2l.5.4c-.6.4-1.3.7-2 .9l.9 1.4a14 14 0 0 0 4.2-2.3c.4-3.7-.7-7-2.5-10.1zM8.4 14.7c-.8 0-1.4-.7-1.4-1.6s.6-1.6 1.4-1.6c.8 0 1.4.7 1.4 1.6s-.6 1.6-1.4 1.6zm7.2 0c-.8 0-1.4-.7-1.4-1.6s.6-1.6 1.4-1.6c.8 0 1.4.7 1.4 1.6s-.6 1.6-1.4 1.6z" />
                      </svg>
                    </span>
                    <span class="about-contact-link__body">
                      <span class="about-contact-link__label">Discord</span>
                      <span class="about-contact-link__value"><%= discordLabel %></span>
                    </span>
                    <svg class="about-contact-link__arrow" viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M7 17L17 7" />
                      <path d="M9 7h8v8" />
                    </svg>
                  </a>
                </div>
              </article>
            </div>
          </div>
        </section>
      </main>
      <%- include("partials/footer") %>
    </div>
  </body>
</html>
