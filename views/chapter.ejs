                <% pageUrls.forEach((src, index) => { %>
                  <div class="page-card">
                    <div class="page-frame">
                      <img
                        class="page-media"
                        src="<%= src %>"
                        alt="Trang <%= index + 1 %>"
                        loading="lazy"
                      />
                    </div>
                  </div>
                <% }) %>
              </div>
            </noscript>
          <% } %>
            </div>
            <% if (pageUrls && pageUrls.length) { %>
            <% const dockCommentCountRaw = Number(commentCount); %>
            <% const dockCommentCount = Number.isFinite(dockCommentCountRaw) && dockCommentCountRaw > 0 ? Math.floor(dockCommentCountRaw) : 0; %>
            <% const dockCommentBadgeLabel = dockCommentCount > 19 ? "19+" : String(dockCommentCount); %>
            <aside class="reader-dock" aria-label="Bảng điều khiển đọc truyện">
              <button
                class="reader-dock__resize-handle"
                type="button"
                data-reader-dock-resize
                data-button-loading-skip
                aria-label="Kéo để đổi độ rộng bảng điều khiển"
                title="Kéo để đổi độ rộng bảng điều khiển"
              ></button>
              <div class="reader-dock__panel">
                <div class="reader-dock__head-top reader-dock__head-top--desktop">
                  <div class="reader-dock__head">
                    <p class="reader-dock__series">
                      <a class="reader-dock__series-link" href="/manga/<%= manga.slug %>"><%= manga.title %></a>
                    </p>
                    <p class="reader-dock__chapter"><%= chapterHeadingLabel %><% if (chapterTitle) { %>: <%= chapterTitle %><% } %></p>
                  </div>
                  <nav class="reader-dock__tools" aria-label="Lối tắt đọc truyện">
                    <button
                      class="reader-dock-collapse-toggle reader-dock-collapse-toggle--head"
                      type="button"
                      data-reader-dock-toggle
                      data-button-loading-skip
                      aria-pressed="false"
                      aria-label="Thu gọn bảng điều khiển đọc truyện"
                      title="Thu gọn bảng điều khiển đọc truyện"
                    >
                      <span class="reader-dock-collapse-toggle__icon" aria-hidden="true">
                        <svg class="reader-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M4 5h4v14H4z" />
                          <path d="M14 7l-4 5 4 5" />
                          <path d="M20 5h-8v14h8" />
                        </svg>
                      </span>
                      <span class="sr-only" data-reader-dock-toggle-text>Thu gọn bảng điều khiển đọc truyện</span>
                    </button>
                    <a class="reader-dock__tool reader-dock__tool--home-collapsed" href="/" aria-label="Trang chủ" title="Trang chủ">
                      <i class="fa-solid fa-house" aria-hidden="true"></i>
                    </a>
                    <a class="reader-dock__tool reader-dock__tool--manga-home-collapsed" href="/manga/<%= manga.slug %>" aria-label="Trang chính truyện" title="Trang chính truyện">
                      <i class="fa-solid fa-book-open" aria-hidden="true"></i>
                    </a>
                    <button class="reader-dock__tool" type="button" data-reader-report data-button-loading-skip aria-label="Báo lỗi trang" title="Báo lỗi">
                      <i class="fa-regular fa-flag" aria-hidden="true"></i>
                    </button>
                    <div class="notify-widget reader-dock__notify-widget" data-notify-widget <%= readerInitiallySignedIn ? "" : "hidden" %>>
                      <button
                        class="notify-trigger reader-dock__tool reader-dock__tool--notify"
                        type="button"
                        data-notify-toggle
                        aria-haspopup="menu"
                        aria-expanded="false"
                        title="Thông báo"
                      >
                        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                          <path d="M6.8 9a5.2 5.2 0 1 1 10.4 0v3.1c0 .8.3 1.5.8 2.1l1.1 1.3H5l1.1-1.3c.5-.6.8-1.3.8-2.1z" />
                          <path d="M9.8 18.1a2.2 2.2 0 0 0 4.4 0" />
                        </svg>
                        <span class="notify-badge" hidden data-notify-badge>0</span>
                        <span class="sr-only">Thông báo</span>
                      </button>
                      <div class="notify-menu" hidden data-notify-menu>
                        <div class="notify-menu__head">
                          <strong>Thông báo</strong>
                          <button class="notify-menu__mark" type="button" data-notify-mark-all hidden>
                            Đánh dấu đã đọc
                          </button>
                        </div>
                        <p class="notify-menu__empty" data-notify-empty>Chưa có thông báo nào.</p>
                        <div class="notify-list" data-notify-list role="list"></div>
                      </div>
                    </div>
                    <div class="auth-widget reader-dock__account" data-auth-widget>
                      <button
                        class="reader-dock__tool reader-dock__tool--login"
                        type="button"
                        data-auth-login
                        aria-label="Đăng nhập"
                        title="Đăng nhập"
                        <%= readerInitiallySignedIn ? "hidden" : "" %>
                      >
                        <i class="fa-solid fa-right-to-bracket" aria-hidden="true"></i>
                      </button>
                      <div class="auth-widget__profile reader-dock__account-profile" data-auth-profile <%= readerInitiallySignedIn ? "" : "hidden" %>>
                        <button
                          class="auth-trigger reader-dock__tool reader-dock__tool--avatar"
                          type="button"
                          data-auth-menu-toggle
                          aria-haspopup="menu"
                          aria-expanded="false"
                          title="Tài khoản"
                        >
                          <img class="auth-trigger__avatar reader-dock__avatar" alt="" hidden data-auth-avatar referrerpolicy="no-referrer" />
                          <svg class="auth-trigger__fallback reader-dock__avatar-fallback" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
                            <circle cx="12" cy="8" r="4" />
                            <path d="M4 20c1.6-3.5 5-5 8-5s6.4 1.5 8 5" />
                          </svg>
                        </button>
                        <div class="auth-menu" hidden data-auth-menu>
                          <div class="auth-menu__head">
                            <a class="auth-menu__name auth-menu__name-link" href="/account" data-auth-name data-auth-profile-link></a>
                            <div class="auth-menu__username" data-auth-username></div>
                          </div>
                          <a class="auth-menu__item" href="/account">Cài đặt tài khoản</a>
                          <a class="auth-menu__item" href="/account/saved">Đã lưu</a>
                          <a class="auth-menu__item" href="/account/history">Lịch sử đọc</a>
                          <button class="auth-menu__item" type="button" data-auth-logout>
                            Đăng xuất
                          </button>
                        </div>
                      </div>
                    </div>
                    <button
                      class="reader-dock__tool reader-dock__tool--comments"
                      type="button"
                      data-reader-comments
                      data-button-loading-skip
                      aria-label="Bình luận"
                      title="Bình luận"
                    >
                      <i class="fa-regular fa-comment-dots" aria-hidden="true"></i>
                      <span class="notify-badge"><%= dockCommentBadgeLabel %></span>
                    </button>
                    <% if (!isWebtoonReader) { %>
                      <button
                        class="reader-dock__tool reader-dock__tool--mode-collapsed reader-mode-toggle reader-mode-toggle--icon-only"
                        type="button"
                        data-reader-mode-toggle
                        data-reader-mode="vertical"
                        data-button-loading-skip
                        aria-pressed="false"
                        aria-label="Chế độ đọc dọc, bấm để chuyển đọc ngang trái sang phải"
                        title="Chế độ đọc dọc, bấm để chuyển đọc ngang trái sang phải"
                      >
                        <span class="reader-mode-toggle__icon reader-mode-toggle__icon--vertical" aria-hidden="true">
                          <svg class="reader-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M12 4v16" />
                            <path d="M8.5 7.5L12 4l3.5 3.5" />
                            <path d="M8.5 16.5L12 20l3.5-3.5" />
                          </svg>
                        </span>
                        <span class="reader-mode-toggle__icon reader-mode-toggle__icon--horizontal" aria-hidden="true">
                          <svg class="reader-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M4 12h16" />
                            <path d="M16 8l4 4-4 4" />
                            <path d="M8 7v10" />
                          </svg>
                        </span>
                        <span class="reader-mode-toggle__icon reader-mode-toggle__icon--horizontal-rtl" aria-hidden="true">
                          <svg class="reader-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M4 12h16" />
                            <path d="M8 8l-4 4 4 4" />
                            <path d="M16 7v10" />
                          </svg>
                        </span>
                        <span class="reader-mode-toggle__label" data-reader-mode-label>Dọc</span>
                      </button>
                    <% } %>
                    <button
                      class="reader-dock__tool reader-dock__tool--jump-top"
                      type="button"
                      data-reader-top
                      data-button-loading-skip
                      aria-label="Lên đầu chương"
                      title="Lên đầu chương"
                    >
                      <i class="fa-solid fa-chevron-up" aria-hidden="true"></i>
                    </button>
                    <button
                      class="reader-dock__tool reader-dock__tool--jump-down"
                      type="button"
                      data-reader-down
                      data-button-loading-skip
                      aria-label="Xuống cuối chương"
                      title="Xuống cuối chương"
                    >
                      <i class="fa-solid fa-chevron-down" aria-hidden="true"></i>
                    </button>
                  </nav>
                </div>
                <div class="reader-dock__controls" data-reader-fixed>
                  <div class="reader-fixed-inner reader-fixed-inner--dock-collapsible">
                    <%- include("partials/chapter-reader-controls", {
                      manga,
                      chapter,
                      chapterTitle,
                      chapterShortLabel,
                      chapterList,
                    prevChapter,
                    nextChapter,
                    buildChapterOptionLabel,
                    dropdownClass: "reader-dropdown--down",
                    showModeToggle: !isWebtoonReader,
                    showDockCollapseToggle: true,
                    iconOnlyModeToggle: true
                  }) %>
                  </div>
                </div>
                <div class="reader-dock__page-nav" data-reader-page-nav>
                  <button class="reader-float-btn reader-float-btn--nav" type="button" data-reader-page-first data-button-loading-skip aria-label="Trang đầu" title="Trang đầu">
                    <svg class="reader-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M17 18l-6-6 6-6" />
                      <path d="M11 18l-6-6 6-6" />
                    </svg>
                  </button>
                  <button class="reader-float-btn reader-float-btn--nav" type="button" data-reader-page-prev data-button-loading-skip aria-label="Trang trước" title="Trang trước">
                    <svg class="reader-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M15 18l-6-6 6-6" />
                    </svg>
                  </button>
                  <div class="reader-dropdown reader-dropdown--down" data-reader-dropdown>
                    <button class="reader-dropdown-trigger" type="button" data-reader-toggle data-button-loading-skip aria-label="Chọn trang" title="Chọn trang">
                      <span class="reader-dropdown-trigger-icon" aria-hidden="true">
                        <i class="fa-solid fa-file-lines"></i>
                      </span>
                      <span class="reader-dropdown-label">
                        <span data-reader-page-current>1</span> / <span data-reader-page-total><%= readerPageTotal %></span>
                      </span>
                      <svg class="reader-icon reader-dropdown-caret" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M6 9l6 6 6-6" />
                      </svg>
                    </button>
                    <div class="reader-dropdown-panel" data-reader-panel>
                      <button class="reader-dropdown-nav" type="button" data-reader-scroll="up" data-button-loading-skip aria-label="Cuộn lên">
                        <svg class="reader-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                          <path d="M6 15l6-6 6 6" />
                        </svg>
                      </button>
                      <div class="reader-dropdown-list" data-reader-list>
                        <% pageUrls.forEach((_src, pageIndex) => { %>
                          <button
                            class="reader-dropdown-option <%= pageIndex === 0 ? "is-active" : "" %>"
                            type="button"
                            data-reader-option
                            data-reader-page-index="<%= pageIndex %>"
                          >
                            <span class="reader-dropdown-option-text">Trang <%= pageIndex + 1 %></span>
                          </button>
                        <% }) %>
                      </div>
                      <button class="reader-dropdown-nav" type="button" data-reader-scroll="down" data-button-loading-skip aria-label="Cuộn xuống">
                        <svg class="reader-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                          <path d="M6 9l6 6 6-6" />
                        </svg>
                      </button>
                    </div>
                  </div>
                  <button class="reader-float-btn reader-float-btn--nav" type="button" data-reader-page-next data-button-loading-skip aria-label="Trang sau" title="Trang sau">
                    <svg class="reader-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M9 18l6-6-6-6" />
                    </svg>
                  </button>
                  <button class="reader-float-btn reader-float-btn--nav" type="button" data-reader-page-last data-button-loading-skip aria-label="Trang cuối" title="Trang cuối">
                    <svg class="reader-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M13 18l6-6-6-6" />
                      <path d="M7 18l6-6-6-6" />
                    </svg>
                  </button>
                </div>
                <div class="reader-dock__comments">
                  <div class="reader-dock__comments-body" data-comment-scroll-container>
                    <% const chapterCommentBasePath = `/manga/${manga.slug}/chapters/${encodeURIComponent(String(chapter.number))}`; %>
                    <%- include("partials/manga-comments-section", {
                      manga,
                      comments,
                      commentCount,
                      commentPagination,
                      commentComposerEnabled,
                      commentDeleteByTeamMember,
                      commentScope: "chapter",
                      commentBasePathOverride: chapterCommentBasePath,
                      commentInfiniteMode: true,
                      commentInfiniteBatchSize: 10
                    }) %>
                  </div>
                </div>
              </div>
            </aside>
            <% } %>
          </div>
        </section>
        <% } %>
      </main>
      <% if (hasReaderPages) { %>
        <div class="reader-float" data-reader-float>
          <div class="reader-float-inner">
            <div class="reader-fixed-inner">
              <%- include("partials/chapter-reader-controls", {
                manga,
                chapter,
                chapterTitle,
                chapterShortLabel,
                chapterList,
                prevChapter,
                nextChapter,
                buildChapterOptionLabel,
                dropdownClass: "",
                showModeToggle: false,
                showDockCollapseToggle: false,
                iconOnlyModeToggle: false
              }) %>
            </div>
            <button class="reader-float-btn reader-float-btn--quick" type="button" data-reader-top data-button-loading-skip aria-label="Lên đầu trang" title="Lên đầu">
              <i class="fa-solid fa-chevron-up" aria-hidden="true"></i>
            </button>
            <button class="reader-float-btn reader-float-btn--quick" type="button" data-reader-down data-button-loading-skip aria-label="Xuống cuối trang" title="Xuống cuối trang">
              <i class="fa-solid fa-chevron-down" aria-hidden="true"></i>
            </button>
          </div>
        </div>
        <div
          class="reader-report-modal"
          data-reader-report-modal
          data-reader-report-submit-url="/manga/<%= encodeURIComponent(manga.slug) %>/chapters/<%= encodeURIComponent(String(chapter.number)) %>/report"
          hidden
        >
          <div class="reader-report-modal__backdrop" data-reader-report-close></div>
          <div class="reader-report-modal__dialog" role="dialog" aria-modal="true" aria-labelledby="reader-report-title">
            <h2 id="reader-report-title">Báo lỗi chương</h2>
            <p class="reader-report-modal__desc">Chọn vấn đề bạn gặp phải để đội ngũ xử lý nhanh hơn.</p>
            <div class="reader-report-modal__reasons" role="group" aria-label="Lý do báo lỗi">
              <button type="button" class="reader-report-modal__reason" data-reader-report-reason="broken_images">Ảnh hỏng / không tải được</button>
              <button type="button" class="reader-report-modal__reason" data-reader-report-reason="wrong_order">Thứ tự trang sai</button>
              <button type="button" class="reader-report-modal__reason" data-reader-report-reason="translation_issue">Lỗi dịch / sai nội dung</button>
              <button type="button" class="reader-report-modal__reason" data-reader-report-reason="other">Lỗi khác</button>
            </div>
            <textarea
              class="reader-report-modal__note"
              rows="3"
              maxlength="50"
              placeholder="Mô tả ngắn (tuỳ chọn)"
              data-reader-report-note
            ></textarea>
            <p class="reader-report-modal__feedback" data-reader-report-feedback></p>
            <div class="reader-report-modal__actions">
              <button type="button" class="reader-report-modal__btn reader-report-modal__btn--ghost" data-reader-report-close>Huỷ</button>
              <button type="button" class="reader-report-modal__btn" data-reader-report-submit>Gửi báo lỗi</button>
            </div>
          </div>
        </div>
      <% } %>
      <%- include("partials/comments-lazy-loader") %>
      <%- include("partials/footer") %>
    </div>
  </body>
</html>
