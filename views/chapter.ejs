      body.reader-page.reader-page--reader-mode.reader-dock-collapsed .reader-dock__tools > .reader-dock__account .auth-trigger__fallback {
        width: 16px;
        height: 16px;
      }

      body.reader-page.reader-page--reader-mode.reader-dock-collapsed .reader-dock__tools > .reader-dock__notify-widget,
      body.reader-page.reader-page--reader-mode.reader-dock-collapsed .reader-dock__tools > .reader-dock__account {
        width: 30px;
        min-width: 30px;
        flex: 0 0 30px;
        position: relative;
      }

      body.reader-page.reader-page--reader-mode.reader-dock-collapsed .reader-dock__tools > .reader-dock__notify-widget[hidden] {
        display: none !important;
      }

      body.reader-page.reader-page--reader-mode.reader-dock-collapsed .reader-dock__controls,
      body.reader-page.reader-page--reader-mode.reader-dock-collapsed .reader-dock__page-nav {
        display: none;
      }

      body.reader-page.reader-page--reader-mode.reader-dock-collapsed .reader-dropdown-label,
      body.reader-page.reader-page--reader-mode.reader-dock-collapsed .reader-dropdown-caret,
      body.reader-page.reader-page--reader-mode.reader-dock-collapsed .reader-mode-toggle__label {
        display: none;
      }

      body.reader-page.reader-page--reader-mode.reader-dock-collapsed .reader-dock__comments {
        display: none;
      }

      body.reader-page.reader-page--reader-mode.reader-dock-collapsed .reader-dock__head-top--desktop .auth-menu {
        left: auto !important;
        right: calc(100% + 0.34rem) !important;
        top: 0 !important;
        bottom: auto !important;
        transform: none !important;
        max-height: min(76vh, 420px);
        overflow: auto;
      }

      body.reader-page.reader-page--reader-mode.reader-dock-collapsed .reader-dock-collapse-toggle__icon {
        transform: rotate(180deg);
      }
    }

    body.reader-page.reader-page--reader-mode.reader-dock-preinit .reader-dock__comments #comments .comment-box {
      visibility: hidden;
      pointer-events: none;
    }
  </style>
  <body class="reader-page<%= hasReaderPages ? ` reader-page--reader-mode reader-dock-preinit${isWebtoonReader ? " reader-webtoon" : ""}` : "" %>">
    <script nonce="<%= cspNonce || '' %>">
      (() => {
        const body = document.body;
        if (!body || !body.classList || !body.classList.contains("reader-page--reader-mode")) {
          return;
        }

        const isWebtoonReader = body.classList.contains("reader-webtoon");
        let readerMode = "vertical";
        let dockCollapsed = false;

        try {
          if (!isWebtoonReader) {
            const storedMode = (window.localStorage.getItem("bfang:reader-mode") || "")
              .toString()
              .trim()
              .toLowerCase();
            if (storedMode === "horizontal" || storedMode === "horizontal-rtl") {
              readerMode = storedMode;
            }
          } else {
            window.localStorage.setItem("bfang:reader-mode", "vertical");
          }

          dockCollapsed =
            window.localStorage.getItem("bfang:reader-dock-collapsed") === "1";
        } catch (_error) {
          readerMode = "vertical";
          dockCollapsed = false;
        }

        const isHorizontal = readerMode === "horizontal" || readerMode === "horizontal-rtl";
        const isHorizontalRtl = readerMode === "horizontal-rtl";

        body.classList.toggle("reader-reading-horizontal", isHorizontal);
        body.classList.toggle("reader-reading-horizontal-rtl", isHorizontalRtl);
        body.classList.toggle("reader-dock-collapsed", dockCollapsed);
        body.dataset.readerMode = readerMode;
      })();
    </script>
    <div class="site">
      <% if (!hasReaderPages) { %>
        <%- include("partials/header") %>
      <% } %>
      <main
        <% if (hasReaderPages) { %>
        data-reading-progress
        data-reading-manga-slug="<%= manga.slug %>"
        data-reading-manga-title="<%= (manga && manga.title ? manga.title : '').toString().trim() %>"
        data-reading-chapter-id="<%= Number(chapter && chapter.id ? chapter.id : 0) %>"
        data-reading-chapter-number="<%= chapter.number %>"
        data-reading-chapter-title="<%= (chapter && chapter.title ? chapter.title : '').toString().trim() %>"
        data-reading-chapter-url="/manga/<%= encodeURIComponent(manga.slug) %>/chapters/<%= encodeURIComponent(String(chapter.number)) %>"
        <% } %>
      >
        <% const chapterTitle = (chapter.title || "").toString().trim(); %>
        <% const isOneshotChapter = Boolean(chapter && chapter.is_oneshot); %>
        <% const chapterHeadingLabel = isOneshotChapter ? "Oneshot" : `Chương ${chapter.number}`; %>
        <% const chapterShortLabel = isOneshotChapter ? "Oneshot" : `Ch. ${chapter.number}`; %>
        <% const buildChapterOptionLabel = (item) => {
          const chapterItem = item && typeof item === "object" ? item : {};
          const itemTitle = (chapterItem.title || "").toString().trim();
          const baseLabel = chapterItem.is_oneshot ? "Oneshot" : `Ch. ${chapterItem.number}`;
          return itemTitle ? `${baseLabel} — ${itemTitle}` : baseLabel;
        }; %>
        <% const processingState = chapterProcessingState; %>
        <% const processingDonePagesRaw = Number(chapter.processing_done_pages); %>
        <% const processingTotalPagesRaw = Number(chapter.processing_total_pages); %>
        <% const processingDonePages = Number.isFinite(processingDonePagesRaw) && processingDonePagesRaw >= 0 ? Math.floor(processingDonePagesRaw) : 0; %>
        <% const processingTotalPages = Number.isFinite(processingTotalPagesRaw) && processingTotalPagesRaw > 0 ? Math.floor(processingTotalPagesRaw) : 0; %>
        <% const processingPercent = processingTotalPages > 0 ? Math.min(100, Math.max(0, Math.floor((Math.min(processingDonePages, processingTotalPages) / processingTotalPages) * 100))) : 0; %>
        <% const shouldShowReaderIntro = !isChapterInteractionLocked && (isChapterLocked || processingState === "processing" || !pageUrls || pageUrls.length === 0); %>

        <% if (shouldShowReaderIntro) { %>
          <section class="section container">
            <div class="reader-header">
              <div class="reader-title">
                <a class="reader-back" href="/manga/<%= manga.slug %>">Quay lại truyện</a>
                <h1><%= chapterHeadingLabel %><% if (chapterTitle) { %>: <%= chapterTitle %><% } %></h1>
                <div class="reader-meta">
                  <span><%= manga.title %></span>
                  <span class="reader-dot">•</span>
                  <span><%= chapter.pages %> trang</span>
                  <span class="reader-dot">•</span>
                  <span>Cập nhật <%= formatDate(chapter.date) %></span>
                </div>
              </div>
            </div>
            <% if (isChapterLocked) { %>
              <p class="reader-note">Chương này đang được khóa mật khẩu. Vui lòng nhập mật khẩu để mở khóa.</p>
            <% } else if (processingState === "processing") { %>
              <p class="reader-note" data-chapter-processing-summary>
                Chương đang xử lý ảnh<% if (processingTotalPages > 0) { %> — <%= processingDonePages %>/<%= processingTotalPages %> (<%= processingPercent %>%)<% } %>. Vui lòng quay lại sau.
              </p>
            <% } else if (!pageUrls || pageUrls.length === 0) { %>
              <p class="reader-note">Trang đọc mẫu: hiển thị khung trang, chưa có ảnh scan.</p>
            <% } %>
          </section>
        <% } %>

        <% if (isChapterLocked) { %>
          <section class="section container">
            <div class="panel chapter-unlock-card">
              <div class="chapter-unlock-card__header">
                <span class="chapter-unlock-card__icon" aria-hidden="true">
                  <i class="fa-solid fa-lock"></i>
                </span>
                <div class="chapter-unlock-card__title-wrap">
                  <h2>Mở khóa chương</h2>
                  <p>Chương này được bảo vệ bằng mật khẩu. Nhập đúng mật khẩu để tiếp tục đọc.</p>
                </div>
              </div>
              <form
                class="chapter-unlock-form"
                method="post"
                action="<%= chapterUnlockPath %>"
                data-chapter-unlock-form
                data-chapter-unlock-retry-after-ms="<%= Math.max(Number(chapterUnlockRetryAfterMs) || 0, 0) %>"
                novalidate
              >
                <label class="chapter-unlock-form__label" for="chapter-unlock-password">Mật khẩu chương</label>
                <div class="chapter-unlock-form__row">
                  <input
                    id="chapter-unlock-password"
                    class="chapter-unlock-form__input"
                    type="password"
                    name="chapter_password"
                    minlength="<%= chapterPasswordMinLength %>"
                    maxlength="<%= chapterPasswordMaxLength %>"
                    autocomplete="current-password"
                    required
                    spellcheck="false"
                    data-chapter-unlock-input
                  />
                  <button
                    class="button chapter-unlock-form__submit"
                    type="submit"
                    data-chapter-unlock-submit
                    data-button-loading-skip
                  >
                    Mở khóa
                  </button>
                </div>
                <p class="chapter-unlock-form__hint">
                  Hệ thống sẽ tạm khóa nếu nhập sai quá nhiều lần liên tiếp để bảo vệ chương truyện.
                </p>
                <p class="chapter-unlock-form__countdown" data-chapter-unlock-countdown hidden></p>
                <p
                  class="chapter-unlock-form__error"
                  data-chapter-unlock-error
                  <%= chapterUnlockError ? "" : "hidden" %>
                ><%= chapterUnlockError || "" %></p>
              </form>
            </div>
          </section>
        <% } else if (isChapterInteractionLocked) { %>
          <section class="section container">
            <% const interactionPrevChapter = chapterInteractionPrevChapter && Number.isFinite(Number(chapterInteractionPrevChapter.number)) ? chapterInteractionPrevChapter : null; %>
            <div class="reader-header">
              <div class="reader-title">
                <a class="reader-back" href="/manga/<%= manga.slug %>">Quay lại truyện</a>
                <h1><%= chapterHeadingLabel %><% if (chapterTitle) { %>: <%= chapterTitle %><% } %></h1>
                <div class="reader-meta">
                  <span><%= manga.title %></span>
                  <span class="reader-dot">•</span>
                  <span><%= chapter.pages %> trang</span>
                  <span class="reader-dot">•</span>
                  <span>Cập nhật <%= formatDate(chapter.date) %></span>
