                  </p>
                  <h2 class="reader-chapter-bridge__title">Bạn phải bình luận ở chương trước để mở chương này</h2>
                  <div class="reader-chapter-bridge__actions">
                    <% if (interactionPrevChapter) { %>
                      <a class="reader-chapter-bridge__action" href="/manga/<%= manga.slug %>/chapters/<%= interactionPrevChapter.number %>">
                        <i class="fa-solid fa-arrow-left" aria-hidden="true"></i>
                        <span>Quay lại chương trước</span>
                      </a>
                    <% } %>
                    <a class="reader-chapter-bridge__action" href="/manga/<%= manga.slug %>">
                      <i class="fa-solid fa-book-open" aria-hidden="true"></i>
                      <span>Trang chính truyện</span>
                    </a>
                  </div>
                </div>
              </div>
            </div>
          </section>
        <% } else { %>
        <section class="section container reader reader-shell">
          <% const lazyPlaceholderSrc = "data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///ywAAAAAAQABAAACAUwAOw=="; %>
          <% const readerNextPrefetchPayload = encodeURIComponent(
            JSON.stringify(Array.isArray(nextChapterPrefetchUrls) ? nextChapterPrefetchUrls : [])
          ); %>
          <% const totalChapterPages = Math.max(Number(chapter && chapter.pages ? chapter.pages : 0) || 0, 0); %>
          <% const renderedPageTotal = Array.isArray(pageUrls) ? pageUrls.length : 0; %>
          <% const readerPageTotal = renderedPageTotal > 0 ? renderedPageTotal : totalChapterPages; %>
          <% const chapterViewThreshold = Math.max(1, Math.floor(readerPageTotal / 2 + 1)); %>
          <% const readerInitiallySignedIn = typeof isInitiallySignedIn !== "undefined" && isInitiallySignedIn; %>
          <div class="reader-shell__layout<%= pageUrls && pageUrls.length ? "" : " reader-shell__layout--single" %>">
            <div class="reader-shell__content">
          <% if (pageUrls && pageUrls.length) { %>
            <div class="reader-mobile-top" aria-label="Điều hướng đọc truyện trên điện thoại">
              <div class="reader-mobile-top__head reader-dock__head-top">
                <div class="reader-dock__head">
                  <p class="reader-dock__series">
                    <a class="reader-dock__series-link" href="/manga/<%= manga.slug %>"><%= manga.title %></a>
                  </p>
                  <p class="reader-dock__chapter"><%= chapterHeadingLabel %><% if (chapterTitle) { %>: <%= chapterTitle %><% } %></p>
                </div>
                <nav class="reader-dock__tools" aria-label="Lối tắt đọc truyện">
                  <a class="reader-dock__tool" href="/" aria-label="Trang chủ" title="Trang chủ">
                    <i class="fa-solid fa-house" aria-hidden="true"></i>
                  </a>
                  <button class="reader-dock__tool" type="button" data-reader-report data-button-loading-skip aria-label="Báo lỗi trang" title="Báo lỗi">
                    <i class="fa-regular fa-flag" aria-hidden="true"></i>
                  </button>
                  <div class="notify-widget reader-dock__notify-widget" data-notify-widget <%= readerInitiallySignedIn ? "" : "hidden" %>>
                    <button
                      class="notify-trigger reader-dock__tool reader-dock__tool--notify"
                      type="button"
                      data-notify-toggle
                      aria-haspopup="menu"
                      aria-expanded="false"
