                      data-page-index="<%= index %>"
                      alt="Trang <%= index + 1 %>"
                      loading="<%= isEagerPage ? "eager" : "lazy" %>"
                      decoding="async"
                      fetchpriority="<%= index === 0 ? "high" : isEagerPage ? "auto" : "low" %>"
                    />
                  </div>
                </div>
              <% }) %>
              <% const currentChapterNumberValue = Number(chapter.number); %>
              <% const nextChapterNumberValue = nextChapter ? Number(nextChapter.number) : Number.NaN; %>
              <% const canGoNextChapter = Boolean(
