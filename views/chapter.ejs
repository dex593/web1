                  <div class="page-paper">
                    <span class="page-number">Trang <%= page %></span>
                  </div>
                </div>
              <% }) %>
            <% } %>
          </div>
          <% if (pageUrls && pageUrls.length) { %>
            <div class="reader-horizontal-progress" data-reader-horizontal-progress aria-live="polite" aria-atomic="true">
              <span data-reader-page-current>1</span>/<span data-reader-page-total><%= readerPageTotal %></span>
            </div>
