                    </p>
                    <p class="note" data-chapter-processing-reload hidden>Đã xử lý xong, đang tải lại trang để hiển thị ảnh…</p>
                  </div>
                </div>
              </div>
            <% } else if (pageUrls && pageUrls.length) { %>
              <% const eagerPageCount = Math.min(3, pageUrls.length); %>
