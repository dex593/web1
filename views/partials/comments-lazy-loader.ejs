<script nonce="<%= cspNonce || '' %>">
  (() => {
    const commentsRoot = document.querySelector("#comments");
    if (!commentsRoot) return;

    const notifyReaderLayout = (phase) => {
      window.dispatchEvent(
        new CustomEvent("bfang:reader-comments-layout", {
          detail: { phase }
        })
      );
    };

    const scriptSrc = (commentsRoot.getAttribute("data-comment-script-src") || "").toString().trim();
    if (!scriptSrc) return;

    const isLazyCommentsSection = commentsRoot.hasAttribute("data-comment-lazy");
    let loaded = false;
    let observer = null;
    const getCommentSubmitHandler = () => {
      const commentsApi = window.BfangComments && typeof window.BfangComments === "object"
        ? window.BfangComments
        : null;
      return commentsApi && typeof commentsApi.submit === "function" ? commentsApi.submit : null;
    };
    let scriptReady = Boolean(getCommentSubmitHandler());
    let pendingSubmitForm = null;
    const hasCommentTargetHash = () => /^#comment-\d+$/i.test((window.location.hash || "").toString().trim());

    const cleanup = () => {
      document.removeEventListener("focusin", onIntent, true);
      document.removeEventListener("pointerdown", onIntent, true);
      document.removeEventListener("keydown", onIntent, true);
      window.removeEventListener("hashchange", onHashIntent);
      if (observer) {
        observer.disconnect();
        observer = null;
      }
    };

    const replayPendingSubmit = () => {
      const form = pendingSubmitForm;
      pendingSubmitForm = null;
      if (!form || !form.isConnected) return;
      window.setTimeout(() => {
        if (!form.isConnected) return;
        form.dispatchEvent(new Event("submit", { bubbles: true, cancelable: true }));
      }, 0);
    };

    const submitPendingFormNatively = () => {
      const form = pendingSubmitForm;
      pendingSubmitForm = null;
      if (!form || !form.isConnected || typeof form.submit !== "function") return;
      form.submit();
    };

    const markScriptReady = () => {
      scriptReady = Boolean(getCommentSubmitHandler());
      if (scriptReady) {
        replayPendingSubmit();
      }
      return scriptReady;
    };

    const loadCommentsScript = () => {
      if (loaded) return;
      loaded = true;
      cleanup();
      commentsRoot.setAttribute("data-comment-auto-hydrate", "1");
      notifyReaderLayout("hydrate-start");

      const existingScript = document.querySelector(`script[src="${scriptSrc}"]`);
      if (existingScript) {
        if (markScriptReady()) {
          if (window.BfangComments && typeof window.BfangComments.refresh === "function") {
            window.BfangComments.refresh();
          }
        } else {
          existingScript.addEventListener("load", () => {
            if (!markScriptReady()) {
              submitPendingFormNatively();
            }
          }, { once: true });
          existingScript.addEventListener("error", () => {
            loaded = false;
            submitPendingFormNatively();
          }, { once: true });
        }
        window.setTimeout(() => notifyReaderLayout("hydrate-refresh"), 60);
        window.setTimeout(() => notifyReaderLayout("hydrate-settled"), 260);
        return;
      }

      const script = document.createElement("script");
      script.src = scriptSrc;
      script.defer = true;
      script.nonce = "<%= cspNonce || '' %>";
      script.addEventListener("load", () => {
        notifyReaderLayout("hydrate-loaded");
        markScriptReady();
        window.setTimeout(() => notifyReaderLayout("hydrate-settled"), 260);
      });
      script.addEventListener("error", () => {
        loaded = false;
        notifyReaderLayout("hydrate-error");
        submitPendingFormNatively();
      });
      document.head.appendChild(script);
    };

    const isCommentFormSubmit = (form) => {
      if (!form || !form.closest || !form.closest("#comments")) return false;
      if (form.querySelector("textarea[name='content']")) return true;
      const actionUrl = (form.getAttribute("action") || form.action || "").toString().trim();
      return /\/comments\/\d+\/(?:like|report)(?:$|\?|\/)/i.test(actionUrl);
    };

    const onSubmitIntent = (event) => {
      const form = event && event.target;
      if (!isCommentFormSubmit(form)) return;
      const submitHandler = getCommentSubmitHandler();
      if (scriptReady || submitHandler) {
        if (!submitHandler) return;
        scriptReady = true;
        event.preventDefault();
        if (typeof event.stopImmediatePropagation === "function") {
          event.stopImmediatePropagation();
        }
        submitHandler(form);
        return;
      }
      event.preventDefault();
      pendingSubmitForm = form;
      loadCommentsScript();
    };

    const onIntent = (event) => {
      const target = event && event.target;
      if (!target || !target.closest) return;
      if (target.closest("#comments")) {
        loadCommentsScript();
      }
    };

    const onHashIntent = () => {
      if (hasCommentTargetHash()) {
        loadCommentsScript();
      }
    };

    document.addEventListener("focusin", onIntent, true);
    document.addEventListener("pointerdown", onIntent, true);
    document.addEventListener("keydown", onIntent, true);
    document.addEventListener("submit", onSubmitIntent, true);
    window.addEventListener("hashchange", onHashIntent);

    if (hasCommentTargetHash()) {
      loadCommentsScript();
      return;
    }

    if (typeof IntersectionObserver === "function") {
      observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            loadCommentsScript();
          });
        },
        {
          root: null,
          rootMargin: isLazyCommentsSection ? "320px 0px" : "1100px 0px",
          threshold: 0.01
        }
      );
      observer.observe(commentsRoot);
      return;
    }

    window.setTimeout(() => {
      loadCommentsScript();
    }, 1200);
  })();
</script>
