<% const resolvedCommentScope = typeof commentScope === "string" && commentScope.trim() ? commentScope.trim().toLowerCase() : "manga"; %>
<% const resolvedCommentBasePath = typeof commentBasePathOverride === "string" && commentBasePathOverride.trim() ? commentBasePathOverride.trim() : `/manga/${manga.slug}`; %>
<% const resolvedCommentCreateAction = `${resolvedCommentBasePath}/comments`; %>
<section
  id="comments"
  class="section container"
  data-comment-mention-url="/manga/<%= manga.slug %>/comment-mentions"
  data-comment-manga-slug="<%= manga.slug %>"
  data-comment-manga-title="<%= manga.title %>"
  data-comment-scope="<%= resolvedCommentScope %>"
  data-comment-image-upload-url="/comments/upload-image"
  data-comment-image-upload-enabled="<%= commentImageUploadsEnabled ? "1" : "0" %>"
  data-comment-script-src="<%= cacheBust('/comments.js', assetVersion) %>"
>
  <% const commentComposerEnabledFlag = typeof commentComposerEnabled === "boolean" ? commentComposerEnabled : true; %>
  <% const commentPage = commentPagination && commentPagination.page ? Number(commentPagination.page) : 1; %>
  <% const commentTotalPages = commentPagination && commentPagination.totalPages ? Number(commentPagination.totalPages) : 1; %>
  <% const commentPageHref = (targetPage) => {
    const safeTarget = Number.isFinite(targetPage) && targetPage > 0 ? Math.floor(targetPage) : 1;
    if (typeof commentPageHrefBuilder === "function") {
      return commentPageHrefBuilder(safeTarget);
    }
    if (safeTarget <= 1) return `${resolvedCommentBasePath}#comments`;
    return `${resolvedCommentBasePath}?commentPage=${safeTarget}#comments`;
  }; %>
  <% const isMemberBadge = (badge) => {
    if (!badge) return false;
    const label = String(badge.label || "").trim();
    if (!label) return false;
    const code = String(badge.code || "").trim().toLowerCase();
    const normalizedLabel = label.toLowerCase();
    return code === "member" ||
      normalizedLabel.includes("member") ||
      normalizedLabel.includes("thanh vien") ||
      normalizedLabel.includes("thành viên");
  }; %>
  <% const pickTopBadge = (badgesInput) => {
    const badges = Array.isArray(badgesInput) ? badgesInput : [];
    return badges.find((badge) => {
      if (!badge) return false;
      const label = String(badge.label || "").trim();
      return Boolean(label) && !isMemberBadge(badge);
    });
  }; %>
  <% const toLh3SizedImageUrl = (value, sizeValue) => {
    const raw = String(value || "").trim();
    if (!raw) return "";
    const match = raw.match(/^https?:\/\/lh3\.googleusercontent\.com\/d\/([A-Za-z0-9_-]+)=s(\d+)$/i);
    if (!match) return raw;
    const imageId = match[1];
    const parsedSize = Number(sizeValue);
    const safeSize = Number.isFinite(parsedSize) && parsedSize >= 0
      ? Math.min(Math.floor(parsedSize), 4096)
      : 450;
    return `https://lh3.googleusercontent.com/d/${imageId}=s${safeSize}`;
  }; %>
  <div class="section-header">
    <h2>Bình luận (<%= commentCount %>)</h2>
    <span class="section-line"></span>
  </div>
  <div class="comment-box <%= commentComposerEnabledFlag ? "" : "comment-box--locked" %>">
    <% if (commentComposerEnabledFlag) { %>
      <div class="comment-avatar" aria-hidden="true" data-auth-widget>
        <img
          class="comment-avatar__img"
          alt=""
          hidden
          loading="lazy"
          referrerpolicy="no-referrer"
          data-auth-avatar
        />
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
          <circle cx="12" cy="8" r="4" />
          <path d="M4 20c1.6-3.5 5-5 8-5s6.4 1.5 8 5" />
        </svg>
      </div>
      <form class="comment-form" method="post" action="<%= resolvedCommentCreateAction %>">
        <div class="comment-authbar" data-auth-widget>
          <button class="button button--ghost comment-authbar__login" type="button" data-auth-login>
            Đăng nhập
          </button>
          <div class="comment-authbar__profile" hidden data-auth-profile>
            <strong class="comment-authbar__name" data-auth-name></strong>
          </div>
        </div>
        <textarea
          class="comment-textarea"
          name="content"
          rows="3"
          maxlength="500"
          placeholder="Viết bình luận..."
          required
        ></textarea>
        <div class="comment-submit">
          <button class="button" type="submit">Gửi bình luận</button>
        </div>
      </form>
    <% } else { %>
      <div class="comment-lock-notice" role="note" aria-live="polite">
        <span class="comment-lock-notice__text">Bạn cần đăng nhập để bình luận.</span>
        <button class="button comment-lock-notice__login" type="button" data-auth-login>Đăng nhập</button>
      </div>
    <% } %>
  </div>

  <% if (comments.length === 0) { %>
    <p class="note" data-comment-empty-note="1">Chưa có bình luận nào.</p>
  <% } else { %>
    <ul class="comment-items">
      <% comments.forEach((comment) => { %>
        <li
          id="comment-<%= comment.id %>"
          class="comment-item"
          data-comment-id="<%= comment.id %>"
          data-comment-author-id="<%= comment.authorUserId || "" %>"
          data-comment-parent-author-id=""
        >
          <div
            class="comment-avatar <%= comment.authorUserId ? "comment-avatar--interactive" : "" %>"
            <% if (comment.authorUserId) { %>
              role="link"
              tabindex="0"
              data-comment-author-trigger
              data-comment-user-id="<%= comment.authorUserId %>"
              <% if (comment.authorUsername) { %>data-comment-username="<%= comment.authorUsername %>"<% } %>
              aria-label="Xem trang cá nhân của <%= comment.author %>"
            <% } else { %>
              aria-hidden="true"
            <% } %>
          >
            <% if (comment.avatarUrl) { %>
              <img
                class="comment-avatar__img"
                src="<%= comment.avatarUrl %>"
                alt=""
                loading="lazy"
                referrerpolicy="no-referrer"
              />
            <% } else { %>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
                <circle cx="12" cy="8" r="4" />
                <path d="M4 20c1.6-3.5 5-5 8-5s6.4 1.5 8 5" />
              </svg>
            <% } %>
          </div>
          <div class="comment-body">
            <% const commentTopBadge = pickTopBadge(comment.badges || []); %>
            <% const commentLikeCount = Number(comment.likeCount) > 0 ? Math.floor(Number(comment.likeCount)) : 0; %>
            <% const commentReportCount = Number(comment.reportCount) > 0 ? Math.floor(Number(comment.reportCount)) : 0; %>
            <div class="comment-bubble">
              <div class="comment-header">
                <span
                  class="comment-author <%= comment.authorUserId ? "comment-author--interactive" : "" %>"
                  <% if (comment.userColor) { %>style="--user-color: <%= comment.userColor %>"<% } %>
                  <% if (comment.authorUserId) { %>
                    role="link"
                    tabindex="0"
                    data-comment-author-trigger
                    data-comment-user-id="<%= comment.authorUserId %>"
                    <% if (comment.authorUsername) { %>data-comment-username="<%= comment.authorUsername %>"<% } %>
                  <% } %>
                >
                  <span class="comment-author__name"><%= comment.author %></span>
                  <% if (commentTopBadge) { %>
                    <span
                      class="comment-badge"
                      <% if (commentTopBadge.color) { %>style="--badge-color: <%= commentTopBadge.color %>; --badge-bg: <%= `${commentTopBadge.color}22` %>"<% } %>
                    >
                      <%= commentTopBadge.label %>
                    </span>
                  <% } %>
                </span>
                <% const commentChapterNumberText = (comment && comment.chapterNumberText ? String(comment.chapterNumberText) : "").trim(); %>
                <% const commentChapterLabelText = (comment && comment.chapterLabel ? String(comment.chapterLabel) : "").trim(); %>
                <% if (commentChapterNumberText) { %>
                  <a
                    class="comment-chapter-tag"
                    href="/manga/<%= manga.slug %>/chapters/<%= encodeURIComponent(commentChapterNumberText) %>"
                  >
                    Chương <%= commentChapterNumberText %>
                  </a>
                <% } else if (commentChapterLabelText) { %>
                  <span class="comment-chapter-tag"><%= commentChapterLabelText %></span>
                <% } %>
              </div>
              <% const commentContentText = String(comment.content || "").trim(); %>
              <% if (commentContentText) { %>
                <p
                  class="comment-text"
                  data-comment-raw="<%= comment.content %>"
                  data-comment-mentions="<%= JSON.stringify(comment.mentions || []) %>"
                ><%= comment.content %></p>
              <% } %>
              <% if (comment.imageUrl) { %>
                <% const commentImageHref = toLh3SizedImageUrl(comment.imageUrl, 0); %>
                <% const commentImageSrc = toLh3SizedImageUrl(comment.imageUrl, 450); %>
                <a class="comment-image-link" href="<%= commentImageHref %>" target="_blank" rel="noopener noreferrer">
                        <img
                          class="comment-image"
                          src="<%= commentImageSrc %>"
                          alt="Ảnh bình luận"
                          loading="lazy"
                          referrerpolicy="no-referrer"
                        />
                </a>
              <% } %>
            </div>
            <% const commentTimeText = formatTimeAgo(comment.createdAt); %>
            <% const commentTimeCompact = commentTimeText.replace(/\s+trước$/i, "").trim(); %>
            <div class="comment-meta">
              <span class="comment-time" data-time-mobile="<%= commentTimeCompact %>"><%= commentTimeText %></span>
              <div class="comment-actions">
                <form method="post" action="/comments/<%= comment.id %>/like">
                  <button
                    class="comment-action comment-action--like <%= comment.liked ? "is-active" : "" %>"
                    type="submit"
                    data-comment-like
                    data-liked="<%= comment.liked ? "1" : "0" %>"
                  >
                    <i class="fa-solid fa-thumbs-up" aria-hidden="true"></i>
                    <span class="comment-action__label">Thích</span>
                    <% if (commentLikeCount > 0) { %>
                      <span class="comment-action__count" data-comment-like-count><%= commentLikeCount %></span>
                    <% } %>
                  </button>
                </form>
                <% if (!comment.parentId && commentComposerEnabledFlag) { %>
                <button class="comment-action comment-action--reply" type="button" data-comment-reply>
                    <i class="fa-solid fa-reply" aria-hidden="true"></i>
                    Trả lời
                  </button>
                <% } %>
                <form method="post" action="/comments/<%= comment.id %>/report">
                  <button
                    class="comment-action comment-action--report <%= comment.reported ? "is-muted" : "" %>"
                    type="submit"
                    data-comment-report
                    data-button-loading-skip
                    data-reported="<%= comment.reported ? "1" : "0" %>"
                    <%= comment.reported ? "disabled" : "" %>
                  >
                    <i class="fa-regular fa-flag" aria-hidden="true"></i>
                    <span class="comment-action__label">Báo cáo</span>
                    <% if (commentReportCount > 0) { %>
                      <span class="comment-action__count" data-comment-report-count><%= commentReportCount %></span>
                    <% } %>
                  </button>
                </form>
                <button
                  class="comment-action comment-action--delete"
                  type="button"
                  data-comment-delete
                  hidden
                >
                  <i class="fa-regular fa-trash-can" aria-hidden="true"></i>
                  Xóa
                </button>
              </div>
            </div>
            <% if (commentComposerEnabledFlag) { %>
              <div class="comment-reply">
                <form class="comment-form comment-form--reply" method="post" action="<%= resolvedCommentCreateAction %>">
                  <input type="hidden" name="parent_id" value="<%= comment.id %>" />
                  <textarea
                    class="comment-textarea"
                    name="content"
                    rows="2"
                    maxlength="500"
                    placeholder="Viết trả lời..."
                    required
                  ></textarea>
                  <div class="comment-submit">
                    <button class="button" type="submit">Gửi trả lời</button>
                  </div>
                </form>
              </div>
            <% } %>
            <% if (comment.replies && comment.replies.length) { %>
              <ul class="comment-replies">
                <% comment.replies.forEach((reply) => { %>
                  <li
                    id="comment-<%= reply.id %>"
                    class="comment-item comment-item--reply"
                    data-comment-id="<%= reply.id %>"
                    data-comment-author-id="<%= reply.authorUserId || "" %>"
                    data-comment-parent-author-id="<%= comment.authorUserId || "" %>"
                  >
                    <div
                      class="comment-avatar <%= reply.authorUserId ? "comment-avatar--interactive" : "" %>"
                      <% if (reply.authorUserId) { %>
                        role="link"
                        tabindex="0"
                        data-comment-author-trigger
                        data-comment-user-id="<%= reply.authorUserId %>"
                        <% if (reply.authorUsername) { %>data-comment-username="<%= reply.authorUsername %>"<% } %>
                        aria-label="Xem trang cá nhân của <%= reply.author %>"
                      <% } else { %>
                        aria-hidden="true"
                      <% } %>
                    >
                      <% if (reply.avatarUrl) { %>
                        <img
                          class="comment-avatar__img"
                          src="<%= reply.avatarUrl %>"
                          alt=""
                          loading="lazy"
                          referrerpolicy="no-referrer"
                        />
                      <% } else { %>
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
                          <circle cx="12" cy="8" r="4" />
                          <path d="M4 20c1.6-3.5 5-5 8-5s6.4 1.5 8 5" />
                        </svg>
                      <% } %>
                    </div>
                    <div class="comment-body">
                      <% const replyTopBadge = pickTopBadge(reply.badges || []); %>
                      <% const replyLikeCount = Number(reply.likeCount) > 0 ? Math.floor(Number(reply.likeCount)) : 0; %>
                      <% const replyReportCount = Number(reply.reportCount) > 0 ? Math.floor(Number(reply.reportCount)) : 0; %>
                      <div class="comment-bubble">
                        <div class="comment-header">
                          <span
                            class="comment-author <%= reply.authorUserId ? "comment-author--interactive" : "" %>"
                            <% if (reply.userColor) { %>style="--user-color: <%= reply.userColor %>"<% } %>
                            <% if (reply.authorUserId) { %>
                              role="link"
                              tabindex="0"
                              data-comment-author-trigger
                              data-comment-user-id="<%= reply.authorUserId %>"
                              <% if (reply.authorUsername) { %>data-comment-username="<%= reply.authorUsername %>"<% } %>
                            <% } %>
                          >
                            <span class="comment-author__name"><%= reply.author %></span>
                            <% if (replyTopBadge) { %>
                              <span
                                class="comment-badge"
                                <% if (replyTopBadge.color) { %>style="--badge-color: <%= replyTopBadge.color %>; --badge-bg: <%= `${replyTopBadge.color}22` %>"<% } %>
                              >
                                <%= replyTopBadge.label %>
                              </span>
                            <% } %>
                          </span>
                          <% const replyChapterNumberText = (reply && reply.chapterNumberText ? String(reply.chapterNumberText) : "").trim(); %>
                          <% const replyChapterLabelText = (reply && reply.chapterLabel ? String(reply.chapterLabel) : "").trim(); %>
                          <% if (replyChapterNumberText) { %>
                            <a
                              class="comment-chapter-tag"
                              href="/manga/<%= manga.slug %>/chapters/<%= encodeURIComponent(replyChapterNumberText) %>"
                            >
                              Chương <%= replyChapterNumberText %>
                            </a>
                          <% } else if (replyChapterLabelText) { %>
                            <span class="comment-chapter-tag"><%= replyChapterLabelText %></span>
                          <% } %>
                        </div>
                        <% const replyContentText = String(reply.content || "").trim(); %>
                        <% if (replyContentText) { %>
                          <p
                            class="comment-text"
                            data-comment-raw="<%= reply.content %>"
                            data-comment-mentions="<%= JSON.stringify(reply.mentions || []) %>"
                          ><%= reply.content %></p>
                        <% } %>
                        <% if (reply.imageUrl) { %>
                          <% const replyImageHref = toLh3SizedImageUrl(reply.imageUrl, 0); %>
                          <% const replyImageSrc = toLh3SizedImageUrl(reply.imageUrl, 450); %>
                          <a class="comment-image-link" href="<%= replyImageHref %>" target="_blank" rel="noopener noreferrer">
                                  <img
                                    class="comment-image"
                                    src="<%= replyImageSrc %>"
                                    alt="Ảnh bình luận"
                                    loading="lazy"
                                    referrerpolicy="no-referrer"
                                  />
                                </a>
                              <% } %>
                      </div>
                      <% const replyTimeText = formatTimeAgo(reply.createdAt); %>
                      <% const replyTimeCompact = replyTimeText.replace(/\s+trước$/i, "").trim(); %>
                      <div class="comment-meta">
                        <span class="comment-time" data-time-mobile="<%= replyTimeCompact %>"><%= replyTimeText %></span>
                        <div class="comment-actions">
                          <form method="post" action="/comments/<%= reply.id %>/like">
                            <button
                              class="comment-action comment-action--like <%= reply.liked ? "is-active" : "" %>"
                              type="submit"
                              data-comment-like
                              data-liked="<%= reply.liked ? "1" : "0" %>"
                            >
                              <i class="fa-solid fa-thumbs-up" aria-hidden="true"></i>
                              <span class="comment-action__label">Thích</span>
                              <% if (replyLikeCount > 0) { %>
                                <span class="comment-action__count" data-comment-like-count><%= replyLikeCount %></span>
                              <% } %>
                            </button>
                          </form>
                          <form method="post" action="/comments/<%= reply.id %>/report">
                            <button
                              class="comment-action comment-action--report <%= reply.reported ? "is-muted" : "" %>"
                              type="submit"
                              data-comment-report
                              data-button-loading-skip
                              data-reported="<%= reply.reported ? "1" : "0" %>"
                              <%= reply.reported ? "disabled" : "" %>
                            >
                              <i class="fa-regular fa-flag" aria-hidden="true"></i>
                              <span class="comment-action__label">Báo cáo</span>
                              <% if (replyReportCount > 0) { %>
                                <span class="comment-action__count" data-comment-report-count><%= replyReportCount %></span>
                              <% } %>
                            </button>
                          </form>
                          <button
                            class="comment-action comment-action--delete"
                            type="button"
                            data-comment-delete
                            hidden
                          >
                            <i class="fa-regular fa-trash-can" aria-hidden="true"></i>
                            Xóa
                          </button>
                        </div>
                      </div>
                    </div>
                  </li>
                <% }) %>
              </ul>
            <% } %>
          </div>
        </li>
      <% }) %>
    </ul>
  <% } %>

  <% if (commentTotalPages > 1) { %>
    <nav class="comment-pagination" aria-label="Phân trang bình luận">
      <a
        class="button button--ghost comment-pagination__nav <%= commentPagination && commentPagination.hasPrev ? "" : "is-disabled" %>"
        href="<%= commentPagination && commentPagination.hasPrev ? commentPageHref(commentPagination.prevPage) : "#" %>"
        aria-label="Trang trước"
        <%= commentPagination && commentPagination.hasPrev ? "" : 'tabindex="-1" aria-disabled="true"' %>
      >
        <i class="fa-solid fa-chevron-left" aria-hidden="true"></i>
        <span class="sr-only">Trang trước</span>
      </a>
      <span class="chip comment-pagination__meta">Trang <%= commentPage %>/<%= commentTotalPages %></span>
      <a
        class="button button--ghost comment-pagination__nav <%= commentPagination && commentPagination.hasNext ? "" : "is-disabled" %>"
        href="<%= commentPagination && commentPagination.hasNext ? commentPageHref(commentPagination.nextPage) : "#" %>"
        aria-label="Trang sau"
        <%= commentPagination && commentPagination.hasNext ? "" : 'tabindex="-1" aria-disabled="true"' %>
      >
        <i class="fa-solid fa-chevron-right" aria-hidden="true"></i>
        <span class="sr-only">Trang sau</span>
      </a>
    </nav>
  <% } %>
</section>
