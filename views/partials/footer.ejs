<%
  const runtimeSiteConfig = siteConfig && typeof siteConfig === "object" ? siteConfig : {};
  const brandingConfig =
    runtimeSiteConfig.branding && typeof runtimeSiteConfig.branding === "object"
      ? runtimeSiteConfig.branding
      : {};
  const siteName = (brandingConfig.siteName || "BFANG Team").toString().trim() || "BFANG Team";
  const footerYear =
    (brandingConfig.footerYear || String(new Date().getFullYear())).toString().trim() || String(new Date().getFullYear());
  const dmcaFooterHtml =
    typeof brandingConfig.dmcaFooterHtml === "string" ? brandingConfig.dmcaFooterHtml.trim() : "";
%>
<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-meta">
      <span>© <%= footerYear %> <%= siteName %></span>
      <div class="footer-links">
        <a class="inline-link" href="/manga">Toàn bộ truyện</a>
        <% if (newsPageEnabled) { %>
          <span class="footer-separator" aria-hidden="true">·</span>
          <a class="inline-link" href="/tin-tuc">Tin tức</a>
        <% } %>
        <% if (forumPageEnabled) { %>
          <span class="footer-separator" aria-hidden="true">·</span>
          <a class="inline-link" href="/forum">Diễn đàn</a>
        <% } %>
        <span class="footer-links__legal">
          <span class="footer-separator footer-separator--legal-start" aria-hidden="true">·</span>
          <a class="inline-link" href="/privacy-policy">Chính sách bảo mật</a>
          <span class="footer-links__legal-dot" aria-hidden="true">·</span>
          <a class="inline-link" href="/terms-of-service">Điều khoản dịch vụ</a>
          <span class="footer-links__legal-dot" aria-hidden="true">&middot;</span>
          <a class="inline-link" href="/copyright">Copyright</a>
        </span>
      </div>
      <% if (dmcaFooterHtml) { %>
        <div class="footer-dmca"><%- dmcaFooterHtml %></div>
      <% } %>
    </div>
  </div>
</footer>

<dialog class="modal" data-public-confirm-dialog aria-label="Xác nhận thao tác">
  <div class="modal-card">
    <div class="modal-head">
      <h2 class="modal-title" data-public-confirm-title>Xác nhận</h2>
      <button class="modal-close" type="button" data-public-confirm-close aria-label="Đóng">
        <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <path d="M6 6l12 12" />
          <path d="M18 6L6 18" />
        </svg>
      </button>
    </div>
    <p class="modal-body" data-public-confirm-body></p>
    <div class="modal-meta" data-public-confirm-meta></div>
    <div class="modal-actions">
      <button class="button button--ghost" type="button" data-public-confirm-cancel>Hủy</button>
      <button class="button" type="button" data-public-confirm-ok>Xác nhận</button>
    </div>
  </div>
</dialog>
