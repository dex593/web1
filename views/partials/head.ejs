<head>
  <% const seoData = seo && typeof seo === "object" ? seo : {}; %>
  <% const runtimeSiteConfig = siteConfig && typeof siteConfig === "object" ? siteConfig : {}; %>
  <% const brandingConfig = runtimeSiteConfig.branding && typeof runtimeSiteConfig.branding === "object" ? runtimeSiteConfig.branding : {}; %>
  <% const seoConfig = runtimeSiteConfig.seo && typeof runtimeSiteConfig.seo === "object" ? runtimeSiteConfig.seo : {}; %>
  <% const siteNameFallback = (brandingConfig.siteName || "BFANG Team").toString().trim() || "BFANG Team"; %>
  <% const siteName = (seoData.siteName || siteNameFallback).toString().trim() || siteNameFallback; %>
  <% const pageTitle = (seoData.title || title || "").toString().trim(); %>
  <% const normalizedPageTitle = pageTitle.toLowerCase(); %>
  <% const normalizedSiteName = siteName.toLowerCase(); %>
  <% const hasSiteNameInTitle = Boolean(pageTitle) && normalizedPageTitle.includes(normalizedSiteName); %>
  <% const useAbsoluteTitle = seoData.titleAbsolute === true; %>
  <% const fullTitle = pageTitle
    ? (useAbsoluteTitle || hasSiteNameInTitle ? pageTitle : `${pageTitle} — ${siteName}`)
    : siteName; %>
  <% const defaultSeoDescription = (seoConfig.defaultDescription || `${siteNameFallback} - Đọc truyện tranh online miễn phí, cập nhật nhanh mỗi ngày.`).toString().trim(); %>
  <% const seoDescription = (seoData.description || defaultSeoDescription).toString().trim(); %>
  <% const seoKeywordListRaw = Array.isArray(seoData.keywordList)
    ? seoData.keywordList
    : (seoData.keywords || "").toString().split(","); %>
  <% const seoKeywordSeen = new Set(); %>
  <% const seoKeywordList = []; %>
  <% seoKeywordListRaw.forEach((value) => {
    const keyword = (value || "").toString().replace(/\s+/g, " ").trim();
    if (!keyword) return;
    const normalizedKeyword = keyword.toLowerCase();
    if (seoKeywordSeen.has(normalizedKeyword)) return;
    seoKeywordSeen.add(normalizedKeyword);
    seoKeywordList.push(keyword);
  }); %>
  <% const seoKeywords = seoKeywordList.join(", "); %>
  <% const seoCanonical = (seoData.canonical || "").toString().trim(); %>
  <% const seoAmpHtml = (seoData.ampHtml || "").toString().trim(); %>
  <% const requestPathValue = (typeof requestPath === "string" ? requestPath : "").toString().trim(); %>
  <% const isAdminRequest = typeof isAdminPath === "boolean"
    ? isAdminPath
    : requestPathValue === "/admin" || requestPathValue.startsWith("/admin/"); %>
  <% const isAdultContentControlEnabled = Boolean(adultContentControlEnabled); %>
  <% const isChapterPath = /^\/manga\/[^/]+\/chapters\/[^/]+$/.test(requestPathValue); %>
  <% const isMangaDetailPath = /^\/manga\/[^/]+$/.test(requestPathValue); %>
  <% const isMangaListPath = requestPathValue === "/manga"; %>
  <% const isHomepagePath = requestPathValue === "/"; %>
  <% const defaultRobots = pageTitle === "Không tìm thấy"
    ? "noindex,nofollow,noarchive,nosnippet,noimageindex,max-snippet:0,max-image-preview:none,max-video-preview:0"
    : "index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1"; %>
  <% const seoRobots = (seoData.robots || defaultRobots).toString().trim(); %>
  <% const ogType = (seoData.ogType || "website").toString().trim() || "website"; %>
  <% const ogImage = (seoData.image || "").toString().trim(); %>
  <% const twitterCard = (seoData.twitterCard || (ogImage ? "summary_large_image" : "summary")).toString().trim(); %>
  <% const googleFontsStylesheetUrl = "https://fonts.googleapis.com/css2?family=Anton&family=Noto+Sans+JP:wght@400;500;700&display=swap"; %>
  <% const fontAwesomeStylesheetUrl = "https://cdn.jsdelivr.net/npm/@fortawesome/fontawesome-free@6.7.2/css/all.min.css"; %>
  <% const flowbiteScriptUrl = "https://cdn.jsdelivr.net/npm/flowbite@2.5.2/dist/flowbite.min.js"; %>
  <% const jsonLdList = Array.isArray(seoData.jsonLd) ? seoData.jsonLd : []; %>
  <% const safeHeadScripts = typeof headScripts !== "undefined" ? headScripts : null; %>
  <% const safeHeadStyles = typeof headStyles !== "undefined" ? headStyles : null; %>
  <% const safeHeadExtraStylesheets = typeof headExtraStylesheets !== "undefined" ? headExtraStylesheets : null; %>
  <% const safeHeadPreconnectOrigins = typeof headPreconnectOrigins !== "undefined" ? headPreconnectOrigins : null; %>
  <% const safeHeadPreloadImages = typeof headPreloadImages !== "undefined" ? headPreloadImages : null; %>
  <% const headScriptOverrides = safeHeadScripts && typeof safeHeadScripts === "object" ? safeHeadScripts : {}; %>
  <% const headStyleOverrides = safeHeadStyles && typeof safeHeadStyles === "object" ? safeHeadStyles : {}; %>
  <% const headScriptDefaults = {
    confirm: true,
    toast: true,
    auth: true,
    buttonUi: true,
    serviceWorker: !isAdminRequest,
    pwaInstall: !isAdminRequest,
    fastNav: !isAdminRequest && !isChapterPath,
    flowbite: isAdminRequest,
    continueReading: !isAdminRequest,
    readingActivityTicker: !isAdminRequest,
    readingHistory: false,
    bookmarks: false,
    notifications: false,
    messagesIndicator: !isAdminRequest,
    adultContent: !isAdminRequest && isAdultContentControlEnabled,
    homepageRefresh: isHomepagePath,
    comments: false,
    mangaDetail: isMangaDetailPath,
    filters: isMangaListPath || (isAdminRequest && requestPathValue.startsWith("/admin/manga")),
    headerSearch: !isAdminRequest,
    lazysizes: isChapterPath,
    reader: isChapterPath,
    admin: isAdminRequest
  }; %>
  <% const isHeadScriptEnabled = (key) => {
    if (Object.prototype.hasOwnProperty.call(headScriptOverrides, key)) {
      return Boolean(headScriptOverrides[key]);
    }
    return Boolean(headScriptDefaults[key]);
  }; %>
  <% const headStyleDefaults = {
    googleFonts: true,
    fontAwesome: true
  }; %>
  <% const isHeadStyleEnabled = (key) => {
    if (Object.prototype.hasOwnProperty.call(headStyleOverrides, key)) {
      return Boolean(headStyleOverrides[key]);
    }
    return Boolean(headStyleDefaults[key]);
  }; %>
  <% const extraPreconnectOriginsRaw = Array.isArray(safeHeadPreconnectOrigins) ? safeHeadPreconnectOrigins : []; %>
  <% const extraPreconnectOrigins = []; %>
  <% const preconnectSeen = new Set(); %>
  <% if (isHeadStyleEnabled("googleFonts")) {
    preconnectSeen.add("https://fonts.googleapis.com");
    preconnectSeen.add("https://fonts.gstatic.com");
  } %>
  <% if (isHeadStyleEnabled("fontAwesome")) {
    preconnectSeen.add("https://cdn.jsdelivr.net");
  } %>
  <% extraPreconnectOriginsRaw.forEach((originValue) => {
    const origin = (originValue || "").toString().trim();
    if (!origin || !/^https:\/\//i.test(origin) || preconnectSeen.has(origin)) return;
    preconnectSeen.add(origin);
    extraPreconnectOrigins.push(origin);
  }); %>
  <% const preloadImagesRaw = Array.isArray(safeHeadPreloadImages) ? safeHeadPreloadImages : []; %>
  <% const preloadImages = []; %>
  <% const preloadSeen = new Set(); %>
  <% const extraStylesheetsRaw = Array.isArray(safeHeadExtraStylesheets) ? safeHeadExtraStylesheets : []; %>
  <% const extraStylesheets = []; %>
  <% const extraStylesheetSeen = new Set(); %>
  <% const assetToken = assetVersion == null ? "" : String(assetVersion).trim(); %>
  <% const assetUrl = (url) => {
    const raw = (url || "").toString();
    if (!raw || !assetToken) return raw;
    if (typeof cacheBust === "function") {
      return cacheBust(raw, assetToken);
    }
    const separator = raw.includes("?") ? "&" : "?";
    return `${raw}${separator}t=${encodeURIComponent(assetToken)}`;
  }; %>
  <% const safeJsonForScript = (value) => JSON.stringify(value)
    .replace(/</g, "\\u003c")
    .replace(/>/g, "\\u003e")
    .replace(/&/g, "\\u0026")
    .replace(/\u2028/g, "\\u2028")
    .replace(/\u2029/g, "\\u2029"); %>
  <% preloadImagesRaw.forEach((imageValue) => {
    const imageHref = (imageValue || "").toString().trim();
    const isValid = imageHref.startsWith("/") || /^https?:\/\//i.test(imageHref);
    if (!isValid || preloadSeen.has(imageHref)) return;
    preloadSeen.add(imageHref);
    preloadImages.push(imageHref);
  }); %>
  <% extraStylesheetsRaw.forEach((stylesheetValue) => {
    const stylesheetHref = (stylesheetValue || "").toString().trim();
    const isValid = stylesheetHref.startsWith("/") || /^https:\/\//i.test(stylesheetHref);
    if (!isValid || extraStylesheetSeen.has(stylesheetHref)) return;
    extraStylesheetSeen.add(stylesheetHref);
    extraStylesheets.push(stylesheetHref);
  }); %>
<% const toastUiRevision = "toast-ui-v63"; %>
  <% const mainStylesheetUrl = assetUrl(`/styles.css?rev=${toastUiRevision}`); %>

  <%- include("head-meta", {
    fullTitle,
    seoDescription,
    seoKeywords,
    seoRobots,
    siteName,
    seoCanonical,
    seoAmpHtml,
    ogType,
    seoKeywordList,
    ogImage,
    twitterCard,
    jsonLdList,
    safeJsonForScript,
    assetUrl,
    cspNonce
  }) %>
  <%- include("head-config", {
    runtimeSiteConfig,
    authPublicConfig,
    turnstilePublicConfig,
    safeJsonForScript,
    assetUrl,
    cspNonce
  }) %>
  <%- include("head-styles", {
    isHeadStyleEnabled,
    extraPreconnectOrigins,
    googleFontsStylesheetUrl,
    fontAwesomeStylesheetUrl,
    mainStylesheetUrl,
    extraStylesheets,
    assetUrl,
    preloadImages,
    cspNonce
  }) %>
  <% if (isAdultContentControlEnabled) { %>
    <style nonce="<%= cspNonce || '' %>">
      .cover--adult {
        position: relative;
      }

      .cover--adult img {
        filter: blur(14px) saturate(0.78) brightness(0.68);
        transform: scale(1.04);
        transform-origin: center;
      }

      .cover--adult::after {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(180deg, rgba(0, 0, 0, 0.08), rgba(0, 0, 0, 0.58));
        pointer-events: none;
      }

      .cover--adult.is-adult-revealed img,
      .cover--adult[data-adult-revealed="1"] img {
        filter: none;
        transform: none;
      }

      .cover--adult.is-adult-revealed::after,
      .cover--adult[data-adult-revealed="1"]::after {
        display: none;
      }
    </style>
  <% } %>
  <%- include("head-scripts", {
    isHeadScriptEnabled,
    flowbiteScriptUrl,
    assetUrl,
    toastUiRevision,
    cspNonce
  }) %>
</head>
