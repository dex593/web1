  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= fullTitle %></title>
  <meta name="description" content="<%= seoDescription %>" />
  <% if (seoKeywords) { %>
    <meta name="keywords" content="<%= seoKeywords %>" />
    <meta name="news_keywords" content="<%= seoKeywords %>" />
  <% } %>
  <meta name="robots" content="<%= seoRobots %>" />
  <meta name="googlebot" content="<%= seoRobots %>" />
  <meta name="author" content="<%= siteName %>" />
  <meta name="application-name" content="<%= siteName %>" />
  <meta name="theme-color" content="#0f0f11" />
  <meta name="mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <meta name="apple-mobile-web-app-title" content="<%= siteName %>" />
  <link rel="manifest" href="<%= assetUrl("/manifest.webmanifest") %>" />
  <link rel="apple-touch-icon" href="<%= assetUrl("/pwa/apple-touch-icon.png") %>" />
  <link rel="icon" type="image/svg+xml" href="<%= assetUrl("/logobfang.svg") %>" />

  <% if (seoCanonical) { %>
    <link rel="canonical" href="<%= seoCanonical %>" />
    <link rel="alternate" hreflang="vi-VN" href="<%= seoCanonical %>" />
    <link rel="alternate" hreflang="x-default" href="<%= seoCanonical %>" />
  <% } %>
  <% if (seoAmpHtml) { %>
    <link rel="amphtml" href="<%= seoAmpHtml %>" />
  <% } %>

  <meta property="og:locale" content="vi_VN" />
  <meta property="og:type" content="<%= ogType %>" />
  <% if (ogType === "article" && seoKeywordList.length) { %>
    <% seoKeywordList.slice(0, 12).forEach((keyword) => { %>
      <meta property="article:tag" content="<%= keyword %>" />
    <% }) %>
  <% } %>
  <meta property="og:site_name" content="<%= siteName %>" />
  <meta property="og:title" content="<%= fullTitle %>" />
  <meta property="og:description" content="<%= seoDescription %>" />
  <% if (seoCanonical) { %>
    <meta property="og:url" content="<%= seoCanonical %>" />
  <% } %>
  <% if (ogImage) { %>
    <meta property="og:image" content="<%= ogImage %>" />
  <% } %>

  <meta name="twitter:card" content="<%= twitterCard %>" />
  <meta name="twitter:title" content="<%= fullTitle %>" />
  <meta name="twitter:description" content="<%= seoDescription %>" />
  <% if (ogImage) { %>
    <meta name="twitter:image" content="<%= ogImage %>" />
  <% } %>

  <% if (jsonLdList.length) { %>
    <% jsonLdList.forEach((schema) => { %>
      <script type="application/ld+json" nonce="<%= cspNonce || "" %>"><%- safeJsonForScript(schema) %></script>
    <% }) %>
  <% } %>
