      @media (min-width: 760px) {
        .site {
          padding: 18px;
        }

        .intro-grid,
        .about-grid {
          grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .grid {
          grid-template-columns: repeat(3, minmax(0, 1fr));
        }
      }
    </style>
  </head>
  <body>
    <div class="site">
      <header class="site-header">
        <div class="container header-inner">
          <a class="brand" href="/" aria-label="<%= `${brandMark} ${brandSubmark}`.trim() %>">
            <span class="brand__mark"><%= brandMark %></span>
            <span class="brand__sub"><%= brandSubmark %></span>
          </a>
          <div class="header-actions">
            <div class="header-nav">
              <nav class="nav" id="site-nav-links">
                <a href="/manga">Toàn bộ truyện</a>
                <% if (newsPageEnabled) { %>
                  <a href="/tin-tuc">Tin tức</a>
                <% } %>
                <% if (forumPageEnabled) { %>
                  <a href="/forum">Diễn đàn</a>
                <% } %>
                <a href="/publish" data-publish-nav-link data-publish-nav-mode="<%= initialPublishMode %>"><%= initialPublishLabel %></a>
                <a href="/#about"><%= aboutNavLabel %></a>
              </nav>
            </div>
            <a
              class="message-trigger"
              href="/messages"
              <%= isInitiallySignedIn ? "" : "hidden" %>
              data-auth-member-only="1"
              data-message-widget
              title="Tin nhắn"
            >
              <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M21 14.2a3.8 3.8 0 0 1-3.8 3.8H9l-4.5 3v-3.4A3.8 3.8 0 0 1 1 13.8V6.8A3.8 3.8 0 0 1 4.8 3h12.4A3.8 3.8 0 0 1 21 6.8z" />
              </svg>
              <span class="notify-badge" hidden data-message-badge>0</span>
              <span class="sr-only">Tin nhắn</span>
            </a>
            <div class="notify-widget" <%= isInitiallySignedIn ? "" : "hidden" %> data-notify-widget>
              <button
                class="notify-trigger"
                type="button"
                data-notify-toggle
                aria-haspopup="menu"
                aria-expanded="false"
                title="Thông báo"
              >
                <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M6.8 9a5.2 5.2 0 1 1 10.4 0v3.1c0 .8.3 1.5.8 2.1l1.1 1.3H5l1.1-1.3c.5-.6.8-1.3.8-2.1z" />
                  <path d="M9.8 18.1a2.2 2.2 0 0 0 4.4 0" />
                </svg>
                <span class="notify-badge" hidden data-notify-badge>0</span>
                <span class="sr-only">Thông báo</span>
              </button>
            </div>
            <div class="auth-widget" data-auth-widget>
              <a
                class="button button--ghost auth-widget__login"
                href="<%= loginHref %>"
                target="_top"
                <%= isInitiallySignedIn ? "hidden" : "" %>
              >
                Đăng nhập
              </a>
              <div class="auth-widget__profile" <%= isInitiallySignedIn ? "" : "hidden" %> data-auth-profile>
                <button
                  class="auth-trigger"
                  type="button"
                  data-auth-menu-toggle
                  aria-haspopup="menu"
                  aria-expanded="false"
                  title="Tài khoản"
                >
                  <svg
                    class="auth-trigger__fallback"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.6"
                    aria-hidden="true"
                  >
                    <circle cx="12" cy="8" r="4" />
                    <path d="M4 20c1.6-3.5 5-5 8-5s6.4 1.5 8 5" />
                  </svg>
                </button>
              </div>
            </div>
          </div>
        </div>
      </header>
      <main class="amp-main">

      <header class="hero">
        <h1><%= welcomeMessage %></h1>
        <p><%= introductionText %></p>
        <div class="stats">
          <div class="stat">
            <b><%= stats && stats.totalSeries ? stats.totalSeries : 0 %></b>
            <span>Truyện</span>
          </div>
          <div class="stat">
            <b><%= stats && stats.totalChapters ? stats.totalChapters : 0 %></b>
            <span>Chương</span>
          </div>
        </div>
        <div class="intro-grid">
          <article class="intro-card">
            <p class="intro-card-title">Thông báo</p>
            <% if (noticeList.length) { %>
              <% noticeList.slice(0, 3).forEach((notice) => { %>
                <div class="intro-note">
                  <% if (notice && notice.title) { %>
                    <span class="intro-note-title"><%= notice.title %></span>
                  <% } %>
                  <% if (notice && notice.body) { %>
                    <p class="intro-note-text"><%= notice.body %></p>
                  <% } %>
                </div>
              <% }) %>
            <% } else { %>
              <p class="intro-note-text">Chưa có thông báo.</p>
            <% } %>
          </article>
          <article class="intro-card">
            <p class="intro-card-title">Kênh liên hệ</p>
            <a class="contact-link" href="<%= facebookUrl %>">
              Facebook
              <span><%= facebookLabel %></span>
            </a>
            <a class="contact-link" href="<%= discordUrl %>">
              Discord
              <span><%= discordLabel %></span>
            </a>
          </article>
        </div>
      </header>

      <% if (showForumSection) { %>
        <section class="section">
          <div class="section-header">
            <h2>Diễn đàn</h2>
            <span class="section-line"></span>
          </div>
          <ul class="forum-list">
            <% forumPosts.forEach((post) => { %>
              <li class="forum-item">
                <a class="forum-link" href="<%= post && post.href ? post.href : "/forum" %>">
                  <p class="forum-title"><%= post && post.title ? post.title : "Bài viết mới" %></p>
                  <p class="forum-meta">
                    <%= post && post.metadataAuthor ? post.metadataAuthor : (post && post.authorName ? post.authorName : "Thành viên") %>
                    <% if (post && post.timeAgo) { %>
                      · <%= post.timeAgo %>
                    <% } %>
                    <% if (post && Number.isFinite(Number(post.commentCount))) { %>
                      · <%= Number(post.commentCount) %> bình luận
                    <% } %>
                  </p>
                </a>
              </li>
            <% }) %>
          </ul>
        </section>
      <% } %>

      <section class="section">
        <div class="section-header">
          <h2>Tựa nổi bật</h2>
          <span class="section-line"></span>
        </div>
        <div class="grid">
          <% featuredList.forEach((manga) => { %>
            <article class="card">
              <a href="/manga/<%= encodeURIComponent(manga.slug) %>">
                <div class="cover">
                  <% if (manga.cover) { %>
                    <% const coverBase = cacheBust(manga.cover, manga.coverUpdatedAt); %>
                    <% const coverAmp = appendCoverVariant(coverBase, 360, 540, 95); %>
                    <amp-img src="<%= coverAmp %>" width="360" height="540" layout="responsive" alt="Bìa <%= manga.title %>"></amp-img>
                  <% } else { %>
                    <span class="no-cover">No Cover</span>
                  <% } %>
                </div>
                <div class="body">
                  <p class="title"><%= manga.title %></p>
                  <p class="author"><%= manga.groupName || manga.author || "" %></p>
                  <div class="meta-row">
                    <span class="tag"><%= manga.status || "Đang cập nhật" %></span>
                    <span class="meta"><%= toChapterLabel(manga) %></span>
                  </div>
                </div>
              </a>
            </article>
          <% }) %>
        </div>
      </section>

      <section class="section">
        <div class="section-header">
          <h2>Mới cập nhật</h2>
          <span class="section-line"></span>
        </div>
        <div class="grid">
          <% latestList.forEach((manga) => { %>
            <article class="card">
              <a href="/manga/<%= encodeURIComponent(manga.slug) %>">
                <div class="cover">
                  <% if (manga.cover) { %>
                    <% const coverBase = cacheBust(manga.cover, manga.coverUpdatedAt); %>
                    <% const coverAmp = appendCoverVariant(coverBase, 320, 480, 95); %>
                    <amp-img src="<%= coverAmp %>" width="320" height="480" layout="responsive" alt="Bìa <%= manga.title %>"></amp-img>
                  <% } else { %>
                    <span class="no-cover">No Cover</span>
                  <% } %>
                </div>
                <div class="body">
                  <p class="title"><%= manga.title %></p>
                  <p class="author"><%= manga.groupName || manga.author || "" %></p>
                  <div class="meta-row">
                    <span class="tag"><%= manga.status || "Đang cập nhật" %></span>
                    <span class="meta"><%= toChapterLabel(manga) %></span>
                  </div>
                </div>
              </a>
            </article>
          <% }) %>
        </div>
      </section>

      <section class="section" id="about">
        <div class="section-header">
          <h2><%= aboutTitle %></h2>
          <span class="section-line"></span>
        </div>
        <div class="about-grid">
          <article class="about-card">
            <h3><%= contentStandardsTitle %></h3>
            <% contentStandards.forEach((line) => { %>
              <p><%= line %></p>
            <% }) %>
          </article>
          <article class="about-card">
            <h3>Thông tin nhanh</h3>
            <p>Năm thành lập: <%= foundedYear %></p>
            <p>Dự án manga: <%= stats && stats.totalSeries ? stats.totalSeries : 0 %>+</p>
            <p>Chương đã dịch: <%= stats && stats.totalChapters ? stats.totalChapters : 0 %>+</p>
            <h3 style="margin-top:10px;"><%= contactTitle %></h3>
            <a class="contact-link" href="<%= facebookUrl %>">
              Facebook
              <span><%= facebookLabel %></span>
            </a>
            <a class="contact-link" href="<%= discordUrl %>">
              Discord
              <span><%= discordLabel %></span>
            </a>
          </article>
        </div>
      </section>

      </main>
      <footer class="site-footer">
        <div class="container footer-inner">
          <div class="footer-meta">
            <span>© <%= footerYear %> <%= siteName %></span>
            <div class="footer-links">
              <a href="/manga">Toàn bộ truyện</a>
              <% if (newsPageEnabled) { %>
                <span class="footer-separator" aria-hidden="true">·</span>
                <a href="/tin-tuc">Tin tức</a>
              <% } %>
              <% if (forumPageEnabled) { %>
                <span class="footer-separator" aria-hidden="true">·</span>
                <a href="/forum">Diễn đàn</a>
              <% } %>
              <span class="footer-separator" aria-hidden="true">·</span>
              <a href="/privacy-policy">Privacy Policy</a>
              <span class="footer-links__legal-dot" aria-hidden="true">·</span>
              <a href="/terms-of-service">Terms of Service</a>
            </div>
          </div>
        </div>
      </footer>
    </div>
  </body>
</html>
