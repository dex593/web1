<%
  const featuredList = Array.isArray(featured) ? featured.slice(0, 8) : [];
  const latestList = Array.isArray(latest) ? latest.slice(0, 12) : [];
  const pageCanonical = (canonicalUrl || webUrl || "").toString().trim() || "/";

  const appendCoverVariant = (url, width, height, quality) => {
    const raw = (url || "").toString().trim();
    const parsedWidth = Number(width);
    const parsedHeight = Number(height);
    const parsedQuality = Number(quality);
    if (!raw || !Number.isFinite(parsedWidth) || parsedWidth <= 0) return raw;

    const params = [`w=${Math.floor(parsedWidth)}`];
    if (Number.isFinite(parsedHeight) && parsedHeight > 0) {
      params.push(`h=${Math.floor(parsedHeight)}`);
    }
    if (Number.isFinite(parsedQuality) && parsedQuality > 0) {
      params.push(`q=${Math.floor(parsedQuality)}`);
    }

    const separator = raw.includes("?") ? "&" : "?";
    return `${raw}${separator}${params.join("&")}`;
  };

  const toChapterLabel = (manga) => {
    if (!manga) return "";
    if (manga.latestChapterIsOneshot) return "Oneshot";
    const number = Number(manga.latestChapterNumber) || 0;
    return `Chương ${number}`;
  };

  const buildLoginHref = (url) => {
    const raw = (url || "/").toString().trim() || "/";
    const separator = raw.includes("?") ? "&" : "?";
    return `${raw}${separator}auth=login`;
  };

  const loginHref = buildLoginHref(pageCanonical);
  const runtimeSiteConfig = siteConfig && typeof siteConfig === "object" ? siteConfig : {};
  const brandingConfig =
    runtimeSiteConfig.branding && typeof runtimeSiteConfig.branding === "object"
      ? runtimeSiteConfig.branding
      : {};
  const homepageConfig =
    runtimeSiteConfig.homepage && typeof runtimeSiteConfig.homepage === "object"
      ? runtimeSiteConfig.homepage
      : {};
  const seoConfig =
    runtimeSiteConfig.seo && typeof runtimeSiteConfig.seo === "object"
      ? runtimeSiteConfig.seo
      : {};
  const siteName = (brandingConfig.siteName || "BFANG Team").toString().trim() || "BFANG Team";
  const brandMark = (brandingConfig.brandMark || "BFANG").toString().trim() || "BFANG";
  const brandSubmark = (brandingConfig.brandSubmark || "Team").toString().trim() || "Team";
  const aboutNavLabel =
    (brandingConfig.aboutNavLabel || `Về ${brandMark}`).toString().trim() || `Về ${brandMark}`;
  const footerYear =
    (brandingConfig.footerYear || String(new Date().getFullYear())).toString().trim() || String(new Date().getFullYear());
  const authConfig = authPublicConfig && typeof authPublicConfig === "object" ? authPublicConfig : {};
  const initialAuthState =
    authConfig.initialState && typeof authConfig.initialState === "object" ? authConfig.initialState : null;
  const isInitiallySignedIn = Boolean(initialAuthState && initialAuthState.signedIn === true);
  const initialPublishNav =
    initialAuthState && initialAuthState.publishNav && typeof initialAuthState.publishNav === "object"
      ? initialAuthState.publishNav
      : null;
  const initialPublishLabel = isInitiallySignedIn && initialPublishNav && initialPublishNav.inTeam ? "Nhóm dịch" : "Đăng truyện";
  const initialPublishMode = initialPublishLabel === "Nhóm dịch" ? "team" : "publish";
  const welcomeMessage =
    (homepageConfig.welcomeMessage || `Chào mừng bạn đến với website của ${siteName}.`).toString().trim() ||
    `Chào mừng bạn đến với website của ${siteName}.`;
  const introductionText =
    (homepageConfig.introduction ||
      `${siteName} là nhóm dịch manga hoạt động từ năm 2019 với hàng chục đầu truyện và hàng trăm chương truyện.`)
      .toString()
      .trim();
  const aboutTitle = (homepageConfig.aboutTitle || `Về ${siteName}`).toString().trim() || `Về ${siteName}`;
  const foundedYear = (homepageConfig.foundedYear || "2019").toString().trim() || "2019";
  const contentStandardsTitle =
    (homepageConfig.contentStandardsTitle || "Tiêu chuẩn nội dung").toString().trim() || "Tiêu chuẩn nội dung";
  const contactTitle = (homepageConfig.contactTitle || "Kênh liên hệ").toString().trim() || "Kênh liên hệ";
  const fallbackContentStandards = [
    "Chúng tôi chỉ làm manga, và thể loại yêu thích nhất là Drama.",
    "Các dự án được dịch thuật từ tiếng Anh hoặc tiếng Nhật và sử dụng Adobe Photoshop để biên tập."
  ];
  const normalizedContentStandards = Array.isArray(homepageConfig.contentStandards)
    ? homepageConfig.contentStandards
      .map((item) => (item == null ? "" : String(item)).trim())
      .filter(Boolean)
    : [];
  const contentStandards = normalizedContentStandards.length ? normalizedContentStandards : fallbackContentStandards;
  const contactConfig =
    runtimeSiteConfig.contact && typeof runtimeSiteConfig.contact === "object"
      ? runtimeSiteConfig.contact
      : {};
  const normalizeExternalUrl = (value) => {
    const raw = (value || "").toString().trim();
    if (!raw) return "";
    const candidate = /^https?:\/\//i.test(raw) ? raw : `https://${raw.replace(/^\/+/, "")}`;
    try {
      const parsed = new URL(candidate);
      if (parsed.protocol !== "https:" && parsed.protocol !== "http:") return "";
      return `${parsed.protocol}//${parsed.host}${parsed.pathname || "/"}${parsed.search || ""}`;
    } catch (_err) {
      return "";
    }
  };
  const facebookUrl =
    normalizeExternalUrl(contactConfig.facebookUrl || "") ||
    "https://facebook.com/Bfangteam/";
  const facebookLabel =
    (contactConfig.facebookLabel || "facebook.com/Bfangteam").toString().trim() || "facebook.com/Bfangteam";
  const discordUrl =
    normalizeExternalUrl(contactConfig.discordUrl || "") ||
    "https://discord.moetruyen.net/";
  const discordLabel =
    (contactConfig.discordLabel || "discord.moetruyen.net").toString().trim() || "discord.moetruyen.net";
  const homepageData = homepage && typeof homepage === "object" ? homepage : {};
  const noticeList = Array.isArray(homepageData.notices) ? homepageData.notices : [];
  const forumPosts = Array.isArray(forumLatestPosts) ? forumLatestPosts.slice(0, 6) : [];
  const showForumSection = Boolean(forumPageEnabled) && forumPosts.length > 0;
  const seoData = seo && typeof seo === "object" ? seo : {};
  const fallbackSeoTitle =
    (seoConfig.homepageTitle || `${siteName} - Đọc truyện tranh online miễn phí`).toString().trim() ||
    `${siteName} - Đọc truyện tranh online miễn phí`;
  const fallbackSeoDescription =
    (
      seoConfig.homepageDescription ||
      `${siteName} là nơi đọc truyện tranh online miễn phí, cập nhật nhanh manga, manhwa, manhua mới nhất mỗi ngày.`
    )
      .toString()
      .trim() ||
    `${siteName} là nơi đọc truyện tranh online miễn phí, cập nhật nhanh manga, manhwa, manhua mới nhất mỗi ngày.`;
  const seoTitle = (seoData.title || fallbackSeoTitle).toString().trim() || fallbackSeoTitle;
  const useAbsoluteSeoTitle = seoData.titleAbsolute === true;
  const normalizedSeoTitle = seoTitle.toLowerCase();
  const normalizedSiteName = siteName.toLowerCase();
  const composedSeoTitle = useAbsoluteSeoTitle || normalizedSeoTitle.includes(normalizedSiteName)
    ? seoTitle
    : `${seoTitle} — ${siteName}`;
  const seoDescription = (seoData.description || fallbackSeoDescription).toString().trim() || fallbackSeoDescription;
  const seoKeywords = (seoData.keywords || "").toString().trim();
  const seoCanonical = (seoData.canonical || pageCanonical).toString().trim() || pageCanonical;
  const seoRobots =
    (seoData.robots || "index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1").toString().trim() ||
    "index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1";
  const seoOgType = (seoData.ogType || "website").toString().trim() || "website";
  const seoImage = (seoData.image || "").toString().trim();
  const seoTwitterCard = (seoData.twitterCard || (seoImage ? "summary_large_image" : "summary")).toString().trim();
  const routeJsonLdList =
    typeof ampSchemas !== "undefined" && Array.isArray(ampSchemas) ? ampSchemas : [];
  const seoJsonLdList = Array.isArray(seoData.jsonLd) ? seoData.jsonLd : routeJsonLdList;
  const fallbackJsonLdList = [
    {
      "@context": "https://schema.org",
      "@type": seoOgType === "article" ? "Article" : "WebPage",
      name: composedSeoTitle,
      description: seoDescription,
      url: seoCanonical,
      inLanguage: "vi"
    }
  ];
  const finalJsonLdList = seoJsonLdList.length ? seoJsonLdList : fallbackJsonLdList;
  const safeJsonForScript = (value) => JSON.stringify(value)
    .replace(/</g, "\\u003c")
    .replace(/>/g, "\\u003e")
    .replace(/&/g, "\\u0026")
    .replace(/\u2028/g, "\\u2028")
    .replace(/\u2029/g, "\\u2029");
%>
<!doctype html>
<html amp lang="vi">
  <head>
    <meta charset="utf-8" />
    <title><%= composedSeoTitle %></title>
    <meta name="description" content="<%= seoDescription %>" />
    <% if (seoKeywords) { %>
      <meta name="keywords" content="<%= seoKeywords %>" />
      <meta name="news_keywords" content="<%= seoKeywords %>" />
    <% } %>
    <meta name="robots" content="<%= seoRobots %>" />
    <meta name="googlebot" content="<%= seoRobots %>" />
    <meta name="author" content="<%= siteName %>" />
    <meta name="theme-color" content="#0f0f11" />
    <meta property="og:locale" content="vi_VN" />
    <meta property="og:type" content="<%= seoOgType %>" />
    <meta property="og:site_name" content="<%= siteName %>" />
    <meta property="og:title" content="<%= composedSeoTitle %>" />
    <meta property="og:description" content="<%= seoDescription %>" />
    <meta property="og:url" content="<%= seoCanonical %>" />
    <% if (seoImage) { %>
      <meta property="og:image" content="<%= seoImage %>" />
    <% } %>
    <meta name="twitter:card" content="<%= seoTwitterCard %>" />
    <meta name="twitter:title" content="<%= composedSeoTitle %>" />
    <meta name="twitter:description" content="<%= seoDescription %>" />
    <% if (seoImage) { %>
      <meta name="twitter:image" content="<%= seoImage %>" />
    <% } %>
    <link rel="canonical" href="<%= seoCanonical %>" />
    <link rel="alternate" hreflang="vi-VN" href="<%= seoCanonical %>" />
    <link rel="alternate" hreflang="x-default" href="<%= seoCanonical %>" />
    <meta name="viewport" content="width=device-width,minimum-scale=1,initial-scale=1" />
    <% if (finalJsonLdList.length) { %>
      <% finalJsonLdList.forEach((schema) => { %>
        <script type="application/ld+json"><%- safeJsonForScript(schema) %></script>
      <% }) %>
    <% } %>
    <script async src="https://cdn.ampproject.org/v0.js"></script>
    <style amp-boilerplate>
      body {
        -webkit-animation: -amp-start 8s steps(1, end) 0s 1 normal both;
        -moz-animation: -amp-start 8s steps(1, end) 0s 1 normal both;
        -ms-animation: -amp-start 8s steps(1, end) 0s 1 normal both;
        animation: -amp-start 8s steps(1, end) 0s 1 normal both;
      }
      @-webkit-keyframes -amp-start {
        from {
          visibility: hidden;
        }
        to {
          visibility: visible;
        }
      }
      @-moz-keyframes -amp-start {
        from {
          visibility: hidden;
        }
        to {
          visibility: visible;
        }
      }
      @-ms-keyframes -amp-start {
        from {
          visibility: hidden;
        }
        to {
          visibility: visible;
        }
      }
      @-o-keyframes -amp-start {
        from {
          visibility: hidden;
        }
        to {
          visibility: visible;
        }
      }
      @keyframes -amp-start {
        from {
          visibility: hidden;
        }
        to {
          visibility: visible;
        }
      }
    </style>
    <noscript>
      <style amp-boilerplate>
        body {
          -webkit-animation: none;
          -moz-animation: none;
          -ms-animation: none;
          animation: none;
        }
      </style>
    </noscript>
    <style amp-custom>
      :root {
        --bg: #0f0f11;
        --panel: #17171b;
        --card: #1a1a1f;
        --border: #2f2f35;
