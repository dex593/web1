<%
  const pageCanonical = (canonicalUrl || webUrl || "").toString().trim() || "/";
  const chapterList = Array.isArray(manga && manga.chapters) ? manga.chapters : [];
  const visibleChapters = chapterList.slice(0, 24);
  const hiddenChapterCount = Math.max(chapterList.length - visibleChapters.length, 0);
  const groupLinks = Array.isArray(manga && manga.groupTeamLinks)
    ? manga.groupTeamLinks
      .map((item) => ({
        label: item && item.label ? String(item.label).trim() : "",
        url: item && item.url ? String(item.url).trim() : ""
      }))
      .filter((item) => item.label)
    : [];
  const authorList = (manga && manga.author ? manga.author : "")
    .split(",")
    .map((value) => value.trim())
    .filter(Boolean);
  const otherNameList = (manga && manga.otherNames ? manga.otherNames : "")
    .split(/\r?\n/)
    .map((value) => value.trim())
    .filter(Boolean);
  const formattedUpdatedAt =
    manga && manga.updatedAt && typeof formatDate === "function" ? formatDate(manga.updatedAt) : "";
  const commentHref = `${pageCanonical}#comments`;

  const buildCoverVariantUrl = (url, suffix) => {
    const raw = (url || "").toString().trim();
    if (!raw) return "";
    const hashIndex = raw.indexOf("#");
    const hashPart = hashIndex >= 0 ? raw.slice(hashIndex) : "";
    const withoutHash = hashIndex >= 0 ? raw.slice(0, hashIndex) : raw;
    const queryIndex = withoutHash.indexOf("?");
    const queryPart = queryIndex >= 0 ? withoutHash.slice(queryIndex) : "";
    const basePath = queryIndex >= 0 ? withoutHash.slice(0, queryIndex) : withoutHash;
    const match = basePath.match(/^(.*)\.webp$/i);
    if (!match || !match[1]) return raw;
    return `${match[1]}${suffix || ""}.webp${queryPart}${hashPart}`;
  };

  const appendCoverVariant = (url, width) => {
    const raw = (url || "").toString().trim();
    const parsedWidth = Number(width);
    if (!raw || !Number.isFinite(parsedWidth) || parsedWidth <= 0) return raw;
    if (parsedWidth <= 132) return buildCoverVariantUrl(raw, "-sm");
    if (parsedWidth <= 262) return buildCoverVariantUrl(raw, "-md");
    return buildCoverVariantUrl(raw, "");
  };

  const coverBase = manga && manga.cover ? cacheBust(manga.cover, manga.coverUpdatedAt) : "";
  const coverAmp = coverBase ? appendCoverVariant(coverBase, 420) : "";

  const buildLoginHref = (url) => {
    const raw = (url || "/").toString().trim() || "/";
    const separator = raw.includes("?") ? "&" : "?";
    return `${raw}${separator}auth=login`;
  };

  const loginHref = buildLoginHref(pageCanonical);
  const runtimeSiteConfig = siteConfig && typeof siteConfig === "object" ? siteConfig : {};
  const brandingConfig =
    runtimeSiteConfig.branding && typeof runtimeSiteConfig.branding === "object"
      ? runtimeSiteConfig.branding
      : {};
  const siteName = (brandingConfig.siteName || "BFANG Team").toString().trim() || "BFANG Team";
  const brandMark = (brandingConfig.brandMark || "BFANG").toString().trim() || "BFANG";
  const brandSubmark = (brandingConfig.brandSubmark || "Team").toString().trim() || "Team";
  const aboutNavLabel =
    (brandingConfig.aboutNavLabel || `Về ${brandMark}`).toString().trim() || `Về ${brandMark}`;
  const footerYear =
    (brandingConfig.footerYear || String(new Date().getFullYear())).toString().trim() || String(new Date().getFullYear());
  const authConfig = authPublicConfig && typeof authPublicConfig === "object" ? authPublicConfig : {};
  const initialAuthState =
    authConfig.initialState && typeof authConfig.initialState === "object" ? authConfig.initialState : null;
  const isInitiallySignedIn = Boolean(initialAuthState && initialAuthState.signedIn === true);
  const initialPublishNav =
    initialAuthState && initialAuthState.publishNav && typeof initialAuthState.publishNav === "object"
      ? initialAuthState.publishNav
      : null;
  const initialPublishLabel = isInitiallySignedIn && initialPublishNav && initialPublishNav.inTeam ? "Nhóm dịch" : "Đăng truyện";
  const initialPublishMode = initialPublishLabel === "Nhóm dịch" ? "team" : "publish";
  const seoData = seo && typeof seo === "object" ? seo : {};
  const seoTitle =
    (seoData.title || (manga && manga.title ? `${manga.title} | Đọc manga` : "Đọc manga")).toString().trim() ||
    "Đọc manga";
  const useAbsoluteSeoTitle = seoData.titleAbsolute === true;
  const normalizedSeoTitle = seoTitle.toLowerCase();
  const normalizedSiteName = siteName.toLowerCase();
  const composedSeoTitle = useAbsoluteSeoTitle || normalizedSeoTitle.includes(normalizedSiteName)
    ? seoTitle
    : `${seoTitle} — ${siteName}`;
  const seoDescription =
    (seoData.description || (manga && manga.description ? manga.description : `Đọc manga tại ${siteName}.`)).toString().trim() ||
    `Đọc manga tại ${siteName}.`;
  const seoKeywords = (seoData.keywords || "").toString().trim();
  const seoCanonical = (seoData.canonical || pageCanonical).toString().trim() || pageCanonical;
  const seoRobots =
    (seoData.robots || "index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1").toString().trim() ||
    "index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1";
  const seoOgType = (seoData.ogType || "article").toString().trim() || "article";
  const seoImage = (seoData.image || coverAmp || "").toString().trim();
  const seoTwitterCard = (seoData.twitterCard || (seoImage ? "summary_large_image" : "summary")).toString().trim();
  const routeJsonLdList =
    typeof ampSchemas !== "undefined" && Array.isArray(ampSchemas) ? ampSchemas : [];
  const seoJsonLdList = Array.isArray(seoData.jsonLd) ? seoData.jsonLd : routeJsonLdList;
  const fallbackJsonLdList = [
    {
      "@context": "https://schema.org",
      "@type": "ComicSeries",
      name: (manga && manga.title ? manga.title : composedSeoTitle).toString().trim() || composedSeoTitle,
      description: seoDescription,
      url: seoCanonical,
      inLanguage: "vi"
    }
  ];
  const finalJsonLdList = seoJsonLdList.length ? seoJsonLdList : fallbackJsonLdList;
  const safeJsonForScript = (value) => JSON.stringify(value)
    .replace(/</g, "\\u003c")
    .replace(/>/g, "\\u003e")
    .replace(/&/g, "\\u0026")
    .replace(/\u2028/g, "\\u2028")
    .replace(/\u2029/g, "\\u2029");
%>
<!doctype html>
<html amp lang="vi">
  <head>
    <meta charset="utf-8" />
    <title><%= composedSeoTitle %></title>
    <meta name="description" content="<%= seoDescription %>" />
    <% if (seoKeywords) { %>
      <meta name="keywords" content="<%= seoKeywords %>" />
      <meta name="news_keywords" content="<%= seoKeywords %>" />
    <% } %>
    <meta name="robots" content="<%= seoRobots %>" />
    <meta name="googlebot" content="<%= seoRobots %>" />
    <meta name="author" content="<%= siteName %>" />
    <meta name="theme-color" content="#0f0f11" />
    <meta property="og:locale" content="vi_VN" />
    <meta property="og:type" content="<%= seoOgType %>" />
    <meta property="og:site_name" content="<%= siteName %>" />
    <meta property="og:title" content="<%= composedSeoTitle %>" />
    <meta property="og:description" content="<%= seoDescription %>" />
    <meta property="og:url" content="<%= seoCanonical %>" />
    <% if (seoImage) { %>
      <meta property="og:image" content="<%= seoImage %>" />
    <% } %>
    <meta name="twitter:card" content="<%= seoTwitterCard %>" />
    <meta name="twitter:title" content="<%= composedSeoTitle %>" />
    <meta name="twitter:description" content="<%= seoDescription %>" />
    <% if (seoImage) { %>
      <meta name="twitter:image" content="<%= seoImage %>" />
    <% } %>
    <link rel="canonical" href="<%= seoCanonical %>" />
    <link rel="alternate" hreflang="vi-VN" href="<%= seoCanonical %>" />
    <link rel="alternate" hreflang="x-default" href="<%= seoCanonical %>" />
    <meta name="viewport" content="width=device-width,minimum-scale=1,initial-scale=1" />
    <% if (finalJsonLdList.length) { %>
      <% finalJsonLdList.forEach((schema) => { %>
        <script type="application/ld+json"><%- safeJsonForScript(schema) %></script>
      <% }) %>
    <% } %>
    <script async src="https://cdn.ampproject.org/v0.js"></script>
    <style amp-boilerplate>
      body {
        -webkit-animation: -amp-start 8s steps(1, end) 0s 1 normal both;
        -moz-animation: -amp-start 8s steps(1, end) 0s 1 normal both;
        -ms-animation: -amp-start 8s steps(1, end) 0s 1 normal both;
        animation: -amp-start 8s steps(1, end) 0s 1 normal both;
      }
      @-webkit-keyframes -amp-start {
        from {
          visibility: hidden;
        }
        to {
          visibility: visible;
        }
      }
      @-moz-keyframes -amp-start {
        from {
          visibility: hidden;
        }
        to {
          visibility: visible;
        }
      }
      @-ms-keyframes -amp-start {
        from {
          visibility: hidden;
        }
        to {
          visibility: visible;
        }
      }
      @-o-keyframes -amp-start {
        from {
          visibility: hidden;
        }
        to {
          visibility: visible;
        }
      }
      @keyframes -amp-start {
        from {
          visibility: hidden;
        }
        to {
          visibility: visible;
        }
      }
    </style>
    <noscript>
      <style amp-boilerplate>
        body {
          -webkit-animation: none;
          -moz-animation: none;
          -ms-animation: none;
          animation: none;
        }
      </style>
    </noscript>
    <style amp-custom>
      :root {
        --bg: #0f0f11;
        --panel: #17171b;
        --card: #1a1a1f;
        --border: #2f2f35;
        --text: #f4f4f6;
        --muted: #b2b2bc;
        --line: #3c3c45;
      }

      body {
        margin: 0;
        background: radial-gradient(circle at top, #171721 0%, var(--bg) 52%);
        color: var(--text);
        font-family: "Noto Sans JP", sans-serif;
      }

      .site {
        max-width: 1000px;
        margin: 0 auto;
        padding: 16px;
      }

      .site-header {
        border: 1px solid var(--border);
        border-radius: 14px;
        background: linear-gradient(150deg, #1d1d26 0%, #14141a 100%);
        margin-bottom: 14px;
        position: relative;
        z-index: 10;
      }

      .header-inner {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 10px;
        padding: 12px;
        flex-wrap: wrap;
        box-sizing: border-box;
      }

      .brand {
        color: var(--text);
        text-decoration: none;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        font-weight: 700;
        font-size: 13px;
        display: inline-flex;
        align-items: baseline;
        gap: 5px;
      }

      .brand__sub {
        color: var(--muted);
        font-size: 11px;
      }

      .header-actions {
        display: flex;
        align-items: center;
        gap: 7px;
        flex-wrap: wrap;
        min-width: 0;
      }

      .header-nav {
        display: inline-flex;
        align-items: center;
        gap: 7px;
      }

      .header-nav {
        display: flex;
        flex-wrap: wrap;
        justify-content: flex-end;
        gap: 7px;
      }

      .header-nav a {
        color: var(--text);
        text-decoration: none;
        font-size: 11px;
        border: 1px solid var(--line);
        border-radius: 999px;
        padding: 5px 10px;
      }

      .container {
        width: 100%;
        max-width: 100%;
        margin: 0 auto;
      }

      .site-header .header-inner {
        padding: 10px 12px;
      }

      .site-header .nav.hidden {
        display: flex;
        flex-wrap: wrap;
        gap: 7px;
        align-items: center;
      }

      .site-header .nav {
        display: flex;
        flex-wrap: wrap;
        gap: 7px;
        align-items: center;
      }

      .message-trigger,
      .notify-trigger,
      .auth-trigger {
        border: 1px solid var(--line);
        background: #15151b;
        color: var(--text);
        border-radius: 999px;
        width: 30px;
        height: 30px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
      }

      .notify-widget,
      .auth-widget,
      .message-trigger {
        display: inline-flex;
        align-items: center;
      }

      .notify-badge {
        margin-left: 4px;
        border-radius: 999px;
        background: #dc2626;
        color: #fff;
        font-size: 10px;
        padding: 1px 5px;
      }

      .auth-widget__profile {
        display: inline-flex;
        align-items: center;
      }

      .sr-only {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        border: 0;
      }

      .button,
      .button.button--ghost,
      .auth-menu__item,
      .inline-link {
        color: var(--text);
        text-decoration: none;
      }

      .button,
      .button.button--ghost,
      .auth-widget__login {
        border: 1px solid var(--line);
        border-radius: 999px;
        background: #15151b;
        padding: 6px 10px;
        font-size: 11px;
        line-height: 1;
      }

      .auth-widget__login {
        display: inline-flex;
        align-items: center;
        justify-content: center;
      }

      .auth-menu,
      .notify-menu,
      .modal,
      .hidden {
        display: none;
      }

      .site-footer .footer-inner {
        padding: 12px;
      }

      .topbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 10px;
        margin-bottom: 14px;
      }

      .topbar-actions {
        display: flex;
        align-items: center;
        gap: 8px;
      }

      .link {
        color: var(--text);
        text-decoration: none;
      }

      .link {
        font-size: 12px;
        border: 1px solid var(--line);
        border-radius: 999px;
        padding: 6px 11px;
      }

      .detail {
        border: 1px solid var(--border);
        border-radius: 14px;
        background: linear-gradient(150deg, #1c1c25 0%, #14141a 100%);
        padding: 14px;
      }

      .detail-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 14px;
      }

      .cover {
        border: 1px solid var(--border);
        border-radius: 10px;
        overflow: hidden;
        background: #101015;
        max-width: 280px;
      }

      h1 {
        margin: 0 0 8px;
        font-size: 26px;
        line-height: 1.3;
      }

      .meta {
        margin: 0 0 8px;
        color: var(--muted);
        font-size: 13px;
        line-height: 1.55;
      }

      .meta-inline {
        margin: 0 0 8px;
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 8px;
      }

      .meta-inline .chip {
        padding: 3px 9px;
        font-size: 11px;
      }

      .meta-inline .meta {
        margin: 0;
      }

      .note {
        margin: 0 0 10px;
        color: var(--muted);
        font-size: 12px;
        line-height: 1.6;
      }

      .detail-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-top: 10px;
      }

      .detail-action {
        display: inline-block;
        text-decoration: none;
        color: var(--text);
        border: 1px solid var(--line);
        border-radius: 999px;
        padding: 6px 12px;
        font-size: 12px;
      }

      .meta a {
        color: var(--text);
      }

      .chips {
        display: flex;
        flex-wrap: wrap;
        gap: 7px;
        margin: 10px 0;
      }

      .chip {
        color: var(--text);
        text-decoration: none;
        border: 1px solid var(--line);
        border-radius: 999px;
        padding: 4px 10px;
        font-size: 12px;
      }

      .desc {
        margin: 10px 0 0;
        font-size: 14px;
        line-height: 1.6;
        color: #d3d3db;
      }

      .section {
        margin-top: 16px;
      }

      .section-header {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 10px;
      }

      .section-header h2 {
        margin: 0;
        text-transform: uppercase;
        letter-spacing: 0.07em;
        font-size: 14px;
        white-space: nowrap;
      }

      .section-line {
        display: block;
        width: 100%;
        height: 1px;
        background: linear-gradient(to right, var(--line), transparent);
      }

      .chapter-list {
        list-style: none;
        margin: 0;
        padding: 0;
        border: 1px solid var(--border);
        border-radius: 11px;
        overflow: hidden;
        background: var(--card);
      }

      .chapter-list li + li {
        border-top: 1px solid #27272d;
      }

      .chapter-link {
        display: block;
        text-decoration: none;
        color: inherit;
        padding: 10px 12px;
      }

      .chapter-top {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        gap: 8px;
      }

      .chapter-main {
        font-size: 14px;
      }

      .chapter-date {
        color: var(--muted);
        font-size: 12px;
        white-space: nowrap;
      }

      .chapter-group {
        margin-top: 3px;
        color: var(--muted);
        font-size: 12px;
      }

      .chapter-submeta {
        margin-top: 3px;
        color: var(--muted);
        font-size: 11px;
      }

      .more-wrap {
        margin-top: 12px;
      }

      .more-button {
        display: inline-block;
        color: var(--text);
        text-decoration: none;
        border: 1px solid var(--line);
        border-radius: 999px;
        padding: 7px 14px;
        font-size: 13px;
      }

      .empty {
        margin: 0;
        color: var(--muted);
        font-size: 13px;
      }

      .site-footer {
        margin-top: 18px;
        border: 1px solid var(--border);
        border-radius: 12px;
        background: #141419;
      }

      .footer-inner {
        padding: 12px;
      }

      .footer-meta {
        display: flex;
        flex-direction: column;
        gap: 6px;
        color: var(--muted);
        font-size: 12px;
      }

      .footer-links {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        align-items: center;
      }

      .footer-links a {
        color: var(--text);
        text-decoration: none;
        font-size: 12px;
      }

      .footer-separator,
      .footer-links__legal-dot {
        color: #7f7f8a;
      }

      @media (max-width: 720px) {
        .header-inner {
          flex-direction: column;
          align-items: flex-start;
        }

        .header-nav {
          justify-content: flex-start;
        }
      }

      @media (min-width: 860px) {
        .detail-grid {
          grid-template-columns: 280px 1fr;
          align-items: start;
        }
      }
    </style>
  </head>
  <body>
    <div class="site">
      <header class="site-header">
        <div class="container header-inner">
          <a class="brand" href="/" aria-label="<%= `${brandMark} ${brandSubmark}`.trim() %>">
            <span class="brand__mark"><%= brandMark %></span>
            <span class="brand__sub"><%= brandSubmark %></span>
          </a>
          <div class="header-actions">
            <div class="header-nav">
              <nav class="nav" id="site-nav-links">
                <a href="/manga">Toàn bộ truyện</a>
                <% if (newsPageEnabled) { %>
                  <a href="/tin-tuc">Tin tức</a>
                <% } %>
                <% if (forumPageEnabled) { %>
                  <a href="/forum">Diễn đàn</a>
                <% } %>
                <a href="/publish" data-publish-nav-link data-publish-nav-mode="<%= initialPublishMode %>"><%= initialPublishLabel %></a>
                <a href="/#about"><%= aboutNavLabel %></a>
              </nav>
            </div>
            <a
              class="message-trigger"
              href="/messages"
              <%= isInitiallySignedIn ? "" : "hidden" %>
              data-auth-member-only="1"
              data-message-widget
              title="Tin nhắn"
            >
              <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M21 14.2a3.8 3.8 0 0 1-3.8 3.8H9l-4.5 3v-3.4A3.8 3.8 0 0 1 1 13.8V6.8A3.8 3.8 0 0 1 4.8 3h12.4A3.8 3.8 0 0 1 21 6.8z" />
              </svg>
              <span class="notify-badge" hidden data-message-badge>0</span>
              <span class="sr-only">Tin nhắn</span>
            </a>
            <div class="notify-widget" <%= isInitiallySignedIn ? "" : "hidden" %> data-notify-widget>
              <button
                class="notify-trigger"
                type="button"
                data-notify-toggle
                aria-haspopup="menu"
                aria-expanded="false"
                title="Thông báo"
              >
                <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M6.8 9a5.2 5.2 0 1 1 10.4 0v3.1c0 .8.3 1.5.8 2.1l1.1 1.3H5l1.1-1.3c.5-.6.8-1.3.8-2.1z" />
                  <path d="M9.8 18.1a2.2 2.2 0 0 0 4.4 0" />
                </svg>
                <span class="notify-badge" hidden data-notify-badge>0</span>
                <span class="sr-only">Thông báo</span>
              </button>
            </div>
            <div class="auth-widget" data-auth-widget>
              <a
                class="button button--ghost auth-widget__login"
                href="<%= loginHref %>"
                target="_top"
                <%= isInitiallySignedIn ? "hidden" : "" %>
              >
                Đăng nhập
              </a>
              <div class="auth-widget__profile" <%= isInitiallySignedIn ? "" : "hidden" %> data-auth-profile>
                <button
                  class="auth-trigger"
                  type="button"
                  data-auth-menu-toggle
                  aria-haspopup="menu"
                  aria-expanded="false"
                  title="Tài khoản"
                >
                  <svg
                    class="auth-trigger__fallback"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.6"
                    aria-hidden="true"
                  >
                    <circle cx="12" cy="8" r="4" />
                    <path d="M4 20c1.6-3.5 5-5 8-5s6.4 1.5 8 5" />
                  </svg>
                </button>
              </div>
            </div>
          </div>
        </div>
      </header>
      <main class="amp-main">

      <section class="detail">
        <div class="detail-grid">
          <div>
            <% if (coverAmp) { %>
              <div class="cover">
                <amp-img src="<%= coverAmp %>" width="420" height="630" layout="responsive" alt="Bìa <%= manga.title %>"></amp-img>
              </div>
            <% } %>
          </div>

          <div>
            <h1><%= manga && manga.title ? manga.title : "Manga" %></h1>

            <% if (groupLinks.length) { %>
              <p class="meta">
                Nhóm dịch:
                <% groupLinks.forEach((item, index) => { %>
                  <% if (item.url) { %>
                    <a href="<%= item.url %>"><%= item.label %></a>
                  <% } else { %>
                    <span><%= item.label %></span>
                  <% } %><%= index < groupLinks.length - 1 ? ", " : "" %>
                <% }) %>
              </p>
            <% } %>

            <% if (authorList.length) { %>
              <p class="meta">
                Tác giả:
                <% authorList.forEach((authorName, index) => { %>
                  <a href="/manga?q=<%= encodeURIComponent(authorName) %>"><%= authorName %></a><%= index < authorList.length - 1 ? ", " : "" %>
                <% }) %>
              </p>
            <% } %>

            <div class="meta-inline">
              <span class="chip"><%= manga && manga.status ? manga.status : "Đang cập nhật" %></span>
              <% if (formattedUpdatedAt) { %>
                <p class="meta">Cập nhật <%= formattedUpdatedAt %></p>
              <% } %>
            </div>

            <% if (otherNameList.length) { %>
              <p class="note">Tên khác: <%= otherNameList.join(" • ") %></p>
            <% } %>

            <% if (Array.isArray(manga && manga.genres) && manga.genres.length) { %>
              <div class="chips">
                <% manga.genres.forEach((genre) => { %>
                  <a class="chip" href="/manga?include=<%= encodeURIComponent(genre) %>"><%= genre %></a>
                <% }) %>
              </div>
            <% } %>

            <% if (manga && manga.description) { %>
              <p class="desc"><%= manga.description %></p>
            <% } %>

            <div class="detail-actions">
              <a class="detail-action" href="<%= commentHref %>">Xem bình luận</a>
            </div>
          </div>
        </div>
      </section>

      <section class="section">
        <div class="section-header">
          <h2>Danh sách chương</h2>
          <span class="section-line"></span>
        </div>

        <% if (!visibleChapters.length) { %>
          <p class="empty">Chưa có chương nào được đăng.</p>
        <% } else { %>
          <ul class="chapter-list">
            <% visibleChapters.forEach((chapter) => { %>
              <% const isOneshotChapter = Boolean(chapter && chapter.is_oneshot); %>
              <% const chapterLabel = isOneshotChapter ? "Oneshot" : `Ch. ${chapter.number}`; %>
              <% const chapterTitle = (chapter && chapter.title ? chapter.title : "").toString().trim(); %>
              <% const chapterGroups = (chapter && chapter.group_name ? chapter.group_name : "")
                .toString()
                .split(",")
                .map((value) => value.trim())
                .filter(Boolean); %>
              <li>
                <a class="chapter-link" href="/manga/<%= encodeURIComponent(manga.slug) %>/chapters/<%= encodeURIComponent(String(chapter.number)) %>">
                  <div class="chapter-top">
                    <div class="chapter-main">
                      <%= chapterLabel %><%= chapterTitle ? ` - ${chapterTitle}` : "" %>
                      <% if (chapter && chapter.has_password) { %>
                        <span title="Chương có mật khẩu" aria-label="Chương có mật khẩu">&#128274;</span>
                      <% } %>
                      <% if (chapter && chapter.interaction_boost_enabled) { %>
                        <span title="Chương yêu cầu bình luận ở chương trước" aria-label="Chương yêu cầu bình luận ở chương trước">&#128172;</span>
                      <% } %>
                    </div>
                    <div class="chapter-date"><%= chapter && chapter.date ? formatDate(chapter.date) : "" %></div>
                  </div>
                  <% if (chapterGroups.length) { %>
                    <div class="chapter-group"><%= chapterGroups.join(", ") %></div>
                  <% } %>
                  <% if (chapter && Number.isFinite(Number(chapter.pages))) { %>
                    <div class="chapter-submeta"><%= Number(chapter.pages) %> trang</div>
                  <% } %>
                </a>
              </li>
            <% }) %>
          </ul>

          <% if (hiddenChapterCount > 0) { %>
            <div class="more-wrap">
              <a class="more-button" href="<%= pageCanonical %>">Xem thêm</a>
            </div>
          <% } %>
        <% } %>
      </section>

      </main>
      <footer class="site-footer">
        <div class="container footer-inner">
          <div class="footer-meta">
            <span>© <%= footerYear %> <%= siteName %></span>
            <div class="footer-links">
              <a href="/manga">Toàn bộ truyện</a>
              <% if (newsPageEnabled) { %>
                <span class="footer-separator" aria-hidden="true">·</span>
                <a href="/tin-tuc">Tin tức</a>
              <% } %>
              <% if (forumPageEnabled) { %>
                <span class="footer-separator" aria-hidden="true">·</span>
                <a href="/forum">Diễn đàn</a>
              <% } %>
              <span class="footer-separator" aria-hidden="true">·</span>
              <a href="/privacy-policy">Privacy Policy</a>
              <span class="footer-links__legal-dot" aria-hidden="true">·</span>
              <a href="/terms-of-service">Terms of Service</a>
              <span class="footer-links__legal-dot" aria-hidden="true">&middot;</span>
              <a href="/copyright">Copyright</a>
            </div>
          </div>
        </div>
      </footer>
    </div>
  </body>
</html>
