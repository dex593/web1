{
  "name": "bfang-manga",
  "version": "1.0.0",
  "description": "BFANG Team manga upload site",
  "main": "server.js",
  "scripts": {
    "setup:all": "bun scripts/setup-all.js",

    "build": "bun run assets:build",
    "prestart": "bun run assets:build",
    "start": "bun server.js",

    "predev": "bun scripts/predev-styles.js",
    "dev": "bun server.js",

    "test:forum:unit": "bun test --cwd sampleforum",
    "test:forum:smoke": "bun scripts/forum-smoke-check.js",
    "test:forum": "bun run test:forum:unit && bun run test:forum:smoke",

    "forum:cleanup:image-posts": "bun scripts/cleanup-forum-image-posts.js",
    "forum:scope:audit": "bun scripts/fix-forum-comment-scope.js",
    "forum:scope:fix": "bun scripts/fix-forum-comment-scope.js --apply",
    "forum:notifications:fix": "bun scripts/fix-forum-notification-links.js",

    "assets:build": "vite build --config vite.config.js",
    "assets:watch": "vite build --config vite.config.js --watch",
    "styles:build": "bun run assets:build",
    "styles:watch": "bun run assets:watch",

    "purge:tmp": "bun scripts/purge-tmp.js",
    "backup:db": "bun scripts/backup-db.js",
    "restore:db": "bun scripts/restore-db.js",

    "db:schema:json:sync": "bun scripts/sync-db-json.js",
    "db:schema:json:sync:all": "bun scripts/sync-db-json.js --all",
    "db:schema:sync": "bun scripts/sync-db-schema.js",
    "db:schema:sync:strict": "bun scripts/sync-db-schema.js --include-destructive",

    "db:init:maintenance": "bun scripts/run-init-maintenance.js",
    "db:init:maintenance:apply": "bun scripts/run-init-maintenance.js --apply",

    "db:manga:slugs:migrate": "bun scripts/migrate-manga-slugs.js",

    "db:forum:repair": "bun scripts/repair-forum-storage.js",
    "db:forum:repair:apply": "bun scripts/repair-forum-storage.js --apply",

    "db:purge:deleted": "bun scripts/purge-soft-deleted.js",

    "media:sync:s3": "bun scripts/sync-media-to-s3.js",
    "media:sync:s3:apply": "bun scripts/sync-media-to-s3.js --apply",

    "db:bootstrap": "bun scripts/db-bootstrap.js",
    "db:bootstrap:strict": "bun scripts/db-bootstrap.js --strict"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.988.0",
    "@emoji-mart/data": "^1.2.1",
    "browser-image-compression": "^2.0.2",
    "clean-css": "^5.3.3",
    "compression": "^1.8.1",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.9",
    "emoji-mart": "^5.6.0",
    "express": "^4.18.2",
    "express-session": "^1.18.0",
    "googleapis": "^140.0.1",
    "ioredis": "^5.10.1",
    "multer": "^2.0.2",
    "ora": "^8.2.0",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-oauth2": "^1.8.0",
    "pg": "^8.13.1",
    "sharp": "^0.34.5",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "autoprefixer": "^10.5.0",
    "flowbite": "^2.5.2",
    "postcss": "^8.5.11",
    "purgecss": "^7.0.2",
    "tailwindcss": "^3.4.17",
    "vite": "^8.0.10"
  }
}
