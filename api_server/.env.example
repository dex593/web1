PORT=3001

# Postgres (same DB as web server)
DATABASE_URL=postgres://user:pass@localhost:5432/bfang

# Must match SESSION_SECRET of web server for API key hash verification
API_KEY_SECRET=replace-with-web-session-secret

# Shared secret for chapter upload proof (should match web server)
CHAPTER_UPLOAD_SHARED_SECRET=

# Internal media upload proof secret (should match web server)
MEDIA_UPLOAD_SHARED_SECRET=

# URL to build cover links for desktop UI
WEB_BASE_URL=http://127.0.0.1:3000

# Optional CORS allowlist for browser clients (comma or space separated origins)
# Include both localhost and 127.0.0.1 variants for local dev if needed.
# API_ALLOWED_ORIGINS=http://127.0.0.1:3000 http://localhost:3000 https://moetruyen.net

# S3-compatible storage
# - S3_BUCKET: bucket ảnh chương truyện
# - S3_MEDIA_BUCKET: bucket ảnh bìa/avatars
S3_BUCKET=
S3_MEDIA_BUCKET=uploads.moetruyen.net
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true
S3_CHAPTER_PREFIX=chapters
S3_MEDIA_PREFIX=uploads

# CDN base URL used to build returned media links
MEDIA_CDN_BASE_URL=https://uploads.moetruyen.net
