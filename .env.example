PORT=3000
DATABASE_URL=postgresql://postgres:12345@localhost:5432/xxx

# database url tin tức:
# NEWS_DATABASE_URL=postgresql://postgres:12345@localhost:5432/amnews

# Bật/tắt toàn bộ mục Tin tức: on/off (mặc định: on)
NEWS_PAGE_ENABLED=off

# Bật/tắt toàn bộ mục Diễn đàn: true/false (mặc định: false)
FORUM_PAGE_ENABLED=false

# Redis cache theo key nghiệp vụ (endpoint/business)
# Bật/tắt cache Redis tổng thể
REDIS_CACHE_ENABLED=true
# URL kết nối Redis (bắt buộc nếu muốn dùng Redis)
REDIS_URL=redis://127.0.0.1:6379/0
# Prefix key để tránh đụng key hệ thống khác
REDIS_PREFIX=bfang
# TTL mặc định cho helper Redis (giây)
REDIS_DEFAULT_TTL_SECONDS=30
# Timeout kết nối Redis (ms)
REDIS_CONNECT_TIMEOUT_MS=5000
# Khoảng chờ thử reconnect Redis (ms)
REDIS_RECONNECT_RETRY_MS=15000

# Bật/tắt business-key cache layer (fallback biến cũ: SQL_REDIS_CACHE_ENABLED)
REDIS_BUSINESS_CACHE_ENABLED=true
# Chu kỳ refresh version key của business cache (ms)
# (fallback biến cũ: SQL_REDIS_CACHE_VERSION_REFRESH_MS)
REDIS_CACHE_VERSION_REFRESH_MS=1500

# TTL endpoint cache theo nghiệp vụ (Redis, giây)
ENDPOINT_CACHE_HOMEPAGE_TTL_SECONDS=45
ENDPOINT_CACHE_MANGA_LIST_TTL_SECONDS=180
ENDPOINT_CACHE_MANGA_DETAIL_TTL_SECONDS=300
ENDPOINT_CACHE_CHAPTER_DETAIL_TTL_SECONDS=450
ENDPOINT_CACHE_FORUM_HOME_TTL_SECONDS=45

# Kiểm soát nội dung Adult:
# - true  = không kiểm soát (không ẩn với khách, không blur/cảnh báo 18+)
# - false = có kiểm soát (ẩn với khách + blur/cảnh báo 18+)
ADULT_CONTENT_CONTROL=true

# Admin đăng nhập mật khẩu (có thể tắt để chỉ dùng badge-admin qua OAuth)
ADMIN_USER=admin
ADMIN_PASS=12345
ADMIN_PASSWORD_LOGIN_ENABLED=1

APP_ENV=development

# APP_ENV=development => dùng http://localhost:PORT
# APP_ENV=production  => dùng https://<APP_DOMAIN>

APP_DOMAIN=example.com
SITE_URL=https://example.com
PUBLIC_SITE_URL=https://example.com

# Tùy chọn ép callback OAuth về domain cố định
OAUTH_CALLBACK_BASE_URL=https://example.com

# Minify JS khi server khởi động (1 = bật, 0 = tắt)
JS_MINIFY_ENABLED=1

SESSION_SECRET=chuoi-ngau-nhien-dai
# Giữ ổn định phiên đăng nhập qua các lần restart server (tuỳ chọn)
# SERVER_SESSION_VERSION=moetruyen-session-v1
TRUST_PROXY=1
SESSION_COOKIE_SECURE=false

# Múi giờ dùng để ghi/đọc thống kê view theo ngày (BXH tuần/tháng)
# Mặc định: Asia/Ho_Chi_Minh
# VIEW_STATS_TIMEZONE=Asia/Ho_Chi_Minh

# OAuth providers (bật provider tương ứng khi đủ cặp ID/SECRET)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Google Drive upload cho ảnh bình luận/tin nhắn
GOOGLE_DRIVE_UPLOAD_ENABLED=false
COMMENT_IMAGE_UPLOAD_ENABLED=false
MESSAGE_IMAGE_UPLOAD_ENABLED=false
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REFRESH_TOKEN=
GOOGLE_DRIVE_FOLDER_ID=

# Cloudflare Turnstile (khuyến nghị bật cho form bình luận)
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# S3-compatible object storage
# - S3_BUCKET: bucket ảnh chương truyện
# - S3_MEDIA_BUCKET: bucket ảnh bìa/avatars
S3_ENDPOINT=
S3_BUCKET=
S3_MEDIA_BUCKET=uploads.moetruyen.net
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=true
CHAPTER_CDN_BASE_URL=https://i.example.com
S3_CHAPTER_PREFIX=chapters
S3_MEDIA_PREFIX=uploads

# Optional: CDN base URL cho avatar/cover (nếu để trống sẽ dùng CHAPTER_CDN_BASE_URL)
MEDIA_CDN_BASE_URL=https://uploads.moetruyen.net

# Optional: upload trang chương trực tiếp sang api_server (giảm tải web chính)
# Ví dụ: http://127.0.0.1:3001 hoặc https://api.example.com
CHAPTER_UPLOAD_API_URL=

# Optional: api_server chuyên upload media (avatar/cover); nếu trống sẽ dùng CHAPTER_UPLOAD_API_URL
MEDIA_UPLOAD_API_URL=

# Shared secret để web ký proof gọi api_server upload media/chapter
CHAPTER_UPLOAD_SHARED_SECRET=
MEDIA_UPLOAD_SHARED_SECRET=

# Thiết lập .env khuyến nghị production:
# APP_ENV=production
# SITE_URL=https://example.com
# PUBLIC_SITE_URL=https://example.com
# OAUTH_CALLBACK_BASE_URL=https://example.com
# SESSION_SECRET=<chuoi-ngau-nhien-dai-it-nhat-32-ky-tu>
# SESSION_COOKIE_SECURE=true
# TRUST_PROXY=1 (nếu chạy sau Nginx/Cloudflare/Render/Heroku proxy)
# ADMIN_PASSWORD_LOGIN_ENABLED=0 (khuyên dùng để chỉ cho phép badge-admin)
# CSP_ENABLED=true
# CSP_REPORT_ONLY=false
