{
  "name": "bfang-desktop-bulk-uploader",
  "version": "1.0.0",
  "private": true,
  "description": "Electron desktop app for bulk chapter uploads",
  "author": "MoeTruyen",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "styles:build": "tailwindcss -c tailwind.config.js -i ./renderer/styles.source.css -o ./renderer/styles.css --minify",
    "styles:watch": "tailwindcss -c tailwind.config.js -i ./renderer/styles.source.css -o ./renderer/styles.css --watch",
    "icon:sync": "node scripts/sync-web-favicon.js",
    "build:win": "set CSC_IDENTITY_AUTO_DISCOVERY=false&& npm run icon:sync&& electron-builder --win portable --x64",
    "build:win:lite": "set CSC_IDENTITY_AUTO_DISCOVERY=false&& npm run icon:sync&& electron-builder --win nsis --x64"
  },
  "build": {
    "appId": "net.moetruyen.desktopuploader",
    "productName": "Moetruyen Batch Uploader",
    "asar": true,
    "compression": "maximum",
    "electronLanguages": [
      "en-US"
    ],
    "directories": {
      "output": "dist"
    },
    "asarUnpack": [
      "node_modules/sharp/**/*",
      "node_modules/@img/**/*"
    ],
    "files": [
      "main.js",
      "renderer/**/*",
      "assets/**/*",
      "package.json"
    ],
    "win": {
      "icon": "assets/icon.ico",
      "signAndEditExecutable": false,
      "artifactName": "moetruyen-uploader-${version}.exe"
    }
  },
  "dependencies": {
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "electron": "^31.2.1",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.45",
    "autoprefixer": "^10.4.20",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7"
  }
}
